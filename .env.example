# ── Aplikacja ─────────────────────────────────────────────
# Port: na SeoHost/Passenger ustawiany automatycznie. Lokalnie domyślnie 3000.
PORT=3000
# Adres publiczny aplikacji (do budowania linków w mailach). Bez ukośnika na końcu.
APP_URL=http://localhost:3000
NODE_ENV=development

# ── Logowanie admina (jedno konto na czas MVP) ────────────
ADMIN_EMAIL=radek.biedermann@me.com
# Na start możesz wpisać hasło jawnie. Zalecane: wygeneruj hash poleceniem
#   npm run hash -- "twoje-haslo"
# i wklej go do ADMIN_PASSWORD_HASH (wtedy ADMIN_PASSWORD jest ignorowane).
ADMIN_PASSWORD=zmien-to-haslo
ADMIN_PASSWORD_HASH=

# Sekret do podpisywania sesji (ciasteczka logowania). Wpisz długi losowy ciąg.
SESSION_SECRET=zmien-na-dlugi-losowy-ciag

# ── Baza danych (SQLite — plik na dysku) ──────────────────
DATABASE_URL="file:../storage/evoke.db"

# ── Pliki ─────────────────────────────────────────────────
# Katalog na pliki użytkowników (poza public_html!).
STORAGE_DIR=./storage/transfers

# ── Poczta (SMTP) ─────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Evoke Transfer <no-reply@twojadomena.pl>"
