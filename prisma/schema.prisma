// Model danych Evoke Transfer.
// SQLite na start (jeden plik). Aby przejść na PostgreSQL w przyszłości,
// zmień provider na "postgresql" i DATABASE_URL — reszta zostaje.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Użytkownik agencji. W MVP logujemy się przez .env (jedno konto),
// tabela istnieje pod przyszłą obsługę wielu użytkowników.
model User {
  id           Int        @id @default(autoincrement())
  email        String     @unique
  passwordHash String
  name         String?
  role         String     @default("admin")
  createdAt    DateTime   @default(now())
  transfers    Transfer[]
}

// Projekt — pojemnik grupujący transfery, pliki i historię.
// Klient agencji — może mieć wiele projektów. Dostęp do swoich projektów
// przez publiczny token (/c/:token), bez logowania.
model Client {
  id        Int       @id @default(autoincrement())
  name      String                        // nazwa wyświetlana / pełna (firma lub osoba)
  firstName String?                       // imię (opcjonalne) — personalizacja maili, placeholder {imie}
  lastName  String?                       // nazwisko (opcjonalne) — placeholder {nazwisko}
  email     String?
  company   String?
  phone     String?
  nip       String?                       // NIP nabywcy (na dokument rozliczenia)
  address   String?                       // adres nabywcy (na dokument rozliczenia)
  status    String    @default("active") // lead | active | inactive
  tags      String?                       // wolny tekst, oddzielone przecinkami
  token     String    @unique
  note      String?
  createdAt DateTime  @default(now())
  projects  Project[]
  events    Event[]
  charges   Charge[]                      // pozycje rozliczeniowe „bez projektu" (wprost na kliencie)
  messages  Message[]                     // wiadomości od klienta (z portalu /c)
  reminders Reminder[]                    // zadania/przypomnienia powiązane z klientem
}

model Project {
  id                 Int        @id @default(autoincrement())
  name               String
  clientName         String?    // wolny tekst (legacy) — etykieta, gdy brak przypisanego klienta
  client             Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientId           Int?
  description        String?
  status             String     @default("active") // active | archived
  stage              String     @default("active") // pipeline (kanban): lead | active | delivered | paid
  position           Int        @default(0)         // ręczna kolejność (drag & drop) na liście projektów
  clientToken        String?    @unique             // publiczny link do panelu klienta /p/:token
  clientPasswordHash String?                         // opcjonalne hasło do panelu klienta
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  transfers          Transfer[]
  events             Event[]
  charges            Charge[]
  messages           Message[]
  reminders          Reminder[]
}

// Pozycja rozliczeniowa (kwota). „Czasami po kilka" → osobne wiersze.
// Należy do PROJEKTU (projectId) LUB wprost do KLIENTA (clientId, „bez projektu").
// Reguła: ustawione dokładnie jedno z nich. Klient pozycji = clientId ?? project.clientId.
// Kwota w GROSZACH (Int). paidAt = data rozliczenia (null = nierozliczone).
model Charge {
  id        Int       @id @default(autoincrement())
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId Int?
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  clientId  Int?
  label     String?
  amount    Int       @default(0) // w groszach
  date      DateTime? // data pozycji (do filtrowania zakresem i na wydruku)
  dueDate   DateTime? // termin płatności (wiekowanie należności + przypomnienia)
  paidAt    DateTime?
  remindedAt DateTime? // kiedy ostatnio wysłano przypomnienie o tej pozycji
  note      String?
  createdAt DateTime  @default(now())

  @@index([projectId])
  @@index([clientId])
}

// Transfer — jeden obiekt obsługuje OBA kierunki (pole direction):
//   outgoing = agencja → klient (link /t/:token, pobieranie)
//   incoming = klient → agencja (formularz uploadu /upload/:token)
model Transfer {
  id            Int       @id @default(autoincrement())
  project       Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId     Int?
  direction     String    @default("outgoing") // outgoing | incoming
  token         String    @unique               // publiczny identyfikator w URL
  title         String?
  message       String?
  passwordHash  String?                          // opcjonalna ochrona hasłem
  expiresAt     DateTime?                         // opcjonalna data wygaśnięcia
  expiryWarnedAt DateTime?                        // kiedy wysłano ostrzeżenie o wygasaniu (anty-powtórka)
  maxDownloads  Int?                             // opcjonalny limit pobrań
  downloadCount Int       @default(0)
  clientVisible Boolean   @default(false)         // czy pokazać w panelu klienta /p/:token
  notifyOnDownload Boolean @default(false)         // e-mail do agencji przy pierwszym pobraniu
  proofing      Boolean   @default(false)          // proofing: poproś klienta o akceptację plików
  approvalStatus String?                           // null = oczekuje | approved | changes
  approvalComment String?                          // komentarz klienta (wymagany przy poprawkach)
  approvalBy    String?                            // kto zdecydował (imię wpisane przez klienta, opc.)
  approvalAt    DateTime?                          // kiedy podjęto decyzję
  status        String    @default("active")     // active | expired | deleted
  createdBy     User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdById   Int?
  createdAt     DateTime  @default(now())
  files         File[]
  events        Event[]
  messages      Message[]
}

// Pojedynczy plik należący do transferu.
model File {
  id           Int      @id @default(autoincrement())
  transfer     Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  transferId   Int
  originalName String   // nazwa widoczna dla użytkownika
  storedName   String   // bezpieczna nazwa na dysku
  storedPath   String   // ścieżka względna w STORAGE_DIR
  size         BigInt   @default(0)
  mimeType     String?
  createdAt    DateTime @default(now())
}

// Zdarzenie — napędza jednocześnie HISTORIĘ projektu, POWIADOMIENIA i widżety dashboardu.
model Event {
  id         Int       @id @default(autoincrement())
  project    Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId  Int?
  transfer   Transfer? @relation(fields: [transferId], references: [id], onDelete: Cascade)
  transferId Int?
  client     Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientId   Int?      // oś czasu klienta; SetNull — usunięcie klienta nie kasuje historii
  type       String    // created | downloaded | uploaded | email_sent | expired | error | note
  message    String?
  meta       String?   // dodatkowe dane jako JSON (string)
  isRead     Boolean   @default(false) // dla powiadomień w panelu
  dismissed  Boolean   @default(false) // ukryte z listy powiadomień (historia projektu zostaje)
  ip         String?
  createdAt  DateTime  @default(now())
}

// Ustawienia / branding — jeden wiersz (id = 1). Cała customizacja w jednym miejscu.
model Settings {
  id           Int      @id @default(1)
  appName      String   @default("Evoke LINK")
  logoPath     String?
  faviconPath  String?
  ogImagePath  String?  // obraz podglądu linku (OpenGraph); puste = używane jest logo
  colors       String?  // JSON: { primary, adminAccent, adminText, adminSidebar, adminBg }
  texts        String?  // JSON: { heroTitle, heroSubtitle, footer, messages }
  background   String?  // JSON: { type, preset, color, custom, imagePath, overlay, grain, grainStrength } — tło stron klienta
  logo         String?  // JSON: { size, align } — prezentacja logo (wysokość px, wyrównanie)
  layout       String?  // JSON: { style, card, heroOnBg, applyToLogin, radius, button } — układ stron klienta
  customCss    String?  // dowolny CSS wstrzykiwany do stron (escape hatch dla admina)
  emails       String?  // JSON: { logoPath, linkSubject, linkIntro, uploadSubject, downloadSubject, clientConfirm, clientConfirmSubject, clientConfirmBody }
  pdf          String?  // JSON: { template, logoHeight } — wygląd wydruku PDF rozliczenia
  updatedAt    DateTime @updatedAt
}

// Wiadomość od klienta (Faza A: jednokierunkowo klient → agencja). Przypięta do kontekstu,
// z którego wysłano: projekt (/p), transfer (/t) lub klient (/c). `direction` pod przyszłe odpowiedzi.
model Message {
  id          Int       @id @default(autoincrement())
  body        String
  senderName  String?
  senderEmail String?
  direction   String    @default("in") // in = klient→agencja (out = przyszłe odpowiedzi agencji)
  client      Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientId    Int?
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId   Int?
  transfer    Transfer? @relation(fields: [transferId], references: [id], onDelete: SetNull)
  transferId  Int?
  isRead      Boolean   @default(false)
  ip          String?
  createdAt   DateTime  @default(now())

  @@index([clientId])
  @@index([projectId])
  @@index([transferId])
}

// Zadanie/przypomnienie w kalendarzu (menedżer zadań). Opcjonalnie powiązane z klientem/projektem.
model Reminder {
  id        Int       @id @default(autoincrement())
  title     String
  note      String?
  dueAt     DateTime  // termin (data + godzina)
  done      Boolean   @default(false)
  doneAt    DateTime?
  priority  String    @default("normal") // low | normal | high
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientId  Int?
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId Int?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([dueAt])
  @@index([clientId])
  @@index([projectId])
}
