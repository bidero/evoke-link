# Zależności
node_modules/

# Konfiguracja lokalna i sekrety
.env

# Pliki użytkowników i baza danych
storage/transfers/*
!storage/transfers/.gitkeep
storage/tmp/*
!storage/tmp/.gitkeep
storage/*.db
storage/*.db-journal
storage/*.db-wal
storage/*.db-shm

# Sesje (session-file-store)
sessions/

# Backupy (ZIP bazy + plików) — generowane przez src/jobs/backup.job.js
backups/

# Zbudowany CSS jest COMMITOWANY (na hostingu produkcyjnym nie ma Tailwinda —
# build:css uruchamiamy lokalnie i wrzucamy wynik do repo).

# Wgrane logo/favicon (branding) — pliki użytkownika
public/branding/*
!public/branding/.gitkeep

# Logi i systemowe
*.log
.DS_Store
Thumbs.db

# Sygnał restartu Passengera (tworzony przy wdrożeniu)
tmp/restart.txt
