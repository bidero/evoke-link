{
  "name": "evoke-transfer",
  "version": "0.99.12",
  "private": true,
  "description": "Evoke Transfer — prywatny system wymiany plików agencja↔klient",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "node app.js",
    "test": "node --test --test-concurrency=1",
    "build:css": "tailwindcss -i ./src/assets/css/input.css -o ./public/css/app.css --minify",
    "watch:css": "tailwindcss -i ./src/assets/css/input.css -o ./public/css/app.css --watch",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "cleanup": "node src/jobs/cleanup.job.js",
    "backup": "node src/jobs/backup.job.js",
    "reminders": "node src/jobs/reminders.job.js",
    "hash": "node scripts/hash-password.js",
    "set-password": "node scripts/set-password.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "cookie-session": "^2.1.0",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.0.0",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.1",
    "pdfmake": "^0.2.7",
    "prisma": "^5.22.0",
    "qrcode-generator": "^2.0.4"
  },
  "devDependencies": {
    "alpinejs": "^3.15.12",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "sortablejs": "^1.15.6",
    "tailwindcss": "^3.4.17"
  },
  "allowScripts": {
    "prisma@5.22.0": true
  },
  "browserslist": [
    "defaults",
    "Safari >= 12",
    "iOS >= 12"
  ]
}
