<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script>try{if(localStorage.getItem('evoke-theme')==='dark')document.documentElement.classList.add('dark')}catch(e){}window.toggleTheme=function(){var d=document.documentElement.classList.toggle('dark');try{localStorage.setItem('evoke-theme',d?'dark':'light')}catch(e){}};</script>
  <% const appName = (typeof settings !== 'undefined' && settings) ? settings.appName : 'Evoke LINK'; %>
  <title><%= typeof title !== 'undefined' ? title + ' — ' + appName : appName %></title>
  <link rel="stylesheet" href="/css/app.css" />
  <% if (typeof settings !== 'undefined' && settings && settings.faviconPath) { %><link rel="icon" href="<%= settings.faviconPath %>" /><% } %>
  <%- typeof adminStyleTag !== 'undefined' ? adminStyleTag : '' %>
  <%- typeof darkStyleTag !== 'undefined' ? darkStyleTag : '' %>
  <%- typeof customStyleTag !== 'undefined' ? customStyleTag : '' %>
  <script src="/js/chunked-upload.js"></script>
  <script defer src="/js/alpine.min.js"></script>
</head>
<body class="bg-[var(--admin-bg)] antialiased" style="color: var(--admin-text)" x-data="{ nav: false }">
  <div class="min-h-screen flex">
    <!-- Przyciemnienie tła pod offcanvas (mobile) -->
    <div x-show="nav" x-cloak @click="nav = false" class="fixed inset-0 bg-black/40 z-30 md:hidden"></div>

    <!-- Pasek boczny (offcanvas na mobile, statyczny od md) -->
    <aside class="fixed inset-y-0 left-0 z-40 w-60 shrink-0 bg-[var(--admin-sidebar)] border-r border-slate-200/60 flex flex-col transition-transform -translate-x-full md:static md:translate-x-0"
           :class="nav && '!translate-x-0'" style="color: var(--admin-sidebar-text)">
      <div class="h-16 flex items-center gap-2 px-6 border-b border-black/5">
        <% if (typeof settings !== 'undefined' && settings && settings.logoPath) { %>
          <%- logoTag(settings, { appName, imgClass: 'h-8 max-w-[140px] object-contain' }) %>
        <% } else { %>
          <div class="w-8 h-8 rounded-lg bg-brand-600 flex items-center justify-center text-white font-bold">E</div>
          <span class="font-semibold tracking-tight"><%= appName %></span>
        <% } %>
      </div>
      <nav class="flex-1 px-3 py-4 space-y-1 text-sm">
        <% const items = [
          { key: 'dashboard', label: 'Pulpit', href: '/admin' },
          { key: 'projects', label: 'Projekty', href: '/admin/projects' },
          { key: 'clients', label: 'Klienci', href: '/admin/clients' },
          { key: 'transfers', label: 'Transfery', href: '/admin/transfers' },
          { key: 'notifications', label: 'Powiadomienia', href: '/admin/notifications' },
          { key: 'settings', label: 'Ustawienia', href: '/admin/settings' }
        ]; %>
        <% const unread = (typeof unreadCount !== 'undefined') ? unreadCount : 0; %>
        <% items.forEach(function(it){ %>
          <a href="<%= it.href %>"
             class="flex items-center justify-between px-3 py-2 rounded-lg transition <%= (typeof active !== 'undefined' && active === it.key) ? 'bg-brand-50 text-brand-700 font-medium' : 'opacity-70 hover:opacity-100 hover:bg-black/5' %>">
            <span><%= it.label %></span>
            <% if (it.key === 'notifications' && unread > 0) { %>
              <span class="ml-2 inline-flex items-center justify-center min-w-[20px] h-5 px-1.5 rounded-full bg-brand-600 text-white text-xs font-semibold"><%= unread %></span>
            <% } %>
          </a>
        <% }); %>
      </nav>
      <div class="p-3 border-t border-black/5 space-y-1">
        <a href="/admin/account"
           class="block px-3 py-2 rounded-lg text-sm transition <%= (typeof active !== 'undefined' && active === 'account') ? 'bg-brand-50 text-brand-700 font-medium' : 'opacity-70 hover:opacity-100 hover:bg-black/5' %>">
          Konto i hasło
        </a>
        <form method="POST" action="/admin/logout">
          <button type="submit" class="w-full text-left px-3 py-2 rounded-lg text-sm opacity-70 hover:opacity-100 hover:bg-black/5">
            Wyloguj
          </button>
        </form>
      </div>
    </aside>

    <!-- Główna kolumna -->
    <div class="flex-1 flex flex-col min-w-0">
      <header class="h-16 bg-[var(--admin-sidebar)] border-b border-black/5 flex items-center justify-between px-4 sm:px-6 lg:px-8" style="color: var(--admin-sidebar-text)">
        <div class="flex items-center gap-3 min-w-0">
          <button type="button" class="md:hidden opacity-70 hover:opacity-100" @click="nav = true" aria-label="Otwórz menu"><%- icon('menu', { size: 22, cls: '' }) %></button>
          <h1 class="text-lg font-semibold truncate"><%= typeof title !== 'undefined' ? title : '' %></h1>
        </div>
        <form method="GET" action="/admin/search" class="hidden sm:block flex-1 max-w-xs mx-4">
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"><%- icon('search', { size: 15, cls: '' }) %></span>
            <input name="q" value="<%= typeof q !== 'undefined' ? q : '' %>" placeholder="Szukaj…" aria-label="Szukaj"
                   class="w-full rounded-lg border border-slate-300 bg-white/80 pl-9 pr-3 py-1.5 text-sm text-slate-700 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
          </div>
        </form>
        <div class="flex items-center gap-4">
          <button type="button" onclick="window.toggleTheme&&window.toggleTheme()" class="opacity-70 hover:opacity-100" title="Tryb jasny/ciemny" aria-label="Przełącz tryb">
            <span class="dark:hidden"><%- icon('moon', { size: 19, cls: '' }) %></span>
            <span class="hidden dark:inline"><%- icon('sun', { size: 19, cls: '' }) %></span>
          </button>
          <a href="/admin/notifications" class="relative opacity-70 hover:opacity-100" title="Powiadomienia">
            <%- icon('bell', { size: 20, cls: '' }) %>
            <% const unreadH = (typeof unreadCount !== 'undefined') ? unreadCount : 0; %>
            <% if (unreadH > 0) { %>
              <span class="absolute -top-1 -right-1 inline-flex items-center justify-center min-w-[18px] h-[18px] px-1 rounded-full bg-red-500 text-white text-[10px] font-bold"><%= unreadH %></span>
            <% } %>
          </a>
          <span class="hidden sm:inline text-sm opacity-60"><%= typeof currentUser !== 'undefined' && currentUser ? currentUser.email : '' %></span>
        </div>
      </header>
      <main class="flex-1 p-4 sm:p-6 lg:p-8">
        <%- body %>
      </main>
    </div>
  </div>
</body>
</html>
