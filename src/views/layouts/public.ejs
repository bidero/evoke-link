<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script>try{if(localStorage.getItem('evoke-theme')==='dark')document.documentElement.classList.add('dark')}catch(e){}window.toggleTheme=function(){var d=document.documentElement.classList.toggle('dark');try{localStorage.setItem('evoke-theme',d?'dark':'light')}catch(e){}};</script>
  <% const appName = (typeof settings !== 'undefined' && settings) ? settings.appName : 'Evoke LINK'; %>
  <title><%= typeof title !== 'undefined' ? title + ' — ' + appName : appName %></title>
  <link rel="stylesheet" href="/css/app.css?v=<%= assetVer %>" />
  <% if (typeof settings !== 'undefined' && settings && settings.faviconPath) { %><link rel="icon" href="<%= settings.faviconPath %>" /><% } %>
  <%
    // Podgląd linku (OG/Twitter) — gdy klient wkleja link np. w czacie/mailu.
    // UWAGA: tylko ogólne dane (tytuł strony, nazwa, logo) — NIE wyciekamy nazw plików.
    var _ogTitle = (typeof title !== 'undefined' && title) ? title : appName;
    var _ogDesc = (typeof metaDesc !== 'undefined' && metaDesc) ? metaDesc
      : ((typeof settings !== 'undefined' && settings && settings.texts && settings.texts.heroSubtitle) ? settings.texts.heroSubtitle : (appName + ' — bezpieczna wymiana plików'));
    var _ogImgPath = (typeof settings !== 'undefined' && settings) ? (settings.ogImagePath || settings.logoPath || settings.faviconPath || '') : '';
    var _ogImg = _ogImgPath ? ((typeof appUrl !== 'undefined' ? appUrl : '') + _ogImgPath) : '';
  %>
  <meta name="description" content="<%= _ogDesc %>" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="<%= appName %>" />
  <meta property="og:title" content="<%= _ogTitle %>" />
  <meta property="og:description" content="<%= _ogDesc %>" />
  <% if (typeof canonicalUrl !== 'undefined' && canonicalUrl) { %><meta property="og:url" content="<%= canonicalUrl %>" /><% } %>
  <% if (_ogImg) { %><meta property="og:image" content="<%= _ogImg %>" /><meta name="twitter:image" content="<%= _ogImg %>" /><% } %>
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content="<%= _ogTitle %>" />
  <meta name="twitter:description" content="<%= _ogDesc %>" />
  <%- typeof brandStyleTag !== 'undefined' ? brandStyleTag : '' %>
  <%- typeof surfaceStyleTag !== 'undefined' ? surfaceStyleTag : '' %>
  <%- typeof darkStyleTag !== 'undefined' ? darkStyleTag : '' %>
  <%- typeof typographyStyleTag !== 'undefined' ? typographyStyleTag : '' %>
  <%- typeof customStyleTag !== 'undefined' ? customStyleTag : '' %>
  <%# Turbo Drive — nawigacja portali klienta bez pełnego przeładowania (linki same-origin przez
      fetch + podmiana <body>, zachowany back/scroll). Lokalnie (jak Alpine) — CSP 'self' pokrywa.
      Alpine radzi sobie z podmianą <body> przez swój obserwator mutacji; skrypty zależne od DOM
      (tło/szkło, sticky) re-inicjujemy na `turbo:load`. %>
  <script defer src="/js/turbo.js"></script>
  <script src="/js/chunked-upload.js"></script>
  <script src="/js/uploader.js"></script>
  <script defer src="/js/bg-rotate.js"></script>
  <script defer src="/js/sticky-header.js"></script>
  <script defer src="/js/alpine.min.js"></script>
  <script>
    // Po każdej nawigacji Turbo re-inicjujemy TYLKO sticky-header (jest w podmienianym <body>).
    // NIE wołamy tu evokeBgInit: tło siedzi w `#evoke-bg` (data-turbo-permanent) — nie jest
    // odtwarzane, slideshow działa dalej, a `refreshGlass` (puls blur 22→14px) na szkle powodował
    // MIGOTANIE elementów szklanych przy każdej nawigacji. Przy trwałym (stabilnym) tle nowe karty
    // malują się od razu na świeżym backdropie, więc pulsu nie potrzeba.
    document.addEventListener('turbo:load', function () {
      if (window.evokeStickyInit) window.evokeStickyInit();
    });
  </script>
</head>
<%
  const dark = (typeof bgDark !== 'undefined' && bgDark);
  const logoCfg = (typeof settings !== 'undefined' && settings && settings.logo) ? settings.logo : { size: 36, align: 'left' };
  const justify = { left: 'justify-start', center: 'justify-center', right: 'justify-end' }[logoCfg.align] || 'justify-start';
  const L = (typeof uiLayout !== 'undefined' && uiLayout) ? uiLayout : { style: 'classic', heroOnBg: false };
  const heroTitle = (typeof settings !== 'undefined' && settings && settings.texts) ? settings.texts.heroTitle : '';
  const heroSubtitle = (typeof settings !== 'undefined' && settings && settings.texts) ? settings.texts.heroSubtitle : '';
  const showHero = !!heroTitle && (L.heroOnBg !== false);
  const heroT = dark ? 'text-white' : 'text-slate-800';
  const heroS = dark ? 'text-slate-200/80' : 'text-slate-500';
  const footerText = (typeof settings !== 'undefined' && settings && settings.texts && settings.texts.footer) ? settings.texts.footer : (appName + ' · bezpieczna wymiana plików');
  const isPanel = L.style === 'panel';
  const isPanelBg = L.style === 'panel-bg';
  const panelMode = isPanel || isPanelBg; // flush biały panel (reset .evoke-card)
  // Szerokość panelu (panel / panel-bg). Literalne klasy Tailwind (skaner je łapie). Domyślnie md.
  const panelWCls = { sm: 'md:max-w-sm', md: 'md:max-w-md', lg: 'md:max-w-lg', xl: 'md:max-w-xl', '2xl': 'md:max-w-2xl' }[L.panelWidth] || 'md:max-w-md';
  // App-shell dla kompozycji panelowych: na DESKTOPIE strona się NIE przewija (pasek przeglądarki
  // znika), a przewija się sam PANEL (własny scrollbar). Mobile bez zmian (przewija się body).
  // shellBody = wysokość viewportu + clip na <body>; shellFlex = min-h-0 na łańcuchu flex ancestorów
  // (żeby scroll „dotarł" do panelu); scroller (sekcja panelu) dostaje overflow-y-auto niżej.
  const shellBody = panelMode ? 'md:h-screen md:overflow-hidden' : '';
  const shellFlex = panelMode ? 'md:min-h-0' : '';
  const noChrome = panelMode || L.style === 'sidebar'; // własny nagłówek/stopka w środku
  const sticky = !!L.stickyHeader;
  const stickyBg = dark ? 'rgba(15,23,42,0.55)' : 'rgba(255,255,255,0.62)';
  // Nawigacja sekcji portali (/c, /p): kontroler dostarcza portalNav (sekcje+klucze+defaultSec),
  // efektywny tryb w portalNavMode. Layout renderuje warianty CHROME (header / rail-*) i trzyma
  // x-data ze stanem `sec` na wrapperze — wspólny scope dla menu w chrome i sekcji widoku (x-show).
  const pNav = (typeof portalNav !== 'undefined' && portalNav && typeof portalNavMode !== 'undefined' && portalNavMode && portalNavMode !== 'none') ? portalNav : null;
  const pMode = pNav ? portalNavMode : 'none';
  const headerNav = !!pNav && pMode === 'header';
  const railNav = !!pNav && pMode.indexOf('rail') === 0;
  const railRight = pMode === 'rail-right';
  const railOwn = railNav && L.style !== 'sidebar'; // przy kompozycji „Pasek boczny" menu wchodzi w JEJ pas
  // Logo na TLE (aside kompozycji panel-bg/sidebar) POKAZUJEMY normalnie — logo znika z PASA
  // pionowego, nie z panelu/tła (decyzja usera). Ręczny wyłącznik: hideBgLogo.
  const showBgLogo = !L.hideBgLogo;
  // Klasyczne układy (renderują standardowy <header> niżej) mają logo w nagłówku — to awaryjne
  // miejsce, gdy pas pionowy odebrał logo. panel/panel-bg/banner mają własne logo (na tle/w panelu).
  // „Wiadomości" jako pozycja menu (link na podstronę) → pływająca koperta-link znika.
  const msgInMenu = !!(pNav && pNav.sections && pNav.sections.some((s) => s.action === 'messages'));
  // Brandowy pas przy PRAWEJ krawędzi (własny rail-right albo kompozycja „Pasek boczny" z kartą po lewej)
  // → pływające ikonki (tryb/koperta) muszą być białe, inaczej giną na kolorze brandu.
  const brandTopRight = (railOwn && railRight) || (L.style === 'sidebar' && L.cardSide === 'right');
  const fabCls = brandTopRight
    ? 'bg-white/15 hover:bg-white/25 text-white'
    : 'bg-black/5 hover:bg-black/10 dark:bg-white/10 dark:hover:bg-white/20 text-brand-600 dark:text-slate-100';
%>
<body class="client-bg min-h-screen text-slate-800 antialiased <%= panelMode ? 'evoke-panel-mode' : '' %> <%= shellBody %>" style="<%= typeof bgStyle !== 'undefined' ? bgStyle : '' %>">
  <%# Warstwy tła w kontenerze `data-turbo-permanent`: Turbo przenosi go 1:1 na nową stronę zamiast
      odtwarzać → obraz tła (odsłaniany opacity 0→1 po onload) NIE re-odsłania się przy każdej
      nawigacji, więc znika „błysk" tła przy przejściu między portalami. id musi być stałe. %>
  <div id="evoke-bg" data-turbo-permanent aria-hidden="true"><%- typeof bgSlideshow !== 'undefined' ? bgSlideshow : '' %><%- typeof bgOverlay !== 'undefined' ? bgOverlay : '' %></div>
  <%# railOpen (desktop): zapamiętany wybór (localStorage) ma pierwszeństwo — pas trzyma stan między
      ekranami; bez niego domyślny per-strona (/c zwinięty, /p rozwinięty). Na MOBILE zawsze start
      zwinięty (rozwinięcie = pełnoekranowy overlay) i bez zapisu do pamięci. %>
  <div class="relative z-10 min-h-screen flex flex-col <%= shellBody %> <%= shellFlex %>"
       <% if (pNav) { %>x-data="{ sec: (function(){ var h = location.hash.replace('#',''); var ks = <%= JSON.stringify(pNav.keys) %>; return ks.indexOf(h) >= 0 ? h : '<%= pNav.defaultSec %>'; })(), railOpen: (function(){ if (!window.matchMedia('(min-width: 768px)').matches) return false; try{ var v=localStorage.getItem('evoke-rail'); if(v==='0'||v==='1') return v==='1'; }catch(e){} return <%= pNav.railOpen === false ? 'false' : 'true' %>; })() }" x-init="$watch('railOpen', function(v){ if (!window.matchMedia('(min-width: 768px)').matches) return; try{ localStorage.setItem('evoke-rail', v?'1':'0'); }catch(e){} })"<% } %>>

    <% if (!headerNav && !railOwn) { %>
    <%# headerNav: przełącznik trybu jest W pasku menu (chrome-top, withTheme);
        railOwn: przełącznik na dole pasa pionowego — nie dublujemy pływającego. %>
    <button type="button" onclick="window.toggleTheme&&window.toggleTheme()" title="Tryb jasny/ciemny" aria-label="Przełącz tryb"
      class="fixed top-4 right-4 z-30 w-10 h-10 inline-flex items-center justify-center rounded-full <%= fabCls %> backdrop-blur transition">
      <span class="dark:hidden"><%- icon('moon', { size: 18, cls: '' }) %></span>
      <span class="hidden dark:inline"><%- icon('sun', { size: 18, cls: '' }) %></span>
    </button>
    <% } %>

    <% if (typeof msgContext !== 'undefined' && msgContext && msgContext.page && !msgInMenu) { %>
    <%# Wiadomości: pływająca koperta-LINK na podstronę wątku (dawny popup zastąpiony podstroną
        public/messages.ejs; gdy nawigacja ma pozycję „Wiadomości" — koperta znika). %>
    <a href="<%= msgContext.page %>" title="Wiadomości" aria-label="Wiadomości"
       class="fixed top-4 right-16 z-30 w-10 h-10 inline-flex items-center justify-center rounded-full <%= fabCls %> backdrop-blur transition">
      <%- icon('mail', { size: 18, cls: '' }) %>
      <% if (typeof msgHasReply !== 'undefined' && msgHasReply) { %><span class="absolute -top-0.5 -right-0.5 w-3 h-3 rounded-full bg-red-500 ring-2 ring-white"></span><% } %>
    </a>
    <% } %>

    <% if (typeof msgSent !== 'undefined' && msgSent) { %>
    <div x-data="{ show: true }" x-show="show" x-cloak x-init="setTimeout(() => show = false, 4000)" x-transition
      class="fixed top-4 left-1/2 -translate-x-1/2 z-40 rounded-full bg-green-600 text-white text-sm px-4 py-2 shadow-lg">
      Dziękujemy! Wiadomość wysłana.
    </div>
    <% } %>

    <% if (railOwn) { %>
    <%# Własny brandowy pas z menu (portalNav rail-*) — bez logo i stopki (są w kompozycji).
        WYSOKOŚĆ = 100dvh (nie 100vh — na mobile 100vh chowa dół za paskiem URL, więc tryb był poza
        ekranem). Hamburger (góra) i tryb jasny/ciemny (dół) ZAWSZE widoczne; środek (menu) przewija
        się wewnętrznie. Desktop: md:sticky top-0 (nie przewija się z treścią), zwijany hamburgerem
        (md:w-16 ↔ md:w-60, push). Mobile: FIXED wąski pasek ikon (w-14) → rozwija się PŁYNNIE do
        pełnej szerokości (w-screen, animacja transition-[width]); klik pozycji zamyka.
        Hamburger: WYŚRODKOWANY w zwiniętym pasku (justify-center), po rozwinięciu dosunięty do
        KRAWĘDZI pasa (lewej dla rail-left, PRAWEJ dla rail-right) — zostaje w miejscu przy zwijaniu
        i przy pasie z prawej nie „ucieka" z panelem. %>
    <div class="relative flex-1 flex <%= shellFlex %>">
      <%# PODKŁAD pasa (tylko mobile). Pas ma h-[100dvh] (żeby tryb/moon był na dole WIDOKU), ale na
          iOS `100dvh`/`inset-y` na elemencie `position:fixed` bywa liczone jak mały ekran (svh) —
          przy schowanym pasku URL pas jest KRÓTSZY niż realny widok i pod nim prześwituje baza body
          (przy tle-obrazie ciemne #0f172a → „ciemny pasek z prawej", też w Safari). Dlatego podkład
          jest `position:ABSOLUTE` względem `relative flex-1 flex` (a NIE fixed) — ten pojemnik ma
          wysokość ≥ viewport (wypełnia `min-h-screen`), więc podkład `inset-y-0` sięga realnego dołu
          dokumentu, bez pułapek fixed-viewport w Safari. Kryty przez rozwinięty pas (wyższy z). %>
      <div aria-hidden="true" class="md:hidden absolute inset-y-0 z-0 w-14 bg-brand-600 pointer-events-none <%= railRight ? 'right-0' : 'left-0' %>"></div>
      <aside class="flex shrink-0 flex-col bg-brand-600 text-white p-3 overflow-hidden transition-[width] duration-300 ease-in-out top-0 h-[100dvh] md:self-start md:sticky md:z-auto <%= railRight ? 'right-0 md:order-2 md:right-auto' : 'left-0 md:left-auto' %>"
             :class="railOpen ? 'fixed w-screen z-40 md:w-60' : 'fixed w-14 z-30 md:w-16'">
        <%# Hamburger: pojemnik `w-full flex` steruje TYLKO pozycją (wyśrodkowany gdy zwinięty,
            przy krawędzi gdy rozwinięty), a klikalny/hoverowalny jest sam przycisk stałego rozmiaru
            (w-10) — dzięki temu hover NIE zajmuje całej szerokości, a stuknięcie obok przycisku w
            rozwiniętym panelu NIE zamyka pasa (iOS: przypadkowe zamknięcie „po chwili"). %>
        <div class="w-full flex shrink-0 mb-4" :class="railOpen ? '<%= railRight ? "justify-end" : "justify-start" %>' : 'justify-center'">
          <button type="button" @click="railOpen = !railOpen" title="Zwiń/rozwiń menu" aria-label="Zwiń lub rozwiń menu"
                  class="w-10 h-10 inline-flex items-center justify-center rounded-lg text-white/85 hover:bg-white/15 transition">
            <%- icon('menu', { size: 20, cls: '' }) %>
          </button>
        </div>
        <%# Menu w środku — flex-1 (spycha tryb na dół) + własne przewijanie przy wielu pozycjach. %>
        <div class="flex-1 min-h-0 overflow-y-auto -mx-1 px-1">
          <%- include('../public/_portal_nav', { sections: pNav.sections, navMode: pMode, part: 'rail', linkBase: pNav.linkBase || null }) %>
        </div>
        <button type="button" onclick="window.toggleTheme&&window.toggleTheme()" title="Tryb jasny/ciemny" aria-label="Przełącz tryb"
                class="shrink-0 mt-2 w-full flex items-center gap-2.5 rounded-xl px-3 h-9 text-sm text-white/85 hover:bg-white/15 transition text-left"
                :class="railOpen ? '' : 'justify-center px-0'">
          <span class="dark:hidden shrink-0"><%- icon('moon', { size: 16, cls: '' }) %></span>
          <span class="hidden dark:inline shrink-0"><%- icon('sun', { size: 16, cls: '' }) %></span>
          <span class="flex-1 truncate" x-show="railOpen">Tryb jasny / ciemny</span>
        </button>
      </aside>
      <%# Mobile: pas jest FIXED (poza potokiem) → treść dostaje margines na wąski pasek (pl/pr-14).
          Desktop: pas w potoku (sticky), bez marginesu. %>
      <div class="flex-1 flex flex-col min-w-0 <%= shellFlex %> <%= railRight ? 'pr-14 md:pr-0' : 'pl-14 md:pl-0' %>">
    <% } %>

    <% if (L.style !== 'banner' && !noChrome) { %>
    <%# Klasyczne układy: nagłówek z logo. Przy pasie pionowym (railOwn) to JEDYNE miejsce na logo
        (pas jest bez logo), więc pokazujemy go też na desktopie. %>
    <header class="px-6 py-5 <%= sticky ? 'sticky top-0 z-20' : '' %>"<% if (sticky) { %> data-sticky-header style="--sticky-bg:<%= stickyBg %>"<% } %>>
      <% if (headerNav) { %>
        <%# Menu w nagłówku (portalNav 'header'): obok logo; przy logo wyśrodkowanym — pod nim.
            Przełącznik trybu jest wewnątrz menu (withTheme), a koperta w menu — brak pływających ikon, więc bez pr. %>
        <div class="w-full <%= dark ? 'text-white' : '' %> <%= logoCfg.align === 'center' ? 'flex flex-col items-center gap-3' : 'flex items-center justify-between gap-4' %>">
          <div class="flex items-center gap-2 min-w-0">
            <% if (typeof settings !== 'undefined' && settings && settings.logoPath) { %>
              <%- logoTag(settings, { appName, imgClass: 'max-w-[70%] object-contain', imgStyle: 'height: ' + logoCfg.size + 'px' }) %>
            <% } else if (!L.hideName) { %>
              <div class="w-8 h-8 rounded-lg bg-brand-600 flex items-center justify-center text-white font-bold">E</div>
              <span class="font-semibold tracking-tight"><%= appName %></span>
            <% } %>
          </div>
          <%- include('../public/_portal_nav', { sections: pNav.sections, navMode: pMode, part: 'chrome-top', tone: 'bg', withTheme: true, linkBase: pNav.linkBase || null }) %>
        </div>
      <% } else { %>
        <div class="flex items-center gap-2 w-full <%= justify %> <%= dark ? 'text-white' : '' %>">
          <% if (typeof settings !== 'undefined' && settings && settings.logoPath) { %>
            <%- logoTag(settings, { appName, imgClass: 'max-w-[70%] object-contain', imgStyle: 'height: ' + logoCfg.size + 'px' }) %>
          <% } else if (!L.hideName) { %>
            <div class="w-8 h-8 rounded-lg bg-brand-600 flex items-center justify-center text-white font-bold">E</div>
            <span class="font-semibold tracking-tight"><%= appName %></span>
          <% } %>
        </div>
      <% } %>
    </header>
    <% } %>

    <% if (L.style === 'banner') { %>
      <%# Banner: pasek brandowy z logo + hero, karta na tle pod spodem %>
      <header class="bg-brand-600 text-white px-6 py-6">
        <div class="max-w-5xl mx-auto w-full flex items-center gap-2 <%= justify %>">
          <% if (typeof settings !== 'undefined' && settings && settings.logoPath) { %>
            <%- logoTag(settings, { appName, imgClass: 'max-w-[60%] object-contain', imgStyle: 'height: ' + logoCfg.size + 'px' }) %>
          <% } else if (!L.hideName) { %>
            <div class="w-8 h-8 rounded-lg bg-white/20 flex items-center justify-center text-white font-bold">E</div>
            <span class="font-semibold tracking-tight"><%= appName %></span>
          <% } %>
        </div>
        <% if (headerNav) { %>
          <div class="max-w-5xl mx-auto w-full mt-4"><%- include('../public/_portal_nav', { sections: pNav.sections, navMode: pMode, part: 'chrome-top', tone: 'brand', withTheme: true, linkBase: pNav.linkBase || null }) %></div>
        <% } %>
        <% if (showHero) { %>
          <div class="max-w-5xl mx-auto w-full mt-4">
            <h1 class="text-2xl sm:text-3xl font-bold tracking-tight"><%= heroTitle %></h1>
            <% if (heroSubtitle) { %><p class="mt-1 text-white/80"><%= heroSubtitle %></p><% } %>
          </div>
        <% } %>
      </header>
      <main class="flex-1 flex items-center justify-center px-6 py-10">
        <%- body %>
      </main>

    <% } else if (L.style === 'hero-card' || L.style === 'minimal') { %>
      <%# Hero w karcie / Minimal: brak nagłówka w layoucie — sama karta wyśrodkowana
          (dla „hero-card" nagłówek renderuje się WEWNĄTRZ karty w widoku). %>
      <main class="flex-1 flex items-center justify-center px-6 py-8">
        <%- body %>
      </main>

    <% } else if (L.style === 'split') { %>
      <%# Hero z jednej strony, karta z drugiej (strona karty z ustawień) %>
      <% const cardLeft = L.cardSide === 'left'; %>
      <main class="flex-1 px-6 py-8">
        <div class="max-w-5xl mx-auto w-full grid md:grid-cols-2 gap-10 items-center min-h-full">
          <div class="text-center <%= cardLeft ? 'md:order-2 md:text-right' : 'md:order-1 md:text-left' %>">
            <% if (showHero) { %>
              <h1 class="text-3xl sm:text-4xl font-bold tracking-tight <%= heroT %>"><%= heroTitle %></h1>
              <% if (heroSubtitle) { %><p class="mt-3 text-base <%= heroS %>"><%= heroSubtitle %></p><% } %>
            <% } else if (!L.hideName) { %>
              <h1 class="text-3xl sm:text-4xl font-bold tracking-tight <%= heroT %>"><%= appName %></h1>
            <% } %>
          </div>
          <div class="flex justify-center <%= cardLeft ? 'md:order-1 md:justify-start' : 'md:order-2 md:justify-end' %>">
            <%- body %>
          </div>
        </div>
      </main>

    <% } else if (L.style === 'showcase') { %>
      <%# WeTransfer-like: pełne tło, kompaktowa karta przy boku (lewo/prawo/środek), hero nad kartą %>
      <% const sideCls = L.cardSide === 'right' ? 'ml-auto' : (L.cardSide === 'center' ? 'mx-auto' : 'mr-auto'); %>
      <main class="flex-1 flex items-center px-6 sm:px-10 py-10">
        <div class="w-full max-w-md <%= sideCls %>">
          <% if (showHero) { %>
            <div class="mb-5 <%= L.cardSide === 'center' ? 'text-center' : ''%> <%= heroT %>">
              <h1 class="text-3xl sm:text-4xl font-bold tracking-tight"><%= heroTitle %></h1>
              <% if (heroSubtitle) { %><p class="mt-2 text-base <%= heroS %>"><%= heroSubtitle %></p><% } %>
            </div>
          <% } %>
          <%- body %>
        </div>
      </main>

    <% } else if (isPanel) { %>
      <%# WeTransfer: pełne tło + flush panel pełnej wysokości (bez marginesów/zaokrągleń); hero po stronie tła %>
      <% const panelRight = L.cardSide === 'right'; const panelCenter = L.cardSide === 'center'; %>
      <main class="flex-1 flex <%= shellFlex %> <%= panelCenter ? 'justify-center' : '' %>">
        <section class="evoke-panel w-full <%= panelWCls %> bg-white min-h-screen <%= shellFlex %> md:h-full md:overflow-y-auto flex flex-col px-6 sm:px-9 py-7 shrink-0 <%= panelRight ? 'md:order-2' : '' %>">
          <div class="flex items-center gap-2 <%= justify %> mb-6 <%= sticky ? 'sticky top-0 z-20 bg-white py-2 -my-2' : '' %>">
            <% if (typeof settings !== 'undefined' && settings && settings.logoPath) { %>
              <%- logoTag(settings, { appName, imgClass: 'max-w-[70%] object-contain', imgStyle: 'height: ' + logoCfg.size + 'px' }) %>
            <% } else if (!L.hideName) { %>
              <div class="w-8 h-8 rounded-lg bg-brand-600 flex items-center justify-center text-white font-bold">E</div>
              <span class="font-semibold tracking-tight text-slate-800"><%= appName %></span>
            <% } %>
          </div>
          <% if (headerNav) { %><div class="-mt-2 mb-6"><%- include('../public/_portal_nav', { sections: pNav.sections, navMode: pMode, part: 'chrome-top', tone: 'white', withTheme: true, linkBase: pNav.linkBase || null }) %></div><% } %>
          <div class="flex-1 flex flex-col [justify-content:safe_center]">
            <%- body %>
          </div>
        </section>
        <% if (!panelCenter) { %>
          <aside class="hidden md:flex flex-1 flex-col <%= panelRight ? 'md:order-1' : '' %>">
            <div class="flex-1 flex items-center justify-center p-12">
              <% if (showHero) { %>
                <div class="max-w-md <%= heroT %>">
                  <h1 class="text-4xl font-bold tracking-tight"><%= heroTitle %></h1>
                  <% if (heroSubtitle) { %><p class="mt-3 text-lg <%= heroS %>"><%= heroSubtitle %></p><% } %>
                </div>
              <% } %>
            </div>
            <div class="p-6 text-xs <%= dark ? 'text-slate-300/70' : 'text-slate-500' %>"><%= footerText %></div>
          </aside>
        <% } %>
      </main>

    <% } else if (isPanelBg) { %><%# app-shell: main+section dostają min-h-0 + panel przewija się sam %>
      <%# Panel na tle 2: biały panel z treścią po jednej stronie; LOGO + hero NA TLE po drugiej %>
      <% const pbRight = L.cardSide === 'right'; %>
      <main class="flex-1 flex <%= shellFlex %>">
        <section class="evoke-panel w-full <%= panelWCls %> bg-white min-h-screen <%= shellFlex %> md:h-full md:overflow-y-auto flex flex-col px-6 sm:px-9 py-7 shrink-0 <%= pbRight ? 'md:order-2' : '' %>">
          <%# Mobile: logo NAD treścią (na tle jest tylko md+). NIE przyklejamy go na mobile — ma
              płynąć z treścią, bez tła (białe tło + odstęp od górnej krawędzi wyglądały źle).
              „Przyklejony nagłówek" działa na DESKTOPIE: przykleja brandowy pas boczny (poniżej). %>
          <div class="md:hidden flex items-center gap-2 <%= justify %> mb-6">
            <% if (typeof settings !== 'undefined' && settings && settings.logoPath) { %>
              <%- logoTag(settings, { appName, imgClass: 'max-w-[70%] object-contain', imgStyle: 'height: ' + logoCfg.size + 'px' }) %>
            <% } else if (!L.hideName) { %>
              <div class="w-8 h-8 rounded-lg bg-brand-600 flex items-center justify-center text-white font-bold">E</div>
              <span class="font-semibold tracking-tight text-slate-800"><%= appName %></span>
            <% } %>
          </div>
          <% if (headerNav) { %><div class="mb-6"><%- include('../public/_portal_nav', { sections: pNav.sections, navMode: pMode, part: 'chrome-top', tone: 'white', withTheme: true, linkBase: pNav.linkBase || null }) %></div><% } %>
          <div class="flex-1 flex flex-col [justify-content:safe_center]"><%- body %></div>
        </section>
        <%# Przyklejony nagłówek na DESKTOPIE (stickyHeader): brandowy pas boczny (logo/hero/stopka)
            zostaje w widoku przy przewijaniu treści panelu (md:sticky top-0 h-screen self-start). %>
        <aside class="hidden md:flex flex-1 flex-col justify-between p-10 <%= pbRight ? 'md:order-1' : '' %> <%= sticky ? 'md:sticky md:top-0 md:h-screen md:self-start' : '' %>">
          <% if (showBgLogo) { %>
          <div class="flex items-center gap-2 <%= justify %>">
            <% if (typeof settings !== 'undefined' && settings && settings.logoPath) { %>
              <%- logoTag(settings, { appName, imgClass: 'max-w-[60%] object-contain', imgStyle: 'height: ' + logoCfg.size + 'px' }) %>
            <% } else if (!L.hideName) { %>
              <div class="w-8 h-8 rounded-lg bg-brand-600 flex items-center justify-center text-white font-bold">E</div>
              <span class="font-semibold tracking-tight <%= dark ? 'text-white' : 'text-slate-800' %>"><%= appName %></span>
            <% } %>
          </div>
          <% } else { %><div></div><% } %>
          <div>
            <% if (showHero) { %>
              <h1 class="text-3xl sm:text-4xl font-bold tracking-tight <%= heroT %>"><%= heroTitle %></h1>
              <% if (heroSubtitle) { %><p class="mt-3 text-base <%= heroS %>"><%= heroSubtitle %></p><% } %>
            <% } %>
          </div>
          <div class="text-xs <%= dark ? 'text-slate-300/70' : 'text-slate-500' %>"><%= footerText %></div>
        </aside>
      </main>

    <% } else if (L.style === 'sidebar') { %>
      <%# Kolorowy (brand) pasek boczny z logo + hero; treść/karta na tle obok %>
      <% const sbRight = L.cardSide === 'right'; %>
      <main class="flex-1 flex">
        <aside class="hidden md:flex w-72 shrink-0 bg-brand-600 text-white flex-col justify-between p-8 <%= sbRight ? 'md:order-2' : '' %>">
          <div>
            <% if (showBgLogo) { %>
            <div class="flex items-center gap-2 <%= justify %>">
              <% if (typeof settings !== 'undefined' && settings && settings.logoPath) { %>
                <%- logoTag(settings, { appName, imgClass: 'max-w-[80%] object-contain', imgStyle: 'height: ' + logoCfg.size + 'px' }) %>
              <% } else if (!L.hideName) { %>
                <div class="w-8 h-8 rounded-lg bg-white/20 flex items-center justify-center font-bold">E</div>
                <span class="font-semibold tracking-tight"><%= appName %></span>
              <% } %>
            </div>
            <% } %>
            <%# portalNav rail-*: menu wpina się w istniejący pas kompozycji (bez własnego pasa) %>
            <% if (railNav) { %><div class="<%= showBgLogo ? 'mt-8' : '' %>"><%- include('../public/_portal_nav', { sections: pNav.sections, navMode: pMode, part: 'rail', linkBase: pNav.linkBase || null }) %></div><% } %>
          </div>
          <% if (showHero) { %>
            <div><h1 class="text-2xl font-bold tracking-tight"><%= heroTitle %></h1><% if (heroSubtitle) { %><p class="mt-2 text-sm text-white/80"><%= heroSubtitle %></p><% } %></div>
          <% } %>
          <div class="text-xs text-white/70"><%= footerText %></div>
        </aside>
        <div class="flex-1 flex flex-col min-w-0">
          <% if (railNav) { %><div class="md:hidden px-6 pt-4"><%- include('../public/_portal_nav', { sections: pNav.sections, navMode: pMode, part: 'page-top', mobileOnly: true, linkBase: pNav.linkBase || null }) %></div><% } %>
          <% if (headerNav) { %><div class="px-6 pt-5 flex justify-center"><%- include('../public/_portal_nav', { sections: pNav.sections, navMode: pMode, part: 'chrome-top', tone: 'bg', withTheme: true, linkBase: pNav.linkBase || null }) %></div><% } %>
          <div class="flex-1 flex items-center justify-center p-6 sm:p-10"><%- body %></div>
        </div>
      </main>

    <% } else if (L.style === 'corner') { %>
      <%# Kompaktowa karta zadokowana w dolnym rogu na pełnym tle %>
      <% const coRight = L.cardSide === 'right'; const coCenter = L.cardSide === 'center'; %>
      <main class="flex-1 flex items-end px-6 sm:px-10 py-8 <%= coCenter ? 'justify-center' : (coRight ? 'justify-end' : '') %>">
        <div class="w-full max-w-sm">
          <% if (showHero) { %>
            <div class="mb-3 <%= heroT %>"><h1 class="text-2xl font-bold tracking-tight"><%= heroTitle %></h1><% if (heroSubtitle) { %><p class="mt-1 text-sm <%= heroS %>"><%= heroSubtitle %></p><% } %></div>
          <% } %>
          <%- body %>
        </div>
      </main>

    <% } else if (L.style === 'centered') { %>
      <%# Landing: duży hero wyeksponowany nad kartą na pełnym tle %>
      <main class="flex-1 flex flex-col items-center justify-center px-6 py-10 gap-9">
        <% if (showHero) { %>
          <section class="text-center max-w-3xl">
            <h1 class="text-4xl sm:text-5xl font-bold tracking-tight <%= heroT %>"><%= heroTitle %></h1>
            <% if (heroSubtitle) { %><p class="mt-4 text-lg <%= heroS %>"><%= heroSubtitle %></p><% } %>
          </section>
        <% } %>
        <%- body %>
      </main>

    <% } else { %>
      <%# Układ klasyczny (domyślny) %>
      <% if (showHero) { %>
        <section class="px-6 pt-2 pb-4 text-center <%= heroT %>">
          <h1 class="text-2xl sm:text-3xl font-bold tracking-tight"><%= heroTitle %></h1>
          <% if (heroSubtitle) { %><p class="mt-2 text-sm sm:text-base <%= heroS %>"><%= heroSubtitle %></p><% } %>
        </section>
      <% } %>
      <main class="flex-1 flex items-center justify-center px-6 py-8">
        <%- body %>
      </main>
    <% } %>

    <% if (!noChrome) { %>
    <%# Standardowa stopka (klasyczne układy). Pas pionowy nie ma już własnej stopki,
        więc pokazujemy ją też przy railOwn (jedyne miejsce na napis). %>
    <footer class="px-6 py-5 text-center text-xs <%= dark ? 'text-slate-300/70' : 'text-slate-400' %>">
      <%= footerText %>
    </footer>
    <% } %>

    <% if (railOwn) { %>
      </div>
    </div>
    <% } %>
  </div>
</body>
</html>
