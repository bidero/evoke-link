<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script>try{if(localStorage.getItem('evoke-theme')==='dark')document.documentElement.classList.add('dark')}catch(e){}window.toggleTheme=function(){var d=document.documentElement.classList.toggle('dark');try{localStorage.setItem('evoke-theme',d?'dark':'light')}catch(e){}};</script>
  <% const appName = (typeof settings !== 'undefined' && settings) ? settings.appName : 'Evoke LINK'; %>
  <title><%= typeof title !== 'undefined' ? title + ' — ' + appName : appName %></title>
  <link rel="stylesheet" href="/css/app.css" />
  <% if (typeof settings !== 'undefined' && settings && settings.faviconPath) { %><link rel="icon" href="<%= settings.faviconPath %>" /><% } %>
  <%
    // Podgląd linku (OG/Twitter) — gdy klient wkleja link np. w czacie/mailu.
    // UWAGA: tylko ogólne dane (tytuł strony, nazwa, logo) — NIE wyciekamy nazw plików.
    var _ogTitle = (typeof title !== 'undefined' && title) ? title : appName;
    var _ogDesc = (typeof metaDesc !== 'undefined' && metaDesc) ? metaDesc
      : ((typeof settings !== 'undefined' && settings && settings.texts && settings.texts.heroSubtitle) ? settings.texts.heroSubtitle : (appName + ' — bezpieczna wymiana plików'));
    var _ogImgPath = (typeof settings !== 'undefined' && settings) ? (settings.ogImagePath || settings.logoPath || settings.faviconPath || '') : '';
    var _ogImg = _ogImgPath ? ((typeof appUrl !== 'undefined' ? appUrl : '') + _ogImgPath) : '';
  %>
  <meta name="description" content="<%= _ogDesc %>" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="<%= appName %>" />
  <meta property="og:title" content="<%= _ogTitle %>" />
  <meta property="og:description" content="<%= _ogDesc %>" />
  <% if (typeof canonicalUrl !== 'undefined' && canonicalUrl) { %><meta property="og:url" content="<%= canonicalUrl %>" /><% } %>
  <% if (_ogImg) { %><meta property="og:image" content="<%= _ogImg %>" /><meta name="twitter:image" content="<%= _ogImg %>" /><% } %>
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content="<%= _ogTitle %>" />
  <meta name="twitter:description" content="<%= _ogDesc %>" />
  <%- typeof brandStyleTag !== 'undefined' ? brandStyleTag : '' %>
  <%- typeof surfaceStyleTag !== 'undefined' ? surfaceStyleTag : '' %>
  <%- typeof darkStyleTag !== 'undefined' ? darkStyleTag : '' %>
  <%- typeof typographyStyleTag !== 'undefined' ? typographyStyleTag : '' %>
  <%- typeof customStyleTag !== 'undefined' ? customStyleTag : '' %>
  <script src="/js/chunked-upload.js"></script>
  <script src="/js/uploader.js"></script>
  <script defer src="/js/bg-rotate.js"></script>
  <script defer src="/js/sticky-header.js"></script>
  <script defer src="/js/alpine.min.js"></script>
</head>
<%
  const dark = (typeof bgDark !== 'undefined' && bgDark);
  const logoCfg = (typeof settings !== 'undefined' && settings && settings.logo) ? settings.logo : { size: 36, align: 'left' };
  const justify = { left: 'justify-start', center: 'justify-center', right: 'justify-end' }[logoCfg.align] || 'justify-start';
  const L = (typeof uiLayout !== 'undefined' && uiLayout) ? uiLayout : { style: 'classic', heroOnBg: false };
  const heroTitle = (typeof settings !== 'undefined' && settings && settings.texts) ? settings.texts.heroTitle : '';
  const heroSubtitle = (typeof settings !== 'undefined' && settings && settings.texts) ? settings.texts.heroSubtitle : '';
  const showHero = !!heroTitle && (L.heroOnBg !== false);
  const heroT = dark ? 'text-white' : 'text-slate-800';
  const heroS = dark ? 'text-slate-200/80' : 'text-slate-500';
  const footerText = (typeof settings !== 'undefined' && settings && settings.texts && settings.texts.footer) ? settings.texts.footer : (appName + ' · bezpieczna wymiana plików');
  const isPanel = L.style === 'panel';
  const isPanelBg = L.style === 'panel-bg';
  const panelMode = isPanel || isPanelBg; // flush biały panel (reset .evoke-card)
  const noChrome = panelMode || L.style === 'sidebar'; // własny nagłówek/stopka w środku
  const sticky = !!L.stickyHeader;
  const stickyBg = dark ? 'rgba(15,23,42,0.55)' : 'rgba(255,255,255,0.62)';
%>
<body class="client-bg min-h-screen text-slate-800 antialiased <%= panelMode ? 'evoke-panel-mode' : '' %>" style="<%= typeof bgStyle !== 'undefined' ? bgStyle : '' %>">
  <%- typeof bgSlideshow !== 'undefined' ? bgSlideshow : '' %>
  <%- typeof bgOverlay !== 'undefined' ? bgOverlay : '' %>
  <div class="relative z-10 min-h-screen flex flex-col">

    <button type="button" onclick="window.toggleTheme&&window.toggleTheme()" title="Tryb jasny/ciemny" aria-label="Przełącz tryb"
      class="fixed top-4 right-4 z-30 w-10 h-10 inline-flex items-center justify-center rounded-full bg-black/5 hover:bg-black/10 dark:bg-white/10 dark:hover:bg-white/20 backdrop-blur transition text-brand-600 dark:text-slate-100">
      <span class="dark:hidden"><%- icon('moon', { size: 18, cls: '' }) %></span>
      <span class="hidden dark:inline"><%- icon('sun', { size: 18, cls: '' }) %></span>
    </button>

    <% if (typeof msgContext !== 'undefined' && msgContext) { %>
    <div class="fixed top-4 right-16 z-30" x-data="{ open: false }" @keydown.escape.window="open = false">
      <button type="button" @click="open = !open" title="Napisz do nas" aria-label="Napisz wiadomość"
        class="w-10 h-10 inline-flex items-center justify-center rounded-full bg-black/5 hover:bg-black/10 dark:bg-white/10 dark:hover:bg-white/20 backdrop-blur transition text-brand-600 dark:text-slate-100">
        <%- icon('mail', { size: 18, cls: '' }) %>
      </button>
      <div x-show="open" x-cloak x-transition @click.outside="open = false"
        class="absolute right-0 mt-2 w-80 max-w-[88vw] rounded-2xl border border-slate-200 bg-white shadow-xl p-4 text-left text-slate-800">
        <div class="text-sm font-semibold mb-1">Napisz do nas</div>
        <% if (msgContext.scope) { %><p class="text-xs text-slate-400 mb-2"><%= msgContext.scope %></p><% } %>
        <form method="POST" action="<%= msgContext.action %>" class="space-y-2">
          <textarea name="body" required rows="4" maxlength="4000" placeholder="Twoja wiadomość…"
            class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-800 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none"></textarea>
          <div class="grid grid-cols-2 gap-2">
            <input name="senderName" type="text" placeholder="Imię (opc.)" class="rounded-lg border border-slate-300 px-2 py-1.5 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
            <input name="senderEmail" type="email" placeholder="E-mail (opc.)" class="rounded-lg border border-slate-300 px-2 py-1.5 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
          </div>
          <button type="submit" class="w-full rounded-lg bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium py-2 transition">Wyślij</button>
        </form>
      </div>
    </div>
    <% } %>

    <% if (typeof msgSent !== 'undefined' && msgSent) { %>
    <div x-data="{ show: true }" x-show="show" x-cloak x-init="setTimeout(() => show = false, 4000)" x-transition
      class="fixed top-4 left-1/2 -translate-x-1/2 z-40 rounded-full bg-green-600 text-white text-sm px-4 py-2 shadow-lg">
      Dziękujemy! Wiadomość wysłana.
    </div>
    <% } %>

    <% if (L.style !== 'banner' && !noChrome) { %>
    <header class="px-6 py-5 <%= sticky ? 'sticky top-0 z-20' : '' %>"<% if (sticky) { %> data-sticky-header style="--sticky-bg:<%= stickyBg %>"<% } %>>
      <div class="flex items-center gap-2 w-full <%= justify %> <%= dark ? 'text-white' : '' %>">
        <% if (typeof settings !== 'undefined' && settings && settings.logoPath) { %>
          <%- logoTag(settings, { appName, imgClass: 'max-w-[70%] object-contain', imgStyle: 'height: ' + logoCfg.size + 'px' }) %>
        <% } else if (!L.hideName) { %>
          <div class="w-8 h-8 rounded-lg bg-brand-600 flex items-center justify-center text-white font-bold">E</div>
          <span class="font-semibold tracking-tight"><%= appName %></span>
        <% } %>
      </div>
    </header>
    <% } %>

    <% if (L.style === 'banner') { %>
      <%# Banner: pasek brandowy z logo + hero, karta na tle pod spodem %>
      <header class="bg-brand-600 text-white px-6 py-6">
        <div class="max-w-5xl mx-auto w-full flex items-center gap-2 <%= justify %>">
          <% if (typeof settings !== 'undefined' && settings && settings.logoPath) { %>
            <%- logoTag(settings, { appName, imgClass: 'max-w-[60%] object-contain', imgStyle: 'height: ' + logoCfg.size + 'px' }) %>
          <% } else if (!L.hideName) { %>
            <div class="w-8 h-8 rounded-lg bg-white/20 flex items-center justify-center text-white font-bold">E</div>
            <span class="font-semibold tracking-tight"><%= appName %></span>
          <% } %>
        </div>
        <% if (showHero) { %>
          <div class="max-w-5xl mx-auto w-full mt-4">
            <h1 class="text-2xl sm:text-3xl font-bold tracking-tight"><%= heroTitle %></h1>
            <% if (heroSubtitle) { %><p class="mt-1 text-white/80"><%= heroSubtitle %></p><% } %>
          </div>
        <% } %>
      </header>
      <main class="flex-1 flex items-center justify-center px-6 py-10">
        <%- body %>
      </main>

    <% } else if (L.style === 'hero-card' || L.style === 'minimal') { %>
      <%# Hero w karcie / Minimal: brak nagłówka w layoucie — sama karta wyśrodkowana
          (dla „hero-card" nagłówek renderuje się WEWNĄTRZ karty w widoku). %>
      <main class="flex-1 flex items-center justify-center px-6 py-8">
        <%- body %>
      </main>

    <% } else if (L.style === 'split') { %>
      <%# Hero z jednej strony, karta z drugiej (strona karty z ustawień) %>
      <% const cardLeft = L.cardSide === 'left'; %>
      <main class="flex-1 px-6 py-8">
        <div class="max-w-5xl mx-auto w-full grid md:grid-cols-2 gap-10 items-center min-h-full">
          <div class="text-center <%= cardLeft ? 'md:order-2 md:text-right' : 'md:order-1 md:text-left' %>">
            <% if (showHero) { %>
              <h1 class="text-3xl sm:text-4xl font-bold tracking-tight <%= heroT %>"><%= heroTitle %></h1>
              <% if (heroSubtitle) { %><p class="mt-3 text-base <%= heroS %>"><%= heroSubtitle %></p><% } %>
            <% } else if (!L.hideName) { %>
              <h1 class="text-3xl sm:text-4xl font-bold tracking-tight <%= heroT %>"><%= appName %></h1>
            <% } %>
          </div>
          <div class="flex justify-center <%= cardLeft ? 'md:order-1 md:justify-start' : 'md:order-2 md:justify-end' %>">
            <%- body %>
          </div>
        </div>
      </main>

    <% } else if (L.style === 'showcase') { %>
      <%# WeTransfer-like: pełne tło, kompaktowa karta przy boku (lewo/prawo/środek), hero nad kartą %>
      <% const sideCls = L.cardSide === 'right' ? 'ml-auto' : (L.cardSide === 'center' ? 'mx-auto' : 'mr-auto'); %>
      <main class="flex-1 flex items-center px-6 sm:px-10 py-10">
        <div class="w-full max-w-md <%= sideCls %>">
          <% if (showHero) { %>
            <div class="mb-5 <%= L.cardSide === 'center' ? 'text-center' : ''%> <%= heroT %>">
              <h1 class="text-3xl sm:text-4xl font-bold tracking-tight"><%= heroTitle %></h1>
              <% if (heroSubtitle) { %><p class="mt-2 text-base <%= heroS %>"><%= heroSubtitle %></p><% } %>
            </div>
          <% } %>
          <%- body %>
        </div>
      </main>

    <% } else if (isPanel) { %>
      <%# WeTransfer: pełne tło + flush panel pełnej wysokości (bez marginesów/zaokrągleń); hero po stronie tła %>
      <% const panelRight = L.cardSide === 'right'; const panelCenter = L.cardSide === 'center'; %>
      <main class="flex-1 flex <%= panelCenter ? 'justify-center' : '' %>">
        <section class="evoke-panel w-full md:max-w-md bg-white min-h-screen flex flex-col px-6 sm:px-9 py-7 shrink-0 <%= panelRight ? 'md:order-2' : '' %>">
          <div class="flex items-center gap-2 <%= justify %> mb-6 <%= sticky ? 'sticky top-0 z-20 bg-white py-2 -my-2' : '' %>">
            <% if (typeof settings !== 'undefined' && settings && settings.logoPath) { %>
              <%- logoTag(settings, { appName, imgClass: 'max-w-[70%] object-contain', imgStyle: 'height: ' + logoCfg.size + 'px' }) %>
            <% } else if (!L.hideName) { %>
              <div class="w-8 h-8 rounded-lg bg-brand-600 flex items-center justify-center text-white font-bold">E</div>
              <span class="font-semibold tracking-tight text-slate-800"><%= appName %></span>
            <% } %>
          </div>
          <div class="flex-1 flex flex-col justify-center">
            <%- body %>
          </div>
        </section>
        <% if (!panelCenter) { %>
          <aside class="hidden md:flex flex-1 flex-col <%= panelRight ? 'md:order-1' : '' %>">
            <div class="flex-1 flex items-center justify-center p-12">
              <% if (showHero) { %>
                <div class="max-w-md <%= heroT %>">
                  <h1 class="text-4xl font-bold tracking-tight"><%= heroTitle %></h1>
                  <% if (heroSubtitle) { %><p class="mt-3 text-lg <%= heroS %>"><%= heroSubtitle %></p><% } %>
                </div>
              <% } %>
            </div>
            <div class="p-6 text-xs <%= dark ? 'text-slate-300/70' : 'text-slate-500' %>"><%= footerText %></div>
          </aside>
        <% } %>
      </main>

    <% } else if (isPanelBg) { %>
      <%# Panel na tle 2: biały panel z treścią po jednej stronie; LOGO + hero NA TLE po drugiej %>
      <% const pbRight = L.cardSide === 'right'; %>
      <main class="flex-1 flex">
        <section class="evoke-panel w-full md:max-w-md bg-white min-h-screen flex flex-col px-6 sm:px-9 py-7 shrink-0 <%= pbRight ? 'md:order-2' : '' %>">
          <div class="md:hidden flex items-center gap-2 <%= justify %> mb-6">
            <% if (typeof settings !== 'undefined' && settings && settings.logoPath) { %>
              <%- logoTag(settings, { appName, imgClass: 'max-w-[70%] object-contain', imgStyle: 'height: ' + logoCfg.size + 'px' }) %>
            <% } else if (!L.hideName) { %>
              <div class="w-8 h-8 rounded-lg bg-brand-600 flex items-center justify-center text-white font-bold">E</div>
              <span class="font-semibold tracking-tight text-slate-800"><%= appName %></span>
            <% } %>
          </div>
          <div class="flex-1 flex flex-col justify-center"><%- body %></div>
        </section>
        <aside class="hidden md:flex flex-1 flex-col justify-between p-10 <%= pbRight ? 'md:order-1' : '' %>">
          <div class="flex items-center gap-2 <%= justify %>">
            <% if (typeof settings !== 'undefined' && settings && settings.logoPath) { %>
              <%- logoTag(settings, { appName, imgClass: 'max-w-[60%] object-contain', imgStyle: 'height: ' + logoCfg.size + 'px' }) %>
            <% } else if (!L.hideName) { %>
              <div class="w-8 h-8 rounded-lg bg-brand-600 flex items-center justify-center text-white font-bold">E</div>
              <span class="font-semibold tracking-tight <%= dark ? 'text-white' : 'text-slate-800' %>"><%= appName %></span>
            <% } %>
          </div>
          <div>
            <% if (showHero) { %>
              <h1 class="text-3xl sm:text-4xl font-bold tracking-tight <%= heroT %>"><%= heroTitle %></h1>
              <% if (heroSubtitle) { %><p class="mt-3 text-base <%= heroS %>"><%= heroSubtitle %></p><% } %>
            <% } %>
          </div>
          <div class="text-xs <%= dark ? 'text-slate-300/70' : 'text-slate-500' %>"><%= footerText %></div>
        </aside>
      </main>

    <% } else if (L.style === 'sidebar') { %>
      <%# Kolorowy (brand) pasek boczny z logo + hero; treść/karta na tle obok %>
      <% const sbRight = L.cardSide === 'right'; %>
      <main class="flex-1 flex">
        <aside class="hidden md:flex w-72 shrink-0 bg-brand-600 text-white flex-col justify-between p-8 <%= sbRight ? 'md:order-2' : '' %>">
          <div class="flex items-center gap-2 <%= justify %>">
            <% if (typeof settings !== 'undefined' && settings && settings.logoPath) { %>
              <%- logoTag(settings, { appName, imgClass: 'max-w-[80%] object-contain', imgStyle: 'height: ' + logoCfg.size + 'px' }) %>
            <% } else if (!L.hideName) { %>
              <div class="w-8 h-8 rounded-lg bg-white/20 flex items-center justify-center font-bold">E</div>
              <span class="font-semibold tracking-tight"><%= appName %></span>
            <% } %>
          </div>
          <% if (showHero) { %>
            <div><h1 class="text-2xl font-bold tracking-tight"><%= heroTitle %></h1><% if (heroSubtitle) { %><p class="mt-2 text-sm text-white/80"><%= heroSubtitle %></p><% } %></div>
          <% } %>
          <div class="text-xs text-white/70"><%= footerText %></div>
        </aside>
        <div class="flex-1 flex items-center justify-center p-6 sm:p-10"><%- body %></div>
      </main>

    <% } else if (L.style === 'corner') { %>
      <%# Kompaktowa karta zadokowana w dolnym rogu na pełnym tle %>
      <% const coRight = L.cardSide === 'right'; const coCenter = L.cardSide === 'center'; %>
      <main class="flex-1 flex items-end px-6 sm:px-10 py-8 <%= coCenter ? 'justify-center' : (coRight ? 'justify-end' : '') %>">
        <div class="w-full max-w-sm">
          <% if (showHero) { %>
            <div class="mb-3 <%= heroT %>"><h1 class="text-2xl font-bold tracking-tight"><%= heroTitle %></h1><% if (heroSubtitle) { %><p class="mt-1 text-sm <%= heroS %>"><%= heroSubtitle %></p><% } %></div>
          <% } %>
          <%- body %>
        </div>
      </main>

    <% } else if (L.style === 'centered') { %>
      <%# Landing: duży hero wyeksponowany nad kartą na pełnym tle %>
      <main class="flex-1 flex flex-col items-center justify-center px-6 py-10 gap-9">
        <% if (showHero) { %>
          <section class="text-center max-w-3xl">
            <h1 class="text-4xl sm:text-5xl font-bold tracking-tight <%= heroT %>"><%= heroTitle %></h1>
            <% if (heroSubtitle) { %><p class="mt-4 text-lg <%= heroS %>"><%= heroSubtitle %></p><% } %>
          </section>
        <% } %>
        <%- body %>
      </main>

    <% } else { %>
      <%# Układ klasyczny (domyślny) %>
      <% if (showHero) { %>
        <section class="px-6 pt-2 pb-4 text-center <%= heroT %>">
          <h1 class="text-2xl sm:text-3xl font-bold tracking-tight"><%= heroTitle %></h1>
          <% if (heroSubtitle) { %><p class="mt-2 text-sm sm:text-base <%= heroS %>"><%= heroSubtitle %></p><% } %>
        </section>
      <% } %>
      <main class="flex-1 flex items-center justify-center px-6 py-8">
        <%- body %>
      </main>
    <% } %>

    <% if (!noChrome) { %>
    <footer class="px-6 py-5 text-center text-xs <%= dark ? 'text-slate-300/70' : 'text-slate-400' %>">
      <%= footerText %>
    </footer>
    <% } %>
  </div>
</body>
</html>
