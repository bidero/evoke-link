<div class="w-full max-w-sm">
  <div class="bg-white rounded-3xl shadow-xl shadow-brand-200/40 p-8 text-center">
    <div class="flex justify-center mb-3"><%- icon('lock', { size: 40 }) %></div>
    <h1 class="text-xl font-semibold mb-1">Plik chroniony hasłem</h1>
    <p class="text-sm text-slate-500 mb-6">Podaj hasło, aby zobaczyć pliki.</p>

    <% if (error) { %>
      <div class="mb-4 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm px-3 py-2"><%= error %></div>
    <% } %>

    <form method="POST" action="<%= typeof action !== 'undefined' ? action : '/t/' + token %>" class="space-y-3">
      <input name="password" type="password" autofocus required placeholder="Hasło"
             class="w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-center focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
      <button type="submit" class="w-full rounded-lg bg-brand-600 hover:bg-brand-700 text-white font-medium py-2.5 text-sm transition">
        Odblokuj
      </button>
    </form>
  </div>
</div>
