<div class="w-full max-w-lg">
  <% if (sent) { %>
    <div class="evoke-card p-5 sm:p-8 text-center">
      <div class="flex justify-center mb-3"><%- icon('check', { size: 44, cls: 'text-green-600' }) %></div>
      <h1 class="text-2xl font-semibold tracking-tight mb-1">Dziękujemy!</h1>
      <p class="text-sm text-slate-500 mb-2">Przesłano <%= count %> plik(ów). Otrzymaliśmy Twoje materiały.</p>
      <% if (transfer.project) { %><p class="text-xs font-medium text-brand-700 mb-6">Projekt: <%= transfer.project.name %></p><% } else { %><div class="mb-6"></div><% } %>
      <a href="/upload/<%= transfer.token %>" class="evoke-btn inline-block rounded-xl bg-brand-600 hover:bg-brand-700 text-white font-medium px-5 py-2.5 transition">
        Prześlij kolejne pliki
      </a>
    </div>
  <% } else { %>
    <div class="evoke-card p-5 sm:p-8" x-data="uploader()">
      <%- include('_hero_in_card') %>
      <h1 class="text-2xl font-semibold tracking-tight mb-1"><%= transfer.title || 'Prześlij pliki' %></h1>
      <% if (transfer.project) { %>
        <p class="text-xs font-medium text-brand-700 mb-1">Projekt: <%= transfer.project.name %></p>
      <% } %>
      <% if (transfer.message) { %>
        <p class="text-sm text-slate-500 mb-6 whitespace-pre-line"><%= transfer.message %></p>
      <% } else { %>
        <p class="text-sm text-slate-500 mb-6">Przeciągnij pliki lub kliknij, aby wybrać.</p>
      <% } %>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="mb-4 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm px-3 py-2"><%= error %></div>
      <% } %>

      <form @submit.prevent="submit" class="space-y-4">
        <div
          @dragover.prevent="dragging = true" @dragleave.prevent="dragging = false" @drop.prevent="onDrop($event)"
          :class="dragging ? 'border-brand-500 bg-brand-50' : 'border-slate-300'"
          class="rounded-2xl border-2 border-dashed p-8 text-center transition cursor-pointer"
          @click="$refs.input.click()">
          <input x-ref="input" type="file" multiple class="hidden" @change="addFiles($event.target.files)" />
          <div class="flex justify-center mb-1"><%- icon('cloudUpload', { size: 32 }) %></div>
          <p class="text-sm font-medium text-slate-600">Przeciągnij pliki tutaj</p>
          <p class="text-xs text-slate-400">lub kliknij, aby wybrać</p>
        </div>

        <template x-if="files.length">
          <div class="rounded-xl border border-slate-200 divide-y divide-slate-100 text-sm">
            <template x-for="(f, i) in files" :key="i">
              <div class="flex items-center gap-3 px-3 py-2">
                <template x-if="f.preview"><img :src="f.preview" alt="" class="w-9 h-9 rounded-lg object-cover border border-slate-200 shrink-0" /></template>
                <template x-if="!f.preview"><span class="w-9 h-9 rounded-lg bg-slate-50 border border-slate-100 flex items-center justify-center shrink-0"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg></span></template>
                <div class="min-w-0 flex-1">
                  <div class="truncate text-slate-700" x-text="f.name"></div>
                  <div class="mt-1 h-1.5 bg-slate-100 rounded-full overflow-hidden" x-show="uploading">
                    <div class="h-full bg-brand-600 transition-all duration-200" :style="'width:' + Math.max(f.progress, 2) + '%'"></div>
                  </div>
                </div>
                <div class="flex items-center gap-2 shrink-0">
                  <span class="text-xs text-slate-400" x-show="!uploading" x-text="human(f.size)"></span>
                  <span class="text-xs text-slate-500 tabular-nums" x-show="uploading" x-text="f.progress + '%'"></span>
                  <button type="button" @click="remove(i)" x-show="!uploading" class="text-slate-400 hover:text-red-600" aria-label="Usuń"><%- icon('x', { size: 16, cls: '' }) %></button>
                </div>
              </div>
            </template>
          </div>
        </template>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <input name="name" type="text" placeholder="Twoje imię / firma (opcjonalnie)"
                 class="rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
          <input name="email" type="email" placeholder="Twój e-mail (opcjonalnie)"
                 class="rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
        </div>

        <button type="submit" :disabled="uploading || !files.length"
                class="evoke-btn w-full rounded-xl bg-brand-600 hover:bg-brand-700 disabled:opacity-40 disabled:cursor-not-allowed text-white font-medium py-3 transition">
          <span x-show="!uploading">Prześlij pliki</span>
          <span x-show="uploading" x-text="finalizing ? 'Finalizowanie…' : ('Wysyłanie… ' + progress + '%')"></span>
        </button>
      </form>
    </div>
  <% } %>
</div>

<% if (!sent) { %>
<script>
function uploader() {
  return makeUploader({
    chunkUrl: function () { return window.location.pathname.replace(/\/$/, '') + '/chunk'; },
    finalize: async function (uploadId, form) {
      const body = new URLSearchParams();
      body.append('uploadId', uploadId);
      ['name', 'email'].forEach(function (n) { if (form && form[n] && form[n].value) body.append(n, form[n].value); });
      const res = await fetch(window.location.pathname, { method: 'POST', body });
      if (!res.ok) throw new Error('Błąd wysyłania (' + res.status + ').');
      const html = await res.text();
      document.open(); document.write(html); document.close();
    },
  });
}
</script>
<% } %>
