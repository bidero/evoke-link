<%# Fragment Turbo Streams po zgłoszeniu przelewu w /c (Etap 2 — bez reloadu). Podmienia przycisk na
    chip „zgłoszono" i pokazuje podziękowanie. Locals: token, paidDeclaredAt. %>
<turbo-stream action="update" target="paid-declare"><template><%- include('../_paid_declare', { token: token, paidDeclaredAt: paidDeclaredAt, turbo: true }) %></template></turbo-stream>
<turbo-stream action="update" target="paid-flash"><template><div class="mt-3 flex items-center gap-2 rounded-lg bg-green-50 border border-green-200 text-green-800 text-sm px-3 py-2"><%- icon('check', { size: 16, cls: 'text-green-600' }) %> Dziękujemy! Przekazaliśmy informację o wpłacie — potwierdzimy ją wkrótce.</div></template></turbo-stream>
