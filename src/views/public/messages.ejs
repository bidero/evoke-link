<%# Podstrona wiadomości (zastępuje dawny popup) — wspólny widok dla /c /p /t /upload /o.
    Locals: msgBack {href,label} (powrót), msgContext {action,scope} (POST + podpis),
    msgThread (wątek), msgSent (toast w layoucie po ?msg=1). %>
<div class="w-full max-w-2xl">
  <div class="evoke-card p-5 sm:p-8">
    <% if (typeof msgBack !== 'undefined' && msgBack) { %>
      <a href="<%= msgBack.href %>" class="inline-flex items-center gap-1.5 text-xs font-medium text-slate-500 hover:text-brand-700 transition mb-2">
        <%- icon('arrowLeft', { size: 14, cls: '' }) %> <%= msgBack.label %>
      </a>
    <% } %>
    <h1 class="text-2xl font-semibold tracking-tight">Wiadomości</h1>
    <% if (msgContext && msgContext.scope) { %>
      <p class="text-sm text-slate-500 mt-1"><%= msgContext.scope %></p>
    <% } %>

    <% if (typeof msgThread !== 'undefined' && msgThread && msgThread.length) { %>
      <div class="mt-6 max-h-[50vh] overflow-y-auto space-y-2 pr-1">
        <% msgThread.forEach(function(mm){ var out = mm.direction === 'out'; %>
          <div class="flex <%= out ? 'justify-start' : 'justify-end' %>">
            <div class="max-w-[85%]">
              <div class="rounded-2xl px-3 py-2 text-sm whitespace-pre-wrap break-words <%= out ? 'bg-slate-100 text-slate-800' : 'bg-brand-600 text-white' %>"><%= mm.body %></div>
              <% if (mm.attachmentName) { %>
                <div class="mt-1 inline-flex items-center gap-1.5 text-xs <%= out ? 'text-slate-500' : 'text-brand-700' %>"><%- icon('file', { size: 12, cls: '' }) %><%= mm.attachmentName %></div>
              <% } %>
              <div class="mt-0.5 text-[11px] text-slate-400 <%= out ? '' : 'text-right' %>"><%= fmt.date(mm.createdAt) %></div>
            </div>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <p class="mt-6 text-sm text-slate-400">Brak wiadomości — napisz do nas poniżej.</p>
    <% } %>

    <form method="POST" action="<%= msgContext.action %>" enctype="multipart/form-data" data-turbo="false" class="mt-6 pt-6 border-t border-slate-100 space-y-3" x-data="{ fileName: '' }">
      <textarea name="body" required rows="4" maxlength="4000" placeholder="Twoja wiadomość…"
        class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-800 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none"></textarea>
      <%# Imię/e-mail TYLKO gdy nadawca nieznany (anonimowy transfer /t /upload). W portalu klienta
          (/p /c /o) klient jest znany — pola zbędne. %>
      <% if (typeof msgKnownSender === 'undefined' || !msgKnownSender) { %>
        <div class="grid grid-cols-2 gap-2">
          <input name="senderName" type="text" placeholder="Imię (opc.)" class="rounded-lg border border-slate-300 px-2 py-1.5 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
          <input name="senderEmail" type="email" placeholder="E-mail do odpowiedzi (opc.)" class="rounded-lg border border-slate-300 px-2 py-1.5 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
        </div>
      <% } %>
      <%# „Dołącz plik" jako wyraźny obramowany przycisk (było małym linkiem, łatwe do przeoczenia). %>
      <div class="flex items-center gap-3 flex-wrap">
        <label class="inline-flex items-center gap-2 rounded-lg border border-dashed border-slate-400 px-4 py-2 text-sm font-medium text-slate-600 cursor-pointer hover:bg-brand-50 hover:text-brand-700 hover:border-brand-300 transition">
          <%- icon('cloudUpload', { size: 18, cls: '' }) %> Dołącz plik
          <input type="file" name="attachment" class="hidden" @change="fileName = $event.target.files.length ? $event.target.files[0].name : ''" />
        </label>
        <span class="inline-flex items-center gap-1.5 text-xs text-slate-600 truncate min-w-0" x-show="fileName" x-cloak>
          <%- icon('file', { size: 13, cls: 'shrink-0' }) %><span class="truncate" x-text="fileName"></span>
        </span>
      </div>
      <button type="submit" class="evoke-btn w-full rounded-xl bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium py-2.5 transition">Wyślij</button>
    </form>
  </div>
</div>
