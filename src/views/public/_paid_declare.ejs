<%# Zgłoszenie wykonania przelewu (/c) — chip „zgłoszono" albo przycisk. Używane w client-portal.ejs
    i w streamie po zgłoszeniu (Etap 2 — bez reloadu). Locals: token, paidDeclaredAt, turbo. %>
<% if (paidDeclaredAt) { %>
  <span class="inline-flex items-center gap-1.5 text-xs px-2.5 py-1 rounded-full bg-amber-50 text-amber-700" title="Czekamy na potwierdzenie wpłaty przez agencję">
    <%- icon('clock', { size: 13, cls: 'text-amber-500' }) %> Zgłoszono wpłatę <%= fmt.dateOnly(paidDeclaredAt) %> — czekamy na potwierdzenie
  </span>
<% } else { %>
  <%# turbo=true (/c): Turbo obsłuży submit i wstawi stream (bez reloadu); confirm dalej działa (onsubmit). %>
  <form method="POST" action="/c/<%= token %>/paid" <%- (typeof turbo !== 'undefined' && turbo) ? '' : 'data-turbo="false"' %> onsubmit="return confirm('Zgłosić wykonanie przelewu za powyższe pozycje?')">
    <button type="submit" class="evoke-btn inline-flex items-center gap-1.5 rounded-xl border border-slate-300 text-slate-600 hover:bg-brand-50 hover:text-brand-700 hover:border-brand-200 text-sm font-medium px-4 py-2 transition">
      <%- icon('banknote', { size: 15, cls: '' }) %> Zgłoś wykonanie przelewu
    </button>
  </form>
<% } %>
