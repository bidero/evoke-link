<%
  // Nawigacja sekcji: sekcje/klucze/defaultSec buduje KONTROLER (portalNav) — czyta je też layout,
  // który renderuje warianty chrome (menu w nagłówku / pas pionowy) i trzyma x-data ze stanem `sec`.
  // Efektywny tryb w res.locals.portalNavMode; portalNav = null przy < 2 sekcjach → stos jak dotąd.
  var navMode = (typeof portalNavMode !== 'undefined' && portalNavMode) ? portalNavMode : 'none';
  var nav = (typeof portalNav !== 'undefined' && portalNav) ? portalNav : null;
  var navOn = navMode !== 'none' && !!nav;
  var sections = nav ? nav.sections : [];
  var inCard = navOn && (navMode === 'tabs' || navMode.indexOf('side') === 0); // zakładki/menu w karcie
  var sideNav = navOn && navMode.indexOf('side') === 0;
  var pageTop = navOn && navMode === 'top';            // pasek nad kartą (pływający)
  var pageBar = navOn && navMode.indexOf('bar') === 0; // panel obok karty (pływający)
  // Otwiera sekcję: przy stosie zawsze true; przy nawigacji steruje x-show (stan `sec` z layoutu).
  function secAttr(key, first) { return navOn ? ('x-show="sec===\'' + key + '\'"' + (first ? '' : ' x-cloak')) : ''; }
%>
<div class="w-full <%= (sideNav || pageBar) ? 'max-w-4xl' : 'max-w-2xl' %>">
  <% if (pageTop || pageBar) { %><%- include('_portal_nav', { sections: sections, navMode: navMode, part: 'page-top' }) %><% } %>
  <div class="<%= pageBar ? 'md:flex md:gap-6 md:items-start' : '' %>">
    <% if (pageBar) { %><%- include('_portal_nav', { sections: sections, navMode: navMode, part: 'page-side' }) %><% } %>
    <div class="evoke-card p-5 sm:p-8 <%= pageBar ? 'flex-1 min-w-0' : '' %>">
    <h1 class="text-2xl font-semibold tracking-tight mb-1"><%= portalClient.name %></h1>
    <p class="text-sm text-slate-500 mb-6">Twoje projekty — wybierz, aby zobaczyć i przesłać pliki.</p>

    <div class="<%= sideNav ? 'md:flex md:gap-8 md:items-start' : '' %>">
      <% if (inCard) { %><%- include('_portal_nav', { sections: sections, navMode: navMode, part: 'side' }) %><% } %>
      <div class="min-w-0 flex-1">
        <% if (inCard) { %><%- include('_portal_nav', { sections: sections, navMode: navMode, part: 'tabs' }) %><% } %>

        <div <%- secAttr('projekty', true) %>>
          <%
            // Aktywne projekty w głównej liście; zarchiwizowane chowamy pod zwijanym „Archiwum".
            var activeProjects = portalClient.projects.filter(function(p){ return p.status !== 'archived'; });
            var archivedProjects = portalClient.projects.filter(function(p){ return p.status === 'archived'; });
          %>
          <% if (!portalClient.projects.length) { %>
            <p class="text-sm text-slate-400">Brak projektów.</p>
          <% } else { %>
            <% if (activeProjects.length) { %>
              <div class="rounded-xl border border-slate-200 divide-y divide-slate-100 overflow-hidden">
                <% activeProjects.forEach(function(p){ %>
                  <a href="/p/<%= p.clientToken %>" class="flex items-center justify-between px-4 py-3 hover:bg-slate-50 transition group">
                    <span class="min-w-0">
                      <span class="block text-sm font-medium text-slate-800 truncate"><%= p.name %></span>
                      <% if (p.description) { %><span class="block text-xs text-slate-400 truncate"><%= p.description %></span><% } %>
                    </span>
                    <span class="text-brand-600 opacity-0 group-hover:opacity-100 transition shrink-0"><%- icon('arrowRight', { size: 16 }) %></span>
                  </a>
                <% }); %>
              </div>
            <% } else { %>
              <p class="text-sm text-slate-400">Brak aktywnych projektów.</p>
            <% } %>

            <% if (archivedProjects.length) { %>
              <div class="mt-3" x-data="{ arch: false }">
                <button type="button" @click="arch = !arch" class="inline-flex items-center gap-1.5 text-xs font-medium text-slate-500 hover:text-slate-700 transition">
                  <%- icon('archive', { size: 14, cls: '' }) %>
                  <span x-text="arch ? 'Ukryj archiwum' : 'Archiwum (<%= archivedProjects.length %>)'"></span>
                </button>
                <div x-show="arch" x-cloak class="mt-2 rounded-xl border border-slate-200 divide-y divide-slate-100 overflow-hidden">
                  <% archivedProjects.forEach(function(p){ %>
                    <a href="/p/<%= p.clientToken %>" class="flex items-center justify-between px-4 py-3 hover:bg-slate-50 transition group">
                      <span class="min-w-0">
                        <span class="block text-sm text-slate-500 truncate"><%= p.name %></span>
                        <% if (p.description) { %><span class="block text-xs text-slate-400 truncate"><%= p.description %></span><% } %>
                      </span>
                      <span class="text-slate-400 opacity-0 group-hover:opacity-100 transition shrink-0"><%- icon('arrowRight', { size: 16 }) %></span>
                    </a>
                  <% }); %>
                </div>
              </div>
            <% } %>
          <% } %>
        </div>

        <% if (offers.length) { %>
          <!-- Oferty do wglądu / akceptacji -->
          <div <%- secAttr('oferty') %> class="<%= navOn ? '' : 'mt-6 pt-6 border-t border-slate-100' %>">
            <% if (!navOn) { %><h2 class="text-sm font-semibold text-slate-700 mb-3">Oferty</h2><% } %>
            <% const _oc = { open: ['do akceptacji', 'bg-amber-50 text-amber-700'], accepted: ['zaakceptowana', 'bg-green-50 text-green-700'], rejected: ['odrzucona', 'bg-slate-100 text-slate-500'] }; %>
            <div class="rounded-xl border border-slate-200 divide-y divide-slate-100 overflow-hidden">
              <% offers.forEach(function(o){ const _c = _oc[o.st] || _oc.open; %>
                <a href="/o/<%= o.token %>" class="flex items-center justify-between gap-3 px-4 py-3 hover:bg-slate-50 transition group">
                  <span class="min-w-0">
                    <span class="block text-sm font-medium text-slate-800 truncate"><%= o.title %></span>
                    <span class="inline-flex items-center gap-1.5 mt-0.5">
                      <span class="text-xs px-2 py-0.5 rounded-full <%= _c[1] %>"><%= _c[0] %></span>
                      <span class="text-xs text-slate-400"><%= fmt.money(o.gross) %> brutto</span>
                    </span>
                  </span>
                  <span class="text-brand-600 opacity-0 group-hover:opacity-100 transition shrink-0"><%- icon('arrowRight', { size: 16 }) %></span>
                </a>
              <% }); %>
            </div>
          </div>
        <% } %>

        <% if (typeof documents !== 'undefined' && documents.length) { %>
          <!-- Dokumenty udostępnione klientowi -->
          <div <%- secAttr('dokumenty') %> class="<%= navOn ? '' : 'mt-6 pt-6 border-t border-slate-100' %>">
            <% if (!navOn) { %><h2 class="text-sm font-semibold text-slate-700 mb-3">Dokumenty</h2><% } %>
            <div class="rounded-xl border border-slate-200 divide-y divide-slate-100 overflow-hidden">
              <% documents.forEach(function(d){ %>
                <a href="/c/<%= portalClient.token %>/documents/<%= d.id %>" class="flex items-center gap-3 px-4 py-3 hover:bg-slate-50 transition group">
                  <span class="shrink-0"><%- icon('fileText', { size: 18, cls: 'text-slate-400' }) %></span>
                  <span class="min-w-0 flex-1">
                    <span class="block text-sm font-medium text-slate-800 truncate"><%= d.label || d.name %></span>
                    <span class="block text-xs text-slate-400"><% if (d.size) { %><%= fmt.bytes(d.size) %> · <% } %><%= fmt.dateOnly(d.createdAt) %></span>
                  </span>
                  <span class="text-brand-600 opacity-0 group-hover:opacity-100 transition shrink-0"><%- icon('download', { size: 16 }) %></span>
                </a>
              <% }); %>
            </div>
          </div>
        <% } %>

        <% if (typeof unpaid !== 'undefined' && unpaid.length) { %>
          <!-- Do zapłaty: nierozliczone pozycje + dane do przelewu (+ QR wg ZBP) -->
          <div <%- secAttr('platnosci') %> class="<%= navOn ? '' : 'mt-6 pt-6 border-t border-slate-100' %>" x-data="{ qr: false }">
            <% if (!navOn) { %><h2 class="text-sm font-semibold text-slate-700 mb-3">Do zapłaty</h2><% } %>
            <div class="rounded-xl border border-slate-200 divide-y divide-slate-100 overflow-hidden text-sm">
              <% const now = new Date(); unpaid.forEach(function(c){ const overdue = c.dueDate && new Date(c.dueDate) < now; %>
                <div class="flex items-center justify-between gap-3 px-4 py-2.5">
                  <span class="min-w-0">
                    <span class="block text-slate-700 truncate"><%= c.label || 'Pozycja' %></span>
                    <span class="block text-xs mt-0.5 <%= overdue ? 'text-red-600 font-medium' : 'text-slate-400' %>">
                      <%= c.project ? c.project.name : '' %><%= c.project && c.dueDate ? ' · ' : '' %><%= c.dueDate ? 'termin ' + fmt.dateOnly(c.dueDate) : '' %><%= overdue ? ' · po terminie' : '' %>
                    </span>
                  </span>
                  <span class="shrink-0 font-medium text-slate-800"><%= fmt.money(c.gross) %></span>
                </div>
              <% }); %>
              <div class="flex items-center justify-between gap-3 px-4 py-2.5 bg-slate-50">
                <span class="text-slate-600 font-medium">Razem do zapłaty</span>
                <span class="shrink-0 font-semibold text-brand-700"><%= fmt.money(unpaidTotal) %></span>
              </div>
            </div>

            <% if (paidFlash) { %>
              <div class="mt-3 flex items-center gap-2 rounded-lg bg-green-50 border border-green-200 text-green-800 text-sm px-3 py-2"><%- icon('check', { size: 16, cls: 'text-green-600' }) %> Dziękujemy! Przekazaliśmy informację o wpłacie — potwierdzimy ją wkrótce.</div>
            <% } %>

            <% if (seller && seller.bank) { %>
              <div class="mt-3 rounded-xl bg-slate-50 border border-slate-100 px-4 py-3 text-sm space-y-1">
                <p class="text-xs font-medium text-slate-500 uppercase tracking-wide mb-1.5">Dane do przelewu</p>
                <% if (seller.name) { %><p><span class="text-slate-500">Odbiorca:</span> <span class="text-slate-700"><%= seller.name %></span></p><% } %>
                <p><span class="text-slate-500">Konto:</span> <span class="text-slate-700 break-all"><%= seller.bank %></span></p>
                <p><span class="text-slate-500">Tytuł:</span> <span class="text-slate-700"><%= transferTitle %></span></p>
                <% if (paymentQr) { %>
                  <div class="pt-1.5">
                    <button type="button" @click="qr = !qr" class="text-xs font-medium text-brand-700 hover:text-brand-800" x-text="qr ? 'Ukryj kod QR' : 'Zapłać telefonem — pokaż kod QR'"></button>
                    <div x-show="qr" x-cloak class="mt-2">
                      <span class="inline-block rounded-xl border border-slate-200 bg-white p-2"><%- qrSvg(paymentQr, { cell: 3 }) %></span>
                      <p class="text-xs text-slate-400 mt-1.5">Zeskanuj w aplikacji banku — dane przelewu uzupełnią się same.</p>
                    </div>
                  </div>
                <% } %>
              </div>
            <% } %>

            <div class="mt-3">
              <% if (paidDeclaredAt) { %>
                <span class="inline-flex items-center gap-1.5 text-xs px-2.5 py-1 rounded-full bg-amber-50 text-amber-700" title="Czekamy na potwierdzenie wpłaty przez agencję">
                  <%- icon('clock', { size: 13, cls: 'text-amber-500' }) %> Zgłoszono wpłatę <%= fmt.dateOnly(paidDeclaredAt) %> — czekamy na potwierdzenie
                </span>
              <% } else { %>
                <form method="POST" action="/c/<%= portalClient.token %>/paid" onsubmit="return confirm('Zgłosić wykonanie przelewu za powyższe pozycje?')">
                  <button type="submit" class="evoke-btn inline-flex items-center gap-1.5 rounded-xl border border-slate-300 text-slate-600 hover:bg-brand-50 hover:text-brand-700 hover:border-brand-200 text-sm font-medium px-4 py-2 transition">
                    <%- icon('banknote', { size: 15, cls: '' }) %> Zgłoś wykonanie przelewu
                  </button>
                </form>
              <% } %>
            </div>
          </div>
        <% } %>
      </div>
    </div>
    </div>
  </div>
</div>
