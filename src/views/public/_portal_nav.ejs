<%# Nawigacja sekcji portali klienta (/c i /p) — Settings.layout.portalNav.
    W karcie: part 'side' (kolumna menu od md) i 'tabs' (poziome zakładki; przy menu bocznym
    tylko poniżej md — fallback mobilny). Na poziomie strony (poza kartą, na tle):
    part 'page-top' (pasek u góry; dla bar-* tylko poniżej md) i 'page-side' (pływający
    panel boczny od md). Warianty page-* adaptują kolory do ciemnego tła (bgDark).
    Locals: sections [{key,label,icon,badge?}], navMode, part. Stan `sec` z x-data widoku. %>
<% const side = navMode.indexOf('side') === 0; %>
<% const dk = (typeof bgDark !== 'undefined' && bgDark); %>
<% if (part === 'side' && side) { %>
<nav class="hidden md:block w-44 shrink-0 <%= navMode === 'side-right' ? 'md:order-2' : '' %>">
  <ul class="space-y-1 sticky top-6">
    <% sections.forEach(function(s){ %>
      <li>
        <button type="button" @click="sec='<%= s.key %>'; history.replaceState(null,'','#<%= s.key %>')"
                :class="sec==='<%= s.key %>' ? 'bg-brand-50 text-brand-700 font-medium' : 'text-slate-600 hover:bg-slate-50'"
                class="w-full flex items-center gap-2.5 rounded-lg px-3 py-2 text-sm transition text-left">
          <%- icon(s.icon, { size: 16, cls: 'shrink-0' }) %>
          <span class="flex-1 truncate"><%= s.label %></span>
          <% if (s.badge) { %><span class="text-[11px] font-medium px-1.5 py-0.5 rounded-full bg-brand-100 text-brand-700"><%= s.badge %></span><% } %>
        </button>
      </li>
    <% }); %>
  </ul>
</nav>
<% } else if (part === 'tabs') { %>
<div class="<%= side ? 'md:hidden ' : '' %>flex gap-1 overflow-x-auto border-b border-slate-200 mb-6" role="tablist">
  <% sections.forEach(function(s){ %>
    <button type="button" role="tab" @click="sec='<%= s.key %>'; history.replaceState(null,'','#<%= s.key %>')"
            :class="sec==='<%= s.key %>' ? 'border-brand-600 text-brand-700' : 'border-transparent text-slate-500 hover:text-slate-700'"
            class="inline-flex items-center gap-1.5 whitespace-nowrap border-b-2 -mb-px px-3 py-2 text-sm font-medium transition">
      <%- icon(s.icon, { size: 15, cls: 'shrink-0' }) %>
      <span><%= s.label %></span>
      <% if (s.badge) { %><span class="text-[11px] px-1.5 py-0.5 rounded-full bg-brand-100 text-brand-700"><%= s.badge %></span><% } %>
    </button>
  <% }); %>
</div>
<% } else if (part === 'page-top') { %>
<%# Pasek u góry strony (nad kartą, na tle). Fallback mobilny (md:hidden) dla bar-*/rail-*
    — wymuszany też jawnie przez local `mobileOnly` (include z layoutu). %>
<div data-pnav="top" role="tablist"
     class="<%= ((typeof mobileOnly !== 'undefined' && mobileOnly) || navMode.indexOf('bar') === 0) ? 'md:hidden ' : '' %>mb-5 flex flex-wrap justify-center gap-1 rounded-2xl <%= dk ? 'bg-white/10' : 'bg-white/70 shadow-sm' %> backdrop-blur px-2 py-1.5">
  <% sections.forEach(function(s){ %>
    <button type="button" role="tab" @click="sec='<%= s.key %>'; history.replaceState(null,'','#<%= s.key %>')"
            :class="sec==='<%= s.key %>' ? 'bg-brand-600 text-white' : '<%= dk ? 'text-white/85 hover:bg-white/10' : 'text-slate-600 hover:bg-slate-100' %>'"
            class="inline-flex items-center gap-1.5 whitespace-nowrap rounded-xl px-3 py-1.5 text-sm font-medium transition">
      <%- icon(s.icon, { size: 15, cls: 'shrink-0' }) %>
      <span><%= s.label %></span>
      <% if (s.badge) { %><span class="text-[11px] px-1.5 py-0.5 rounded-full bg-brand-100 text-brand-700"><%= s.badge %></span><% } %>
    </button>
  <% }); %>
</div>
<% } else if (part === 'page-side' && navMode.indexOf('bar') === 0) { %>
<%# Pływający pasek boczny strony (osobny panel obok karty, na tle). %>
<nav data-pnav="bar" class="hidden md:block w-48 shrink-0 <%= navMode === 'bar-right' ? 'md:order-2' : '' %>">
  <ul class="sticky top-6 space-y-1 rounded-2xl <%= dk ? 'bg-white/10' : 'bg-white/70 shadow-sm' %> backdrop-blur p-2">
    <% sections.forEach(function(s){ %>
      <li>
        <button type="button" @click="sec='<%= s.key %>'; history.replaceState(null,'','#<%= s.key %>')"
                :class="sec==='<%= s.key %>' ? 'bg-brand-600 text-white font-medium' : '<%= dk ? 'text-white/85 hover:bg-white/10' : 'text-slate-600 hover:bg-white' %>'"
                class="w-full flex items-center gap-2.5 rounded-xl px-3 py-2 text-sm transition text-left">
          <%- icon(s.icon, { size: 16, cls: 'shrink-0' }) %>
          <span class="flex-1 truncate"><%= s.label %></span>
          <% if (s.badge) { %><span class="text-[11px] font-medium px-1.5 py-0.5 rounded-full bg-brand-100 text-brand-700"><%= s.badge %></span><% } %>
        </button>
      </li>
    <% }); %>
  </ul>
</nav>
<% } else if (part === 'chrome-top') { %>
<%# Menu w chrome strony (nagłówek obok logo / banner / biały panel).
    tone: 'bg' (na tle, dark-aware) | 'white' (w białym panelu) | 'brand' (na kolorze brandu). %>
<%
  var tn = (typeof tone !== 'undefined' && tone) ? tone : 'bg';
  var actCls = tn === 'brand' ? 'bg-white text-brand-700' : 'bg-brand-600 text-white';
  var idleCls = tn === 'brand' ? 'text-white/85 hover:bg-white/15'
    : tn === 'white' ? 'text-slate-600 hover:bg-slate-100'
    : (dk ? 'text-white/85 hover:bg-white/15' : 'text-slate-600 hover:bg-black/5');
%>
<nav data-pnav="chrome-top" role="tablist" class="flex flex-wrap items-center gap-1">
  <% sections.forEach(function(s){ %>
    <button type="button" role="tab" @click="sec='<%= s.key %>'; history.replaceState(null,'','#<%= s.key %>')"
            :class="sec==='<%= s.key %>' ? '<%= actCls %>' : '<%= idleCls %>'"
            class="inline-flex items-center gap-1.5 whitespace-nowrap rounded-xl px-3 py-1.5 text-sm font-medium transition">
      <%- icon(s.icon, { size: 15, cls: 'shrink-0' }) %>
      <span><%= s.label %></span>
      <% if (s.badge) { %><span class="text-[11px] px-1.5 py-0.5 rounded-full <%= tn === 'brand' ? 'bg-white/20' : 'bg-brand-100 text-brand-700' %>"><%= s.badge %></span><% } %>
    </button>
  <% }); %>
</nav>
<% } else if (part === 'rail') { %>
<%# Pionowe menu w brandowym pasie (rail-* = własny pas; przy kompozycji „Pasek boczny"
    wpinane w jej istniejący pas). Zawsze na kolorze brandu — biały tekst. %>
<nav data-pnav="rail" class="space-y-1">
  <% sections.forEach(function(s){ %>
    <button type="button" @click="sec='<%= s.key %>'; history.replaceState(null,'','#<%= s.key %>')"
            :class="sec==='<%= s.key %>' ? 'bg-white text-brand-700 font-medium' : 'text-white/85 hover:bg-white/15'"
            class="w-full flex items-center gap-2.5 rounded-xl px-3 py-2 text-sm transition text-left">
      <%- icon(s.icon, { size: 16, cls: 'shrink-0' }) %>
      <span class="flex-1 truncate"><%= s.label %></span>
      <% if (s.badge) { %><span class="text-[11px] font-medium px-1.5 py-0.5 rounded-full bg-white/20"><%= s.badge %></span><% } %>
    </button>
  <% }); %>
</nav>
<% } %>
