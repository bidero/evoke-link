<%# Nawigacja sekcji portali klienta (/c i /p) — Settings.layout.portalNav (tabs | side-left | side-right).
    Include z part: 'side' (kolumna menu, widoczna od md) lub 'tabs' (poziome zakładki;
    przy menu bocznym renderowane tylko poniżej md — fallback mobilny).
    Locals: sections [{key,label,icon,badge?}], navMode, part. Stan `sec` pochodzi z x-data karty. %>
<% const side = navMode.indexOf('side') === 0; %>
<% if (part === 'side' && side) { %>
<nav class="hidden md:block w-44 shrink-0 <%= navMode === 'side-right' ? 'md:order-2' : '' %>">
  <ul class="space-y-1 sticky top-6">
    <% sections.forEach(function(s){ %>
      <li>
        <button type="button" @click="sec='<%= s.key %>'; history.replaceState(null,'','#<%= s.key %>')"
                :class="sec==='<%= s.key %>' ? 'bg-brand-50 text-brand-700 font-medium' : 'text-slate-600 hover:bg-slate-50'"
                class="w-full flex items-center gap-2.5 rounded-lg px-3 py-2 text-sm transition text-left">
          <%- icon(s.icon, { size: 16, cls: 'shrink-0' }) %>
          <span class="flex-1 truncate"><%= s.label %></span>
          <% if (s.badge) { %><span class="text-[11px] font-medium px-1.5 py-0.5 rounded-full bg-brand-100 text-brand-700"><%= s.badge %></span><% } %>
        </button>
      </li>
    <% }); %>
  </ul>
</nav>
<% } else if (part === 'tabs') { %>
<div class="<%= side ? 'md:hidden ' : '' %>flex gap-1 overflow-x-auto border-b border-slate-200 mb-6" role="tablist">
  <% sections.forEach(function(s){ %>
    <button type="button" role="tab" @click="sec='<%= s.key %>'; history.replaceState(null,'','#<%= s.key %>')"
            :class="sec==='<%= s.key %>' ? 'border-brand-600 text-brand-700' : 'border-transparent text-slate-500 hover:text-slate-700'"
            class="inline-flex items-center gap-1.5 whitespace-nowrap border-b-2 -mb-px px-3 py-2 text-sm font-medium transition">
      <%- icon(s.icon, { size: 15, cls: 'shrink-0' }) %>
      <span><%= s.label %></span>
      <% if (s.badge) { %><span class="text-[11px] px-1.5 py-0.5 rounded-full bg-brand-100 text-brand-700"><%= s.badge %></span><% } %>
    </button>
  <% }); %>
</div>
<% } %>
