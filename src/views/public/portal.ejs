<%
  // Nawigacja sekcji: sekcje/klucze/defaultSec buduje KONTROLER (portalNav) — czyta je też layout,
  // który renderuje warianty chrome (menu w nagłówku / pas pionowy) i trzyma x-data ze stanem `sec`.
  var navMode = (typeof portalNavMode !== 'undefined' && portalNavMode) ? portalNavMode : 'none';
  var nav = (typeof portalNav !== 'undefined' && portalNav) ? portalNav : null;
  var navOn = navMode !== 'none' && !!nav;
  var sections = nav ? nav.sections : [];
  var inCard = navOn && (navMode === 'tabs' || navMode.indexOf('side') === 0); // zakładki/menu w karcie
  var sideNav = navOn && navMode.indexOf('side') === 0;
  var pageTop = navOn && navMode === 'top';            // pasek nad kartą (pływający)
  var pageBar = navOn && navMode.indexOf('bar') === 0; // panel obok karty (pływający)
  const fileRequests = project.fileRequests || []; const openRequests = fileRequests.filter((r) => !r.done);
  function secAttr(key, first) { return navOn ? ('x-show="sec===\'' + key + '\'"' + (first ? '' : ' x-cloak')) : ''; }
%>
<div class="w-full <%= (sideNav || pageBar) ? 'max-w-4xl' : 'max-w-2xl' %>">
  <% if (pageTop || pageBar) { %><%- include('_portal_nav', { sections: sections, navMode: navMode, part: 'page-top' }) %><% } %>
  <div class="<%= pageBar ? 'md:flex md:gap-6 md:items-start' : '' %>">
    <% if (pageBar) { %><%- include('_portal_nav', { sections: sections, navMode: navMode, part: 'page-side' }) %><% } %>
    <div class="evoke-card p-5 sm:p-8 <%= pageBar ? 'flex-1 min-w-0' : '' %>">
    <%- include('_hero_in_card') %>
    <%# Przy pasie pionowym link powrotny jest POZYCJĄ PASA — w karcie tylko dla innych wariantów. %>
    <% if (typeof backToPortal !== 'undefined' && backToPortal && navMode.indexOf('rail') !== 0) { %>
      <a href="<%= backToPortal %>" class="inline-flex items-center gap-1.5 text-xs font-medium text-slate-500 hover:text-brand-700 transition mb-2">
        <%- icon('arrowLeft', { size: 14, cls: '' }) %> Wszystkie projekty
      </a>
    <% } %>
    <h1 class="text-2xl font-semibold tracking-tight"><%= project.name %></h1>
    <% if (project.description) { %>
      <p class="text-sm text-slate-500 mt-1 whitespace-pre-line"><%= project.description %></p>
    <% } %>

    <% if (sent) { %>
      <div class="mt-5 flex items-center gap-2 rounded-xl bg-green-50 border border-green-200 text-green-800 text-sm px-4 py-3">
        <%- icon('check', { size: 18, cls: 'text-green-600' }) %> Dziękujemy! Pliki zostały przesłane.
      </div>
    <% } %>

    <div class="mt-8 <%= sideNav ? 'md:flex md:gap-8 md:items-start' : '' %>">
      <% if (inCard) { %><%- include('_portal_nav', { sections: sections, navMode: navMode, part: 'side' }) %><% } %>
      <div class="min-w-0 flex-1">
        <% if (inCard) { %><%- include('_portal_nav', { sections: sections, navMode: navMode, part: 'tabs' }) %><% } %>

        <!-- Pliki od nas -->
        <div <%- secAttr('pliki', true) %>>
          <div class="flex items-center justify-between mb-3">
            <h2 class="text-sm font-semibold text-slate-700 flex items-center gap-2"><%- icon('download', { size: 16 }) %> Pliki od nas</h2>
            <% const totalFromUs = fromUs.reduce((n, t) => n + t.files.length, 0); %>
            <% if (totalFromUs > 0) { %>
              <a href="/p/<%= project.clientToken %>/zip" data-turbo="false" class="text-sm text-brand-700 hover:underline">Pobierz wszystko (ZIP)</a>
            <% } %>
          </div>

          <% if (totalFromUs === 0) { %>
            <p class="text-sm text-slate-400">Brak udostępnionych plików.</p>
          <% } else { %>
            <div class="space-y-4">
              <% fromUs.forEach(function(t){ %>
                <div class="rounded-xl border border-slate-200 overflow-hidden">
                  <div class="px-4 py-2 bg-slate-50 text-xs text-slate-500 flex items-center justify-between gap-2">
                    <span><%= t.title || 'Pliki' %> · <%= fmt.date(t.createdAt) %></span>
                    <% if (t.proofing && t.approvalStatus) { %>
                      <span class="px-1.5 py-0.5 rounded-full font-medium <%= t.approvalStatus === 'approved' ? 'bg-green-50 text-green-700' : 'bg-amber-50 text-amber-700' %>"><%= t.approvalStatus === 'approved' ? 'Zatwierdzone ✓' : 'Poprawki' %></span>
                    <% } %>
                  </div>
                  <div class="divide-y divide-slate-100">
                    <% t.files.forEach(function(f){ %>
                      <%- include('_file_row', { f: f, downloadHref: '/p/' + project.clientToken + '/file/' + f.id, previewHref: '/p/' + project.clientToken + '/preview/' + f.id }) %>
                    <% }); %>
                  </div>
                  <% if (t.proofing) { %>
                    <div class="px-3 pb-3">
                      <%- include('_proofing', { t: t, action: '/p/' + project.clientToken + '/decision/' + t.id }) %>
                    </div>
                  <% } %>
                </div>
              <% }); %>
            </div>
          <% } %>
        </div>

        <!-- Prześlij pliki: lista braków + upload + wcześniej przesłane -->
        <div <%- secAttr('wyslij') %>>
          <% if (fileRequests.length) { %>
            <div class="<%= navOn ? 'mb-8' : 'mt-8 pt-6 border-t border-slate-100' %>">
              <h2 class="text-sm font-semibold text-slate-700 flex items-center gap-2 mb-3"><%- icon('check', { size: 16 }) %> Potrzebujemy od Ciebie</h2>
              <div id="fr-checklist"><%- include('_file_requests', { fileRequests: fileRequests, openRequests: openRequests }) %></div>
            </div>
          <% } %>

          <!-- Upload od klienta -->
          <div class="<%= navOn ? '' : 'mt-8 pt-6 border-t border-slate-100' %>" x-data="uploader()">
            <h2 class="text-sm font-semibold text-slate-700 flex items-center gap-2 mb-3"><%- icon('upload', { size: 16 }) %> Prześlij nam pliki</h2>
            <%# Toast po uploadzie (Etap 2 — wypełniany streamem, bez reloadu). %>
            <div id="upload-msg"></div>
            <form @submit.prevent="submit" data-turbo="false" class="space-y-4">
              <%# #fr-select: po uploadzie odhaczona pozycja znika z selecta — stream podmienia zawartość. %>
              <div id="fr-select"><%- include('_fr_select', { openRequests: openRequests }) %></div>
              <div @dragover.prevent="dragging = true" @dragleave.prevent="dragging = false" @drop.prevent="onDrop($event)"
                   :class="dragging ? 'border-brand-500 bg-brand-50' : 'border-slate-400'"
                   class="rounded-2xl border-2 border-dashed p-6 text-center transition cursor-pointer" @click="$refs.input.click()">
                <input x-ref="input" type="file" multiple class="hidden" @change="addFiles($event.target.files)" />
                <input x-ref="dirInput" type="file" webkitdirectory multiple class="hidden" @change="addFiles($event.target.files)" />
                <div class="flex justify-center mb-1"><%- icon('cloudUpload', { size: 28 }) %></div>
                <p class="text-sm font-medium text-slate-600">Przeciągnij pliki lub folder tutaj</p>
                <p class="text-xs text-slate-400">lub kliknij, aby wybrać &middot;
                  <button type="button" @click.stop="$refs.dirInput.click()" class="font-medium text-brand-700 hover:text-brand-800 underline underline-offset-2">wybierz folder</button>
                </p>
              </div>

              <template x-if="files.length">
                <div class="rounded-xl border border-slate-200 divide-y divide-slate-100 text-sm">
                  <template x-for="(f, i) in files" :key="i">
                    <div class="flex items-center gap-3 px-3 py-2">
                      <template x-if="f.preview"><img :src="f.preview" alt="" class="w-9 h-9 rounded-lg object-cover border border-slate-200 shrink-0" /></template>
                      <template x-if="!f.preview"><span class="w-9 h-9 rounded-lg bg-slate-50 border border-slate-100 flex items-center justify-center shrink-0"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg></span></template>
                      <div class="min-w-0 flex-1">
                        <div class="truncate text-slate-700" x-text="f.name"></div>
                        <div class="mt-1 h-1.5 bg-slate-100 rounded-full overflow-hidden" x-show="uploading">
                          <div class="h-full bg-brand-600 transition-all duration-200" :style="'width:' + Math.max(f.progress, 2) + '%'"></div>
                        </div>
                      </div>
                      <div class="flex items-center gap-2 shrink-0">
                        <span class="text-xs text-slate-400" x-show="!uploading" x-text="human(f.size)"></span>
                        <span class="text-xs text-slate-500 tabular-nums" x-show="uploading" x-text="f.progress + '%'"></span>
                        <button type="button" @click="remove(i)" x-show="!uploading" class="text-slate-400 hover:text-red-600" aria-label="Usuń"><%- icon('x', { size: 16, cls: '' }) %></button>
                      </div>
                    </div>
                  </template>
                </div>
              </template>

              <button type="submit" :disabled="uploading || !files.length"
                      class="evoke-btn w-full rounded-xl bg-brand-600 hover:bg-brand-700 disabled:opacity-40 disabled:cursor-not-allowed text-white font-medium py-3 transition">
                <span x-show="!uploading">Prześlij pliki</span>
                <span x-show="uploading" x-text="finalizing ? 'Finalizowanie…' : ('Wysyłanie… ' + progress + '%')"></span>
              </button>
            </form>

            <!-- Twoje wcześniej przesłane pliki (stabilny kontener #uploaded-files — podmiana streamem po uploadzie) -->
            <div id="uploaded-files"><%- include('_uploaded_files', { fromClient: fromClient, token: project.clientToken }) %></div>
          </div>
        </div>
      </div>
    </div>
    </div>
  </div>
</div>

<script>
function uploader() {
  return makeUploader({
    chunkUrl: function () { return window.location.pathname.replace(/\/$/, '') + '/chunk'; },
    finalize: async function (uploadId) {
      const path = window.location.pathname.replace(/\/$/, '');
      const body = new URLSearchParams({ uploadId: uploadId });
      // GOTCHA XHR: pola formularza trzeba dokleić ręcznie (jak projectId/clientVisible w new.ejs).
      const fr = document.querySelector('select[name=fileRequestId]');
      if (fr && fr.value) body.append('fileRequestId', fr.value);
      // Etap 2: prosimy o Turbo Stream → serwer zwraca fragment, podmieniamy listę plików/checklistę
      // BEZ przeładowania (Turbo.renderStreamMessage). Stan uploadera resetuje makeUploader po sukcesie.
      const res = await fetch(path + '/upload', { method: 'POST', body: body, headers: { 'Accept': 'text/vnd.turbo-stream.html' } });
      if (!res.ok) throw new Error('Błąd wysyłania (' + res.status + ').');
      window.Turbo.renderStreamMessage(await res.text());
    },
  });
}
</script>
