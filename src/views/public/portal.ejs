<div class="w-full max-w-2xl">
  <div class="evoke-card p-5 sm:p-8">
    <%- include('_hero_in_card') %>
    <h1 class="text-2xl font-semibold tracking-tight"><%= project.name %></h1>
    <% if (project.description) { %>
      <p class="text-sm text-slate-500 mt-1 whitespace-pre-line"><%= project.description %></p>
    <% } %>

    <% if (sent) { %>
      <div class="mt-5 flex items-center gap-2 rounded-xl bg-green-50 border border-green-200 text-green-800 text-sm px-4 py-3">
        <%- icon('check', { size: 18, cls: 'text-green-600' }) %> Dziękujemy! Pliki zostały przesłane.
      </div>
    <% } %>

    <!-- Pliki od nas -->
    <div class="mt-8">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-sm font-semibold text-slate-700 flex items-center gap-2"><%- icon('download', { size: 16 }) %> Pliki od nas</h2>
        <% const totalFromUs = fromUs.reduce((n, t) => n + t.files.length, 0); %>
        <% if (totalFromUs > 0) { %>
          <a href="/p/<%= project.clientToken %>/zip" class="text-sm text-brand-700 hover:underline">Pobierz wszystko (ZIP)</a>
        <% } %>
      </div>

      <% if (totalFromUs === 0) { %>
        <p class="text-sm text-slate-400">Brak udostępnionych plików.</p>
      <% } else { %>
        <div class="space-y-4">
          <% fromUs.forEach(function(t){ %>
            <div class="rounded-xl border border-slate-200 overflow-hidden">
              <div class="px-4 py-2 bg-slate-50 text-xs text-slate-500"><%= t.title || 'Pliki' %> · <%= fmt.date(t.createdAt) %></div>
              <div class="divide-y divide-slate-100">
                <% t.files.forEach(function(f){ %>
                  <%- include('_file_row', { f: f, downloadHref: '/p/' + project.clientToken + '/file/' + f.id, previewHref: '/p/' + project.clientToken + '/preview/' + f.id }) %>
                <% }); %>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>

    <!-- Upload od klienta -->
    <div class="mt-8 pt-6 border-t border-slate-100" x-data="uploader()">
      <h2 class="text-sm font-semibold text-slate-700 flex items-center gap-2 mb-3"><%- icon('upload', { size: 16 }) %> Prześlij nam pliki</h2>
      <form @submit.prevent="submit" class="space-y-4">
        <div @dragover.prevent="dragging = true" @dragleave.prevent="dragging = false" @drop.prevent="onDrop($event)"
             :class="dragging ? 'border-brand-500 bg-brand-50' : 'border-slate-300'"
             class="rounded-2xl border-2 border-dashed p-6 text-center transition cursor-pointer" @click="$refs.input.click()">
          <input x-ref="input" type="file" multiple class="hidden" @change="addFiles($event.target.files)" />
          <div class="flex justify-center mb-1"><%- icon('cloudUpload', { size: 28 }) %></div>
          <p class="text-sm font-medium text-slate-600">Przeciągnij pliki tutaj</p>
          <p class="text-xs text-slate-400">lub kliknij, aby wybrać</p>
        </div>

        <template x-if="files.length">
          <div class="rounded-xl border border-slate-200 divide-y divide-slate-100 text-sm">
            <template x-for="(f, i) in files" :key="i">
              <div class="flex items-center gap-3 px-3 py-2">
                <template x-if="f.preview"><img :src="f.preview" alt="" class="w-9 h-9 rounded-lg object-cover border border-slate-200 shrink-0" /></template>
                <template x-if="!f.preview"><span class="w-9 h-9 rounded-lg bg-slate-50 border border-slate-100 flex items-center justify-center shrink-0"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg></span></template>
                <div class="min-w-0 flex-1">
                  <div class="truncate text-slate-700" x-text="f.name"></div>
                  <div class="mt-1 h-1.5 bg-slate-100 rounded-full overflow-hidden" x-show="uploading">
                    <div class="h-full bg-brand-600 transition-all duration-200" :style="'width:' + Math.max(f.progress, 2) + '%'"></div>
                  </div>
                </div>
                <div class="flex items-center gap-2 shrink-0">
                  <span class="text-xs text-slate-400" x-show="!uploading" x-text="human(f.size)"></span>
                  <span class="text-xs text-slate-500 tabular-nums" x-show="uploading" x-text="f.progress + '%'"></span>
                  <button type="button" @click="remove(i)" x-show="!uploading" class="text-slate-400 hover:text-red-600" aria-label="Usuń"><%- icon('x', { size: 16, cls: '' }) %></button>
                </div>
              </div>
            </template>
          </div>
        </template>

        <button type="submit" :disabled="uploading || !files.length"
                class="evoke-btn w-full rounded-xl bg-brand-600 hover:bg-brand-700 disabled:opacity-40 disabled:cursor-not-allowed text-white font-medium py-3 transition">
          <span x-show="!uploading">Prześlij pliki</span>
          <span x-show="uploading" x-text="finalizing ? 'Finalizowanie…' : ('Wysyłanie… ' + progress + '%')"></span>
        </button>
      </form>

      <!-- Twoje wcześniej przesłane pliki -->
      <% const totalFromClient = fromClient.reduce((n, t) => n + t.files.length, 0); %>
      <% if (totalFromClient > 0) { %>
        <div class="mt-6">
          <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-2">Twoje przesłane pliki</h3>
          <div class="rounded-xl border border-slate-200 divide-y divide-slate-100 overflow-hidden">
            <% fromClient.forEach(function(t){ t.files.forEach(function(f){ %>
              <%- include('_file_row', { f: f, downloadHref: '/p/' + project.clientToken + '/file/' + f.id, previewHref: '/p/' + project.clientToken + '/preview/' + f.id }) %>
            <% }); }); %>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</div>

<script>
function uploader() {
  return makeUploader({
    chunkUrl: function () { return window.location.pathname.replace(/\/$/, '') + '/chunk'; },
    finalize: async function (uploadId) {
      const path = window.location.pathname.replace(/\/$/, '');
      const res = await fetch(path + '/upload', { method: 'POST', body: new URLSearchParams({ uploadId: uploadId }) });
      if (!res.ok) throw new Error('Błąd wysyłania (' + res.status + ').');
      window.location = res.url || (window.location.pathname + '?sent=1');
    },
  });
}
</script>
