<div class="text-center max-w-md">
  <div class="text-6xl font-bold text-slate-300 mb-2">500</div>
  <h1 class="text-xl font-semibold mb-2">Coś poszło nie tak</h1>
  <p class="text-sm text-slate-500 mb-4">Wystąpił błąd serwera. Spróbuj ponownie za chwilę.</p>
  <% if (typeof message !== 'undefined' && message) { %>
    <pre class="text-left text-xs bg-slate-100 rounded-lg p-3 overflow-auto mb-6"><%= message %></pre>
  <% } %>
  <a href="/admin" class="inline-block rounded-lg bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium px-4 py-2 transition">
    Wróć do panelu
  </a>
</div>
