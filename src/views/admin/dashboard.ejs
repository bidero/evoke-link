<%
  // Definicje kafelków statystyk (klucz → dane); reszta widżetów ma własne partiale w _widgets/.
  function fmtBytes(b){ if(!b) return '0 B'; const u=['B','KB','MB','GB','TB']; const i=Math.floor(Math.log(b)/Math.log(1024)); return (b/Math.pow(1024,i)).toFixed(1)+' '+u[i]; }
  const TILES = {
    'stat-transfers':   { label: 'Aktywne transfery', value: stats.transfers, hint: 'w toku', href: '/admin/transfers?status=active' },
    'stat-projects':    { label: 'Aktywne projekty', value: stats.projects, hint: 'otwarte', href: '/admin/projects?status=active' },
    'stat-uploads':     { label: 'Oczekujące uploady', value: stats.pendingUploads, hint: 'od klientów', href: '/admin/transfers?status=active&direction=incoming' },
    'stat-outstanding': { label: 'Do rozliczenia', value: fmt.money(stats.outstanding), hint: 'nierozliczone', href: '/admin/clients' },
    'stat-overdue':     { label: 'Przeterminowane', value: fmt.money(stats.overdue), hint: 'po terminie', href: '/admin/clients', valueCls: stats.overdue > 0 ? 'text-red-600' : '' },
    'stat-storage':     { label: 'Wykorzystane miejsce', value: fmtBytes(stats.storageBytes), hint: 'na dysku' },
  };
  // Siatka: mobile 2 kolumny (kafelki ½, treść pełna), lg 12 kolumn — szerokość z w.span (3=¼, 4=⅓, 6=½, 8=⅔, 12=1/1).
  // Literalne klasy (skanuje je Tailwind): lg:col-span-3 lg:col-span-4 lg:col-span-6 lg:col-span-8 lg:col-span-12
  const SPAN_CLS = { 3: 'lg:col-span-3', 4: 'lg:col-span-4', 6: 'lg:col-span-6', 8: 'lg:col-span-8', 12: 'lg:col-span-12' };
  function spanCls(w){
    const mobile = w.key.indexOf('stat-') === 0 ? 'col-span-1' : 'col-span-2';
    return mobile + ' ' + (SPAN_CLS[w.span] || 'lg:col-span-4');
  }
%>

<div x-data="dashEdit(<%= JSON.stringify(hiddenMap) %>, <%= JSON.stringify(spansMap) %>)" @dash-edit.window="start()">
  <!-- bez items-start: widżety rozciągają się do najwyższego w rzędzie (wyrównane dolne krawędzie) -->
  <div id="dashGrid" class="grid grid-cols-2 lg:grid-cols-12 gap-5">
    <% widgets.forEach(function(w){ %>
      <div class="relative <%= spanCls(w) %>" data-key="<%= w.key %>"
           <% if (w.hidden) { %>x-show="edit" x-cloak<% } %>
           :class="edit && hidden['<%= w.key %>'] ? 'opacity-40' : ''">
        <!-- nakładka trybu edycji: szerokość + oko, kursor przenoszenia -->
        <div x-show="edit" x-cloak class="absolute inset-0 z-10 rounded-2xl cursor-grab" title="Przeciągnij, aby przenieść">
          <div class="absolute top-2 right-2 flex gap-1.5">
            <button type="button" @click.stop="cycleSpan('<%= w.key %>')"
                    class="h-8 min-w-[32px] px-1.5 inline-flex items-center justify-center rounded-full bg-white border border-slate-200 shadow-sm text-xs font-semibold text-slate-500 hover:text-brand-700 hover:border-brand-200 transition"
                    title="Zmień szerokość" x-text="spanLabel('<%= w.key %>')"></button>
            <button type="button" @click.stop="toggle('<%= w.key %>')"
                    class="w-8 h-8 inline-flex items-center justify-center rounded-full bg-white border border-slate-200 shadow-sm text-slate-500 hover:text-brand-700 hover:border-brand-200 transition"
                    :title="hidden['<%= w.key %>'] ? 'Pokaż widżet' : 'Ukryj widżet'">
              <span x-show="!hidden['<%= w.key %>']"><%- icon('eye', { size: 15, cls: '' }) %></span>
              <span x-show="hidden['<%= w.key %>']" x-cloak><%- icon('eyeOff', { size: 15, cls: '' }) %></span>
            </button>
          </div>
        </div>
        <% if (w.hidden) { %>
          <!-- placeholder ukrytego widżetu (dane nie są pobierane) -->
          <div class="h-full min-h-[90px] rounded-2xl border border-dashed border-slate-300 bg-white/60 p-5 flex flex-col items-center justify-center text-center">
            <div class="text-sm text-slate-500 inline-flex items-center gap-1.5 justify-center"><%- icon(w.icon, { size: 14, cls: 'text-slate-300' }) %><%= w.label %></div>
            <div class="text-xs text-slate-400 mt-1">ukryty — dane po włączeniu i zapisaniu</div>
          </div>
        <% } else if (TILES[w.key]) { %>
          <%- include('_widgets/_stat', { tile: TILES[w.key], wicon: w.icon }) %>
        <% } else { %>
          <%- include('_widgets/' + w.key, { wicon: w.icon }) %>
        <% } %>
      </div>
    <% }); %>
  </div>

  <!-- pływający pasek trybu edycji (nie przesuwa treści) -->
  <div x-show="edit" x-cloak
       class="fixed bottom-4 left-1/2 -translate-x-1/2 z-40 flex items-center gap-3 rounded-2xl bg-white border border-slate-200 shadow-lg px-4 py-2.5">
    <p class="hidden sm:block text-xs text-slate-400 max-w-[280px]">Przeciągnij widżety; przycisk ¼–1/1 zmienia szerokość, oko ukrywa.</p>
    <button type="button" @click="save()" class="rounded-lg bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium px-4 py-2 transition">Zapisz układ</button>
    <button type="button" @click="cancel()" class="rounded-lg border border-slate-300 text-slate-600 hover:bg-slate-50 text-sm font-medium px-4 py-2 transition">Anuluj</button>
  </div>
</div>

<script src="/js/sortable.min.js"></script>
<script>
  function dashEdit(hiddenMap, spansMap) {
    var SPAN_ORDER = [3, 4, 6, 8, 12];
    var SPAN_CLS = { 3: 'lg:col-span-3', 4: 'lg:col-span-4', 6: 'lg:col-span-6', 8: 'lg:col-span-8', 12: 'lg:col-span-12' };
    var SPAN_LABEL = { 3: '¼', 4: '⅓', 6: '½', 8: '⅔', 12: '1/1' };
    return {
      edit: false,
      hidden: hiddenMap,
      spans: spansMap,
      sortable: null,
      start() {
        this.edit = true;
        if (!this.sortable && window.Sortable) {
          this.sortable = Sortable.create(document.getElementById('dashGrid'), { animation: 150, ghostClass: 'opacity-30' });
        }
      },
      toggle(key) { this.hidden[key] = !this.hidden[key]; },
      spanLabel(key) { return SPAN_LABEL[this.spans[key]] || '⅓'; },
      cycleSpan(key) {
        const next = SPAN_ORDER[(SPAN_ORDER.indexOf(this.spans[key]) + 1) % SPAN_ORDER.length];
        this.spans[key] = next;
        const el = document.querySelector('#dashGrid [data-key="' + key + '"]');
        if (el) {
          Object.values(SPAN_CLS).forEach((c) => el.classList.remove(c));
          el.classList.add(SPAN_CLS[next]);
        }
      },
      cancel() { location.reload(); },
      async save() {
        const grid = document.getElementById('dashGrid');
        const layout = Array.prototype.map.call(grid.children, (el) => ({
          key: el.dataset.key,
          hidden: !!this.hidden[el.dataset.key],
          span: this.spans[el.dataset.key],
        }));
        await fetch('/admin/dashboard/layout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams({ layout: JSON.stringify(layout) }),
        });
        location.reload();
      },
    };
  }
</script>
