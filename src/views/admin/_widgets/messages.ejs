<div class="h-full flex flex-col bg-white rounded-2xl border border-slate-200 overflow-hidden">
  <div class="px-5 py-3 border-b border-slate-100 flex items-center justify-between">
    <h2 class="text-sm font-medium text-slate-700 inline-flex items-center gap-1.5"><%- icon(typeof wicon !== 'undefined' ? wicon : 'mail', { size: 15, cls: 'text-slate-400' }) %> Nieprzeczytane wiadomości</h2>
    <a href="/admin/messages" class="text-xs text-brand-700 hover:underline">Skrzynka →</a>
  </div>
  <% if (!msgThreads.length) { %>
    <div class="flex-1 flex items-center justify-center px-5 py-8 text-center text-sm text-slate-400">Wszystko przeczytane.</div>
  <% } else { %>
    <ul class="divide-y divide-slate-100">
      <% msgThreads.forEach(function(t){ %>
        <% const last = t.messages[t.messages.length - 1]; %>
        <% const who = (t.client && t.client.name) || (last && last.senderName) || 'Klient'; %>
        <% const ctx = t.project ? t.project.name : (t.transfer ? (t.transfer.title || t.transfer.token) : null); %>
        <li class="px-5 py-3">
          <a href="/admin/messages" class="block group">
            <span class="flex items-center justify-between gap-2">
              <span class="text-sm font-medium text-slate-700 truncate group-hover:text-brand-700"><%= who %></span>
              <span class="inline-flex items-center justify-center min-w-[20px] h-5 px-1.5 rounded-full bg-brand-600 text-white text-xs font-semibold shrink-0"><%= t.unread %></span>
            </span>
            <span class="block text-xs text-slate-500 truncate mt-0.5"><%= last ? String(last.body || '').slice(0, 90) : '' %></span>
            <% if (ctx) { %><span class="block text-xs text-slate-400 mt-0.5 truncate"><%= ctx %></span><% } %>
          </a>
        </li>
      <% }); %>
    </ul>
  <% } %>
</div>
