<form method="POST" action="<%= action %>" class="space-y-2">
  <input type="hidden" name="month" value="<%= curMonth %>" />
  <input name="title" type="text" required maxlength="200" value="<%= r.title || '' %>" placeholder="Co zrobić?"
         class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
  <div class="grid grid-cols-2 gap-2">
    <input name="dueAt" type="datetime-local" required value="<%= dtLocal(r.dueAt) %>"
           class="rounded-lg border border-slate-300 px-2 py-1.5 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
    <select name="priority" class="rounded-lg border border-slate-300 px-2 py-1.5 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none">
      <% ['low','normal','high'].forEach(function(p){ %><option value="<%= p %>" <%= r.priority === p ? 'selected' : '' %>><%= PRIO_LABEL[p] %></option><% }); %>
    </select>
  </div>
  <div class="grid grid-cols-2 gap-2">
    <select name="clientId" class="rounded-lg border border-slate-300 px-2 py-1.5 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none">
      <option value="">— klient —</option>
      <% clients.forEach(function(c){ %><option value="<%= c.id %>" <%= r.clientId == c.id ? 'selected' : '' %>><%= c.name %></option><% }); %>
    </select>
    <select name="projectId" class="rounded-lg border border-slate-300 px-2 py-1.5 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none">
      <option value="">— projekt —</option>
      <% projects.forEach(function(p){ %><option value="<%= p.id %>" <%= r.projectId == p.id ? 'selected' : '' %>><%= p.name %></option><% }); %>
    </select>
  </div>
  <textarea name="note" rows="2" placeholder="Notatka (opcjonalnie)"
            class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none"><%= r.note || '' %></textarea>
  <button type="submit" class="w-full rounded-lg bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium py-2 transition"><%= submitLabel %></button>
</form>
