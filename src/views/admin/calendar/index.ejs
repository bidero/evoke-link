<%
  const pad = (n) => String(n).padStart(2, '0');
  const dtLocal = (d) => { const x = new Date(d); return `${x.getFullYear()}-${pad(x.getMonth() + 1)}-${pad(x.getDate())}T${pad(x.getHours())}:${pad(x.getMinutes())}`; };
  const PRIO_LABEL = { low: 'Niski', normal: 'Normalny', high: 'Wysoki' };
  function chipCls(e) {
    if (e.done) return 'bg-slate-100 text-slate-400 line-through';
    if (e.kind === 'reminder') return e.priority === 'high' ? 'bg-red-50 text-red-700' : (e.priority === 'low' ? 'bg-slate-100 text-slate-600' : 'bg-brand-50 text-brand-700');
    if (e.kind === 'charge') return 'bg-amber-50 text-amber-700';
    if (e.kind === 'transfer') return 'bg-sky-50 text-sky-700';
    return 'bg-slate-100 text-slate-600';
  }
%>
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6" x-data="{ addOpen: false }">

  <!-- KALENDARZ -->
  <div class="lg:col-span-2">
    <div class="flex items-center justify-between mb-3 gap-2">
      <div class="flex items-center gap-2">
        <a href="/admin/calendar?month=<%= prevMonth %>" class="w-8 h-8 inline-flex items-center justify-center rounded-lg border border-slate-300 text-slate-500 hover:bg-slate-50" aria-label="Poprzedni"><%- icon('arrowLeft', { size: 16, cls: '' }) %></a>
        <h2 class="text-base font-semibold text-slate-800 capitalize min-w-[140px] text-center"><%= monthLabel %></h2>
        <a href="/admin/calendar?month=<%= nextMonth %>" class="w-8 h-8 inline-flex items-center justify-center rounded-lg border border-slate-300 text-slate-500 hover:bg-slate-50" aria-label="Następny"><%- icon('arrowRight', { size: 16, cls: '' }) %></a>
        <% if (curMonth !== thisMonth) { %><a href="/admin/calendar" class="ml-1 text-sm text-brand-700 hover:underline">Dziś</a><% } %>
      </div>
      <button type="button" @click="addOpen = !addOpen" class="rounded-lg bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium px-3 py-1.5 transition inline-flex items-center gap-1.5"><%- icon('plus', { size: 15, cls: '' }) %> Przypomnienie</button>
    </div>

    <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
      <div class="grid grid-cols-7 text-center text-[11px] font-medium text-slate-400 border-b border-slate-100">
        <% ['Pn','Wt','Śr','Cz','Pt','So','Nd'].forEach(function(d){ %><div class="py-2"><%= d %></div><% }); %>
      </div>
      <% weeks.forEach(function(week){ %>
        <div class="grid grid-cols-7">
          <% week.forEach(function(day){ %>
            <div class="min-h-[92px] border-r border-b border-slate-100 last:border-r-0 p-1.5 <%= day.inMonth ? '' : 'bg-slate-50/60' %>">
              <div class="flex justify-end">
                <span class="text-[11px] inline-flex items-center justify-center w-5 h-5 rounded-full <%= day.isToday ? 'bg-brand-600 text-white font-semibold' : (day.inMonth ? 'text-slate-500' : 'text-slate-300') %>"><%= day.day %></span>
              </div>
              <div class="mt-0.5 space-y-0.5">
                <% day.events.slice(0, 3).forEach(function(e){ %>
                  <% if (e.href) { %><a href="<%= e.href %>" title="<%= e.title %>"<% } else { %><span title="<%= e.title %>"<% } %> class="block truncate rounded px-1 py-0.5 text-[10px] leading-tight <%= chipCls(e) %>"><%= e.title %><% if (e.href) { %></a><% } else { %></span><% } %>
                <% }); %>
                <% if (day.events.length > 3) { %><div class="text-[10px] text-slate-400 pl-1">+<%= day.events.length - 3 %> więcej</div><% } %>
              </div>
            </div>
          <% }); %>
        </div>
      <% }); %>
    </div>

    <div class="flex items-center gap-4 mt-2 text-[11px] text-slate-400">
      <span class="inline-flex items-center gap-1"><span class="w-2.5 h-2.5 rounded-full bg-brand-400"></span> Przypomnienie</span>
      <span class="inline-flex items-center gap-1"><span class="w-2.5 h-2.5 rounded-full bg-amber-400"></span> Płatność</span>
      <span class="inline-flex items-center gap-1"><span class="w-2.5 h-2.5 rounded-full bg-sky-400"></span> Wygasa transfer</span>
    </div>
  </div>

  <!-- PANEL: dodawanie + nadchodzące -->
  <div class="space-y-4">
    <!-- formularz nowego przypomnienia -->
    <div x-show="addOpen" x-cloak x-transition class="bg-white rounded-2xl border border-brand-200 p-4">
      <div class="text-sm font-semibold text-slate-700 mb-2">Nowe przypomnienie</div>
      <%- include('_reminder_form', { action: '/admin/calendar/reminders', r: { title: '', note: '', dueAt: dtLocal(new Date()), priority: 'normal', clientId: null, projectId: null }, clients, projects, curMonth, PRIO_LABEL, dtLocal, submitLabel: 'Dodaj' }) %>
    </div>

    <!-- nadchodzące / zaległe -->
    <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
      <div class="px-4 py-3 border-b border-slate-100 text-sm font-medium text-slate-700">Nadchodzące i zaległe</div>
      <% if (!upcoming.length) { %>
        <div class="px-4 py-8 text-center text-sm text-slate-400">Nic na horyzoncie 🎉</div>
      <% } else { %>
        <div class="divide-y divide-slate-100">
          <% upcoming.forEach(function(e){ %>
            <div class="px-4 py-2.5" <% if (e.kind === 'reminder') { %>x-data="{ edit: false }"<% } %>>
              <div class="flex items-start gap-2">
                <% if (e.kind === 'reminder') { %>
                  <form method="POST" action="/admin/calendar/reminders/<%= e.id %>/toggle" class="shrink-0 mt-0.5"><input type="hidden" name="month" value="<%= curMonth %>" />
                    <button type="submit" class="w-4 h-4 rounded border <%= e.done ? 'bg-brand-600 border-brand-600' : 'border-slate-300 hover:border-brand-500' %> inline-flex items-center justify-center" title="Zrobione">
                      <% if (e.done) { %><%- icon('check', { size: 12, cls: 'text-white' }) %><% } %>
                    </button>
                  </form>
                <% } else { %>
                  <span class="shrink-0 mt-1 w-2 h-2 rounded-full <%= e.kind === 'charge' ? 'bg-amber-400' : 'bg-sky-400' %>"></span>
                <% } %>
                <div class="min-w-0 flex-1">
                  <div class="text-sm text-slate-800 <%= e.done ? 'line-through text-slate-400' : '' %> break-words"><%= e.title %></div>
                  <div class="text-xs mt-0.5 flex items-center gap-1.5 flex-wrap">
                    <span class="<%= e.overdue ? 'text-red-600 font-medium' : 'text-slate-400' %>"><%= fmt.date(e.date) %><%= e.overdue ? ' · zaległe' : '' %></span>
                    <% if (e.sub) { %><span class="text-slate-400">· <%= e.sub %></span><% } %>
                    <% if (e.kind === 'reminder' && e.priority === 'high') { %><span class="px-1.5 rounded-full bg-red-50 text-red-700">pilne</span><% } %>
                  </div>
                </div>
                <div class="flex items-center gap-1 shrink-0">
                  <% if (e.kind === 'reminder') { %>
                    <button type="button" @click="edit = !edit" class="text-slate-400 hover:text-brand-700 p-1" title="Edytuj"><%- icon('pencil', { size: 14, cls: '' }) %></button>
                    <form method="POST" action="/admin/calendar/reminders/<%= e.id %>/delete" onsubmit="return confirm('Usunąć przypomnienie?');"><input type="hidden" name="month" value="<%= curMonth %>" /><button type="submit" class="text-slate-400 hover:text-red-600 p-1" title="Usuń"><%- icon('trash', { size: 14, cls: '' }) %></button></form>
                  <% } else if (e.href) { %>
                    <a href="<%= e.href %>" class="text-slate-400 hover:text-brand-700 p-1" title="Otwórz"><%- icon('externalLink', { size: 14, cls: '' }) %></a>
                  <% } %>
                </div>
              </div>
              <% if (e.kind === 'reminder') { %>
                <div x-show="edit" x-cloak class="mt-2 pt-2 border-t border-slate-100">
                  <%- include('_reminder_form', { action: '/admin/calendar/reminders/' + e.id, r: e, clients, projects, curMonth, PRIO_LABEL, dtLocal, submitLabel: 'Zapisz' }) %>
                </div>
              <% } %>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>

    <!-- zrobione (przywracanie / usuwanie) -->
    <% if (doneReminders.length) { %>
    <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden" x-data="{ open: false }">
      <button type="button" @click="open = !open" class="w-full flex items-center justify-between px-4 py-3 text-left hover:bg-slate-50 transition">
        <span class="text-sm font-medium text-slate-700">Zrobione (<%= doneReminders.length %>)</span>
        <span :class="open && 'rotate-180'" class="transition-transform inline-flex text-slate-400"><%- icon('chevronDown', { size: 16, cls: '' }) %></span>
      </button>
      <div x-show="open" x-cloak class="divide-y divide-slate-100 border-t border-slate-100">
        <% doneReminders.forEach(function(e){ %>
          <div class="px-4 py-2 flex items-center gap-2">
            <div class="min-w-0 flex-1">
              <div class="text-sm text-slate-400 line-through truncate"><%= e.title %></div>
              <div class="text-xs text-slate-400"><%= fmt.date(e.date) %><% if (e.sub) { %> · <%= e.sub %><% } %></div>
            </div>
            <form method="POST" action="/admin/calendar/reminders/<%= e.id %>/toggle"><input type="hidden" name="month" value="<%= curMonth %>" /><button type="submit" class="text-xs text-brand-700 hover:underline px-1 shrink-0" title="Oznacz jako niezrobione">Przywróć</button></form>
            <form method="POST" action="/admin/calendar/reminders/<%= e.id %>/delete" onsubmit="return confirm('Usunąć przypomnienie?');"><input type="hidden" name="month" value="<%= curMonth %>" /><button type="submit" class="text-slate-400 hover:text-red-600 p-1 shrink-0" title="Usuń"><%- icon('trash', { size: 14, cls: '' }) %></button></form>
          </div>
        <% }); %>
      </div>
    </div>
    <% } %>
  </div>
</div>
