      </div>
      <div>
        <label class="block text-xs font-medium text-slate-600 mb-1">Wstęp w mailu z panelem klienta/projektu</label>
        <div class="rte">
          <div class="flex flex-wrap gap-1 mb-1">
            <button type="button" data-cmd="bold" title="Pogrubienie" class="text-xs font-bold rounded border border-slate-300 w-7 h-7 hover:bg-slate-50">B</button>
            <button type="button" data-cmd="italic" title="Kursywa" class="text-xs italic rounded border border-slate-300 w-7 h-7 hover:bg-slate-50">I</button>
            <button type="button" data-cmd="insertUnorderedList" title="Lista" class="text-xs rounded border border-slate-300 px-2 h-7 hover:bg-slate-50">• Lista</button>
            <button type="button" data-cmd="createLink" title="Wstaw link" class="text-xs rounded border border-slate-300 px-2 h-7 hover:bg-slate-50">Link</button>
            <button type="button" data-cmd="removeFormat" title="Wyczyść formatowanie" class="text-xs rounded border border-slate-300 px-2 h-7 hover:bg-slate-50">Wyczyść</button>
          </div>
          <div class="rte-ed w-full rounded-lg border border-slate-300 px-3 py-2 text-sm min-h-[64px] focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" contenteditable="true"></div>
          <input type="hidden" name="panelIntro" value="<%= settings.emails.panelIntro %>" />
        </div>
      </div>

      <div class="border-t border-slate-100 pt-4 space-y-3">
        <label class="flex items-center gap-2 text-sm text-slate-700">
          <input type="checkbox" name="clientConfirm" class="rounded border-slate-300" <%= settings.emails.clientConfirm ? 'checked' : '' %> />
          Wyślij klientowi potwierdzenie po przesłaniu plików (gdy podał e-mail)
        </label>
        <input name="clientConfirmSubject" type="text" value="<%= settings.emails.clientConfirmSubject %>" placeholder="Temat potwierdzenia (domyślny)"
               class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
        <div class="rte">
          <div class="flex flex-wrap gap-1 mb-1">
            <button type="button" data-cmd="bold" title="Pogrubienie" class="text-xs font-bold rounded border border-slate-300 w-7 h-7 hover:bg-slate-50">B</button>
            <button type="button" data-cmd="italic" title="Kursywa" class="text-xs italic rounded border border-slate-300 w-7 h-7 hover:bg-slate-50">I</button>
            <button type="button" data-cmd="insertUnorderedList" title="Lista" class="text-xs rounded border border-slate-300 px-2 h-7 hover:bg-slate-50">• Lista</button>
            <button type="button" data-cmd="createLink" title="Wstaw link" class="text-xs rounded border border-slate-300 px-2 h-7 hover:bg-slate-50">Link</button>
            <button type="button" data-cmd="removeFormat" title="Wyczyść formatowanie" class="text-xs rounded border border-slate-300 px-2 h-7 hover:bg-slate-50">Wyczyść</button>
          </div>
          <div class="rte-ed w-full rounded-lg border border-slate-300 px-3 py-2 text-sm min-h-[64px] focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" contenteditable="true"></div>
          <input type="hidden" name="clientConfirmBody" value="<%= settings.emails.clientConfirmBody %>" />
        </div>
