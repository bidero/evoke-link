<%
  const formState = {
    primary: settings.colors.primary,
    adminAccent: settings.colors.adminAccent || '',
    adminText: settings.colors.adminText || '',
    adminSidebar: settings.colors.adminSidebar,
    adminBg: settings.colors.adminBg,
    bgType: settings.background.type,
    bgPreset: settings.background.preset,
    bgColor: settings.background.color,
    gradC1: settings.background.custom.c1,
    gradC2: settings.background.custom.c2,
    gradC3: settings.background.custom.c3,
    gradAngle: settings.background.custom.angle,
    bgOverlay: settings.background.overlay,
    bgImageGradient: settings.background.imageGradient,
    imgGradC1: settings.background.imageGrad.c1,
    imgGradC2: settings.background.imageGrad.c2 || '#000000',
    imgGradC2on: !!settings.background.imageGrad.c2,
    imgGradAngle: settings.background.imageGrad.angle,
    bgGrain: settings.background.grain,
    bgGrainType: settings.background.grainType,
    bgGrainStrength: settings.background.grainStrength,
    imagePath: settings.background.imagePath,
    logoSize: settings.logo.size,
    logoAlign: settings.logo.align,
    layoutStyle: settings.layout.style,
    layoutCard: settings.layout.card,
    cardSide: settings.layout.cardSide,
    layoutFont: settings.layout.font || 'system',
    heroOnBg: settings.layout.heroOnBg,
    hideName: settings.layout.hideName,
    applyToLogin: settings.layout.applyToLogin,
    layoutRadius: settings.layout.radius,
    layoutButton: settings.layout.button,
    appName: settings.appName || 'Evoke LINK',
    heroTitle: (settings.texts && settings.texts.heroTitle) || '',
    heroSubtitle: (settings.texts && settings.texts.heroSubtitle) || '',
    presetCss: Object.fromEntries(Object.entries(presets).map(([k, v]) => [k, v.css])),
  };
%>
<div class="max-w-4xl" x-data="Object.assign(settingsForm(<%= JSON.stringify(formState) %>), { tab: 'branding' })">

  <% if (saved) { %>
    <div class="mb-4 flex items-center gap-2 rounded-lg bg-green-50 border border-green-200 text-green-800 text-sm px-3 py-2">
      <%- icon('check', { size: 16, cls: 'text-green-600' }) %> Zapisano ustawienia.
    </div>
  <% } %>

  <div class="flex flex-wrap gap-1 border-b border-slate-200 mb-6">
    <% [['branding','Branding'],['wyglad','Wygląd stron klienta'],['pdf','Rozliczenia (PDF)'],['email','E-mail'],['advanced','Zaawansowane']].forEach(function(t){ %>
      <button type="button" @click="tab='<%= t[0] %>'" class="px-4 py-2.5 text-sm font-medium border-b-2 -mb-px transition" :class="tab==='<%= t[0] %>' ? 'border-brand-600 text-brand-700' : 'border-transparent text-slate-500 hover:text-slate-700'"><%= t[1] %></button>
    <% }); %>
  </div>

  <% if (typeof themes !== 'undefined' && themes) { %>
  <div x-show="tab==='wyglad'" x-cloak class="bg-white rounded-2xl border border-slate-200 p-6 mb-6">
    <h2 class="text-sm font-semibold text-slate-700">Gotowe motywy</h2>
    <p class="text-xs text-slate-400 mb-3">Jeden klik ustawia kolor, tło, układ i typografię. Logo, treści i dane PDF zostają bez zmian.</p>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
      <% Object.entries(themes).forEach(function(entry){ const key = entry[0], t = entry[1]; %>
        <form method="POST" action="/admin/settings/apply-theme">
          <input type="hidden" name="theme" value="<%= key %>" />
          <button type="submit" class="w-full flex items-center gap-2 rounded-lg border border-slate-300 hover:border-brand-400 hover:bg-brand-50 px-3 py-2 text-sm text-slate-700 transition">
            <span class="w-4 h-4 rounded-full shrink-0 border border-slate-300" style="background: <%= (t.colors && t.colors.primary) || '#6e00a5' %>"></span>
            <span class="truncate text-left"><%= t.label %></span>
          </button>
        </form>
      <% }); %>
    </div>
  </div>
  <% } %>

  <form method="POST" action="/admin/settings" enctype="multipart/form-data" class="space-y-6">

    <!-- Branding -->
    <div x-show="tab==='branding'" x-cloak class="bg-white rounded-2xl border border-slate-200 p-6 space-y-5">
      <h2 class="text-sm font-semibold text-slate-700">Branding</h2>

      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Nazwa aplikacji</label>
        <input name="appName" type="text" value="<%= settings.appName %>"
               class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Logo <span class="text-slate-400 font-normal">(PNG, SVG…)</span></label>
          <% if (settings.logoPath) { %>
            <div class="flex items-center gap-3 mb-2">
              <img src="<%= settings.logoPath %>" alt="logo" class="h-10 rounded bg-slate-50 border border-slate-200 p-1" />
              <label class="inline-flex items-center gap-1.5 text-xs text-slate-500"><input type="checkbox" name="removeLogo" class="rounded border-slate-300" /> usuń</label>
            </div>
          <% } %>
          <input name="logo" type="file" accept="image/*,.svg" class="block w-full text-sm text-slate-500 file:mr-3 file:rounded-lg file:border-0 file:bg-brand-50 file:text-brand-700 file:px-3 file:py-1.5 file:text-sm" />
          <p class="text-xs text-slate-400 mt-1">SVG jest oczyszczany z kodu (bezpieczny upload).</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Logo (tryb ciemny) <span class="text-slate-400 font-normal">(opcjonalne)</span></label>
          <% if (settings.logo.darkPath) { %>
            <div class="flex items-center gap-3 mb-2">
              <img src="<%= settings.logo.darkPath %>" alt="logo ciemne" class="h-10 rounded bg-slate-800 border border-slate-700 p-1" />
              <label class="inline-flex items-center gap-1.5 text-xs text-slate-500"><input type="checkbox" name="removeLogoDark" class="rounded border-slate-300" /> usuń</label>
            </div>
          <% } %>
          <input name="logoDark" type="file" accept="image/*,.svg" class="block w-full text-sm text-slate-500 file:mr-3 file:rounded-lg file:border-0 file:bg-brand-50 file:text-brand-700 file:px-3 file:py-1.5 file:text-sm" />
          <p class="text-xs text-slate-400 mt-1">Używane w trybie ciemnym (puste = zwykłe logo).</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Favicon</label>
          <% if (settings.faviconPath) { %>
            <div class="flex items-center gap-3 mb-2">
              <img src="<%= settings.faviconPath %>" alt="favicon" class="h-6 w-6 rounded bg-slate-50 border border-slate-200" />
              <label class="inline-flex items-center gap-1.5 text-xs text-slate-500"><input type="checkbox" name="removeFavicon" class="rounded border-slate-300" /> usuń</label>
            </div>
          <% } %>
          <input name="favicon" type="file" accept="image/*,.svg" class="block w-full text-sm text-slate-500 file:mr-3 file:rounded-lg file:border-0 file:bg-brand-50 file:text-brand-700 file:px-3 file:py-1.5 file:text-sm" />
        </div>
      </div>

      <!-- Prezentacja logo: rozmiar + pozycja -->
      <div class="border-t border-slate-100 pt-5">
        <h3 class="text-xs font-semibold text-slate-600 mb-3">Wyświetlanie logo (strona klienta / logowanie)</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 items-start">
          <div>
            <label class="block text-xs font-medium text-slate-600 mb-1">Wysokość: <span x-text="logoSize + ' px'"></span></label>
            <input type="range" name="logoSize" min="16" max="120" step="2" x-model="logoSize" class="w-full accent-brand-600" />
          </div>
          <div>
            <label class="block text-xs font-medium text-slate-600 mb-1">Pozycja</label>
            <div class="flex gap-2 text-sm">
              <template x-for="opt in [['left','Lewo'],['center','Środek'],['right','Prawo']]" :key="opt[0]">
                <label class="flex-1 cursor-pointer">
                  <input type="radio" name="logoAlign" :value="opt[0]" x-model="logoAlign" class="peer sr-only" />
                  <span class="block text-center rounded-lg border border-slate-300 px-2 py-1.5 peer-checked:border-brand-500 peer-checked:bg-brand-50 peer-checked:text-brand-700 transition" x-text="opt[1]"></span>
                </label>
              </template>
            </div>
          </div>
        </div>
        <!-- Podgląd logo -->
        <div class="mt-3 rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 flex items-center"
             :class="{ 'justify-start': logoAlign==='left', 'justify-center': logoAlign==='center', 'justify-end': logoAlign==='right' }">
          <% if (settings.logoPath) { %>
            <img src="<%= settings.logoPath %>" alt="logo" :style="'height:' + logoSize + 'px'" class="max-w-[70%] object-contain" />
          <% } else { %>
            <span class="text-xs text-slate-400">Wgraj logo, aby zobaczyć podgląd. (Bez logo pokazujemy nazwę aplikacji.)</span>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Kolor przewodni (strona klienta) -->
    <div x-show="tab==='branding'" x-cloak class="bg-white rounded-2xl border border-slate-200 p-6">
      <h2 class="text-sm font-semibold text-slate-700 mb-3">Kolor przewodni</h2>
      <div class="flex items-center gap-3 flex-wrap">
        <input type="color" name="primary" x-model="primary" class="h-10 w-14 rounded border border-slate-300 cursor-pointer" />
        <input type="text" x-model="primary" maxlength="7" class="w-28 rounded-lg border border-slate-300 px-3 py-2 text-sm font-mono" />
        <span class="inline-flex items-center gap-2 text-sm text-slate-500">
          podgląd:
          <span class="rounded-lg px-3 py-1.5 text-white text-sm font-medium" :style="'background:' + primary">Przycisk</span>
        </span>
      </div>
      <p class="text-xs text-slate-400 mt-2">Steruje akcentem strony klienta i (domyślnie) panelu. Domyślny: #6e00a5.</p>
    </div>

    <!-- Kolory panelu admina -->
    <div x-show="tab==='branding'" x-cloak class="bg-white rounded-2xl border border-slate-200 p-6">
      <h2 class="text-sm font-semibold text-slate-700 mb-1">Kolory panelu admina</h2>
      <p class="text-xs text-slate-400 mb-4">Akcent i czcionka puste = używają wartości domyślnych (akcent → kolor przewodni, czcionka → auto-kontrast z tła).</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div class="space-y-4">
          <div>
            <label class="block text-xs font-medium text-slate-600 mb-1">Akcent (przyciski, aktywne)</label>
            <div class="flex items-center gap-2">
              <input type="color" :value="adminAccent || primary" @input="adminAccent = $event.target.value" class="h-9 w-12 rounded border border-slate-300 cursor-pointer" />
              <input type="text" name="adminAccent" x-model="adminAccent" maxlength="7" placeholder="(jak przewodni)" class="w-32 rounded-lg border border-slate-300 px-2 py-1.5 text-sm font-mono" />
              <button type="button" x-show="adminAccent" @click="adminAccent=''" class="text-xs text-slate-400 hover:text-slate-600 underline">wyczyść</button>
            </div>
          </div>
          <div>
            <label class="block text-xs font-medium text-slate-600 mb-1">Kolor czcionki</label>
            <div class="flex items-center gap-2">
              <input type="color" :value="adminText || textAuto()" @input="adminText = $event.target.value" class="h-9 w-12 rounded border border-slate-300 cursor-pointer" />
              <input type="text" name="adminText" x-model="adminText" maxlength="7" placeholder="(auto-kontrast)" class="w-32 rounded-lg border border-slate-300 px-2 py-1.5 text-sm font-mono" />
              <button type="button" x-show="adminText" @click="adminText=''" class="text-xs text-slate-400 hover:text-slate-600 underline">wyczyść</button>
            </div>
          </div>
          <div>
            <label class="block text-xs font-medium text-slate-600 mb-1">Tło sidebara</label>
            <div class="flex items-center gap-2">
              <input type="color" name="adminSidebar" x-model="adminSidebar" class="h-9 w-12 rounded border border-slate-300 cursor-pointer" />
              <input type="text" x-model="adminSidebar" maxlength="7" class="w-32 rounded-lg border border-slate-300 px-2 py-1.5 text-sm font-mono" />
            </div>
          </div>
          <div>
            <label class="block text-xs font-medium text-slate-600 mb-1">Tło panelu</label>
            <div class="flex items-center gap-2">
              <input type="color" name="adminBg" x-model="adminBg" class="h-9 w-12 rounded border border-slate-300 cursor-pointer" />
              <input type="text" x-model="adminBg" maxlength="7" class="w-32 rounded-lg border border-slate-300 px-2 py-1.5 text-sm font-mono" />
            </div>
          </div>
        </div>

        <!-- Mini-podgląd panelu -->
        <div>
          <span class="block text-xs font-medium text-slate-600 mb-1">Podgląd</span>
          <div class="rounded-xl border border-slate-200 overflow-hidden h-36 flex" :style="'background:' + adminBg + ';color:' + textEff()">
            <div class="w-20 shrink-0 p-2 space-y-1.5 text-[10px]" :style="'background:' + adminSidebar + ';color:' + sidebarText()">
              <div class="font-bold" :style="'color:' + accentEff()">Logo</div>
              <div class="rounded px-1.5 py-1 font-medium" :style="'background:' + accentBg() + ';color:' + accentEff()">Pulpit</div>
              <div class="opacity-70 px-1.5 py-1">Projekty</div>
              <div class="opacity-70 px-1.5 py-1">Transfery</div>
            </div>
            <div class="flex-1 p-2 text-[10px]">
              <div class="font-semibold mb-1.5">Nagłówek treści</div>
              <div class="bg-white/80 rounded h-5 mb-2 border border-slate-200/60"></div>
              <span class="inline-block rounded px-2 py-1 text-white" :style="'background:' + accentEff()">Przycisk</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Tło strony klienta -->
    <div x-show="tab==='wyglad'" x-cloak class="bg-white rounded-2xl border border-slate-200 p-6 space-y-4">
      <h2 class="text-sm font-semibold text-slate-700">Tło strony klienta</h2>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 text-sm">
        <template x-for="opt in [['gradient','Preset'],['custom','Własny'],['image','Obraz'],['solid','Kolor']]" :key="opt[0]">
          <label class="cursor-pointer">
            <input type="radio" name="bgType" :value="opt[0]" x-model="bgType" class="peer sr-only" />
            <span class="block text-center rounded-lg border border-slate-300 px-3 py-2 peer-checked:border-brand-500 peer-checked:bg-brand-50 peer-checked:text-brand-700 transition" x-text="opt[1]"></span>
          </label>
        </template>
      </div>

      <!-- Gradient: wybór presetu -->
      <div x-show="bgType==='gradient'">
        <label class="block text-xs font-medium text-slate-600 mb-1">Preset gradientu</label>
        <select name="bgPreset" x-model="bgPreset" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm">
          <% Object.entries(presets).forEach(function([key, p]){ %>
            <option value="<%= key %>"><%= p.label %></option>
          <% }); %>
        </select>
      </div>

      <!-- Własny gradient: kolory + kąt -->
      <div x-show="bgType==='custom'" class="space-y-3">
        <div class="grid grid-cols-3 gap-3">
          <div>
            <label class="block text-xs font-medium text-slate-600 mb-1">Kolor 1</label>
            <input type="color" name="gradC1" x-model="gradC1" class="h-9 w-full rounded border border-slate-300 cursor-pointer" />
          </div>
          <div>
            <label class="block text-xs font-medium text-slate-600 mb-1">Kolor 2</label>
            <input type="color" name="gradC2" x-model="gradC2" class="h-9 w-full rounded border border-slate-300 cursor-pointer" />
          </div>
          <div>
            <label class="block text-xs font-medium text-slate-600 mb-1 flex items-center justify-between">Kolor 3 <button type="button" x-show="gradC3" @click="gradC3=''" class="text-[10px] text-slate-400 hover:text-slate-600 underline">usuń</button></label>
            <input type="color" name="gradC3" :value="gradC3 || '#ffffff'" @input="gradC3 = $event.target.value" class="h-9 w-full rounded border border-slate-300 cursor-pointer" :class="gradC3 ? '' : 'opacity-40'" />
          </div>
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-1">Kąt: <span x-text="gradAngle + '°'"></span></label>
          <input type="range" name="gradAngle" min="0" max="360" step="5" x-model="gradAngle" class="w-full accent-brand-600" />
        </div>
        <p class="text-xs text-slate-400">Kolor 3 jest opcjonalny (pusty = gradient dwukolorowy).</p>
      </div>

      <!-- Kolor jednolity -->
      <div x-show="bgType==='solid'">
        <label class="block text-xs font-medium text-slate-600 mb-1">Kolor tła</label>
        <div class="flex items-center gap-2">
          <input type="color" name="bgColor" x-model="bgColor" class="h-9 w-12 rounded border border-slate-300 cursor-pointer" />
          <input type="text" x-model="bgColor" maxlength="7" class="w-32 rounded-lg border border-slate-300 px-2 py-1.5 text-sm font-mono" />
        </div>
      </div>

      <!-- Obraz tła -->
      <div x-show="bgType==='image'" class="space-y-3">
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-1">Obrazy tła <span class="text-slate-400 font-normal">(do 5 MB każdy; kilka = rotacja)</span></label>
          <input name="bg" type="file" accept="image/*" multiple @change="onBgFile($event)" class="block w-full text-sm text-slate-500 file:mr-3 file:rounded-lg file:border-0 file:bg-brand-50 file:text-brand-700 file:px-3 file:py-1.5 file:text-sm" />
          <% const bgImgs = (settings.background.images && settings.background.images.length) ? settings.background.images : (settings.background.imagePath ? [settings.background.imagePath] : []); %>
          <% if (bgImgs.length) { %>
            <div class="mt-3">
              <span class="block text-xs text-slate-500 mb-1.5">Obecne obrazy — zaznacz, by usunąć:</span>
              <div class="flex flex-wrap gap-2">
                <% bgImgs.forEach(function(p){ %>
                  <label class="cursor-pointer" title="Zaznacz, by usunąć">
                    <input type="checkbox" name="removeBgImages" value="<%= p %>" class="peer sr-only" />
                    <img src="<%= p %>" alt="" class="w-16 h-16 rounded-lg object-cover border border-slate-200 transition peer-checked:opacity-40 peer-checked:ring-2 peer-checked:ring-red-400" />
                  </label>
                <% }); %>
              </div>
              <% if (bgImgs.length >= 2) { %>
                <label class="inline-flex items-center gap-2 text-sm text-slate-600 mt-3">
                  <input type="checkbox" name="bgRotate" <%= settings.background.rotate ? 'checked' : '' %> class="rounded border-slate-300" /> Rotacja obrazów (slideshow)
                </label>
                <div class="flex items-center gap-2 text-xs text-slate-500 mt-1.5">Zmiana co
                  <input type="number" name="bgRotateSec" value="<%= settings.background.rotateSec || 8 %>" min="3" max="30" class="w-16 rounded-lg border border-slate-300 px-2 py-1 text-sm" /> s
                </div>
              <% } else { %>
                <p class="text-xs text-slate-400 mt-2">Dodaj 2+ obrazy, aby włączyć rotację.</p>
              <% } %>
            </div>
          <% } %>
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-1">Przyciemnienie obrazu: <span x-text="bgOverlay + '%'"></span></label>
          <input type="range" name="bgOverlay" min="0" max="80" step="5" x-model="bgOverlay" class="w-full accent-brand-600" />
        </div>
        <label class="inline-flex items-center gap-2 text-sm text-slate-600">
          <input type="checkbox" name="bgImageGradient" x-model="bgImageGradient" class="rounded border-slate-300" /> Nałóż gradient na obraz
        </label>
        <div x-show="bgImageGradient" class="pl-6 mt-2" x-cloak>
          <input type="hidden" name="imgGradC2" :value="imgGradC2on ? imgGradC2 : ''" />
          <div class="flex items-center gap-3 flex-wrap text-xs text-slate-600">
            <span class="inline-flex items-center gap-1.5">Kolor 1 <input type="color" name="imgGradC1" x-model="imgGradC1" class="h-7 w-9 rounded border border-slate-300 cursor-pointer" /></span>
            <label class="inline-flex items-center gap-1.5"><input type="checkbox" x-model="imgGradC2on" class="rounded border-slate-300" /> Kolor 2</label>
            <span class="inline-flex items-center gap-1.5" x-show="imgGradC2on"><input type="color" x-model="imgGradC2" class="h-7 w-9 rounded border border-slate-300 cursor-pointer" /></span>
            <span class="inline-flex items-center gap-2">Kąt <input type="range" name="imgGradAngle" x-model="imgGradAngle" min="0" max="360" step="5" class="w-28 accent-brand-600" /><span class="tabular-nums w-9 text-right" x-text="imgGradAngle + '°'"></span></span>
          </div>
        </div>
      </div>

      <div class="space-y-2">
        <label class="inline-flex items-center gap-2 text-sm text-slate-600">
          <input type="checkbox" name="bgGrain" x-model="bgGrain" class="rounded border-slate-300" /> Nakładka ziarna (szum)
        </label>
        <div x-show="bgGrain" class="pl-6 space-y-2" x-cloak>
          <div class="flex items-center gap-2 text-xs">
            <span class="text-slate-600">Rodzaj:</span>
            <template x-for="t in [['fine','Drobny film'],['soft','Miękki'],['coarse','Gruby']]" :key="t[0]">
              <label class="cursor-pointer">
                <input type="radio" name="bgGrainType" :value="t[0]" x-model="bgGrainType" class="peer sr-only" />
                <span class="block rounded-lg border border-slate-300 px-2 py-1 peer-checked:border-brand-500 peer-checked:bg-brand-50 peer-checked:text-brand-700 transition" x-text="t[1]"></span>
              </label>
            </template>
          </div>
          <label class="block text-xs font-medium text-slate-600 mb-1">Moc szumu: <span x-text="bgGrainStrength + '%'"></span></label>
          <input type="range" name="bgGrainStrength" min="0" max="100" step="5" x-model="bgGrainStrength" class="w-full max-w-xs accent-brand-600" />
        </div>
      </div>

      <label class="inline-flex items-center gap-2 text-sm text-slate-600">
        <input type="checkbox" name="bgScroll" <%= settings.background.scroll ? 'checked' : '' %> class="rounded border-slate-300" /> Tło przesuwa się z przewijaniem <span class="text-slate-400">(domyślnie przyklejone)</span>
      </label>

      <!-- Podgląd całej strony klienta (na żywo) -->
      <div>
        <span class="block text-xs font-medium text-slate-600 mb-1">Podgląd strony klienta (na żywo)</span>
        <div class="relative rounded-xl border border-slate-200 overflow-hidden h-80" :style="clientBgStyle() + ';font-family:' + fontFamily()">
          <div x-show="bgType==='image' && (previewImg || imagePath)" class="absolute inset-0" :style="'background:#0f172a center/cover no-repeat; background-image:url(' + (previewImg || imagePath) + ')'"></div>
          <div x-show="bgType==='image' && bgImageGradient" class="absolute inset-0" :style="'background:' + imageGradientCss()"></div>
          <div x-show="bgType==='image' && bgOverlay>0" class="absolute inset-0" :style="'background:rgba(15,23,42,' + (bgOverlay/100) + ')'"></div>
          <div x-show="bgGrain" class="absolute inset-0 pointer-events-none" :style="grainPreviewStyle()"></div>

          <!-- Panel na tle: biały panel pełnej wysokości z boku -->
          <div x-show="layoutStyle==='panel'" x-cloak class="absolute inset-0 flex" :class="cardSide==='right' ? 'justify-end' : (cardSide==='center' ? 'justify-center' : '')">
            <div class="h-full bg-white p-4 flex flex-col justify-center" style="width:46%">
              <div class="flex items-center gap-1.5 mb-3" x-show="!hideName"><span class="w-4 h-4 rounded bg-brand-600 text-white text-[8px] flex items-center justify-center font-bold">E</span><span class="text-[11px] font-semibold text-slate-700" x-text="appName"></span></div>
              <div class="text-[13px] font-semibold text-slate-800" :style="'font-family:'+fontHeading()">Pliki dla Ciebie</div>
              <div class="mt-1.5 h-1.5 rounded bg-slate-200" style="width:66%"></div>
              <div class="mt-1 h-1.5 rounded bg-slate-200" style="width:50%"></div>
              <div class="mt-2 inline-block text-[10px] text-white px-3 py-1 self-start" :style="'background:'+primary+';border-radius:'+btnRadius()">Pobierz</div>
            </div>
          </div>

          <!-- Pasek boczny: kolorowy brand strip + karta na tle -->
          <div x-show="layoutStyle==='sidebar'" x-cloak class="absolute inset-0 flex" :class="cardSide==='right' ? 'flex-row-reverse' : ''">
            <div class="bg-brand-600 text-white p-3 flex flex-col justify-between" style="width:34%">
              <div class="flex items-center gap-1.5" x-show="!hideName"><span class="w-4 h-4 rounded bg-white/20 flex items-center justify-center text-[8px] font-bold">E</span><span class="text-[10px] font-semibold" x-text="appName"></span></div>
              <div x-show="heroOnBg && heroTitle" class="text-[12px] font-bold" :style="'font-family:'+fontHeading()" x-text="heroTitle"></div>
              <div class="text-[8px] text-white/70" x-text="appName"></div>
            </div>
            <div class="flex-1 flex items-center justify-center p-4">
              <div class="p-3" :style="cardStyle()+';width:82%'">
                <div class="text-[13px] font-semibold text-slate-800" :style="'font-family:'+fontHeading()">Pliki dla Ciebie</div>
                <div class="mt-1.5 h-1.5 rounded bg-slate-200" style="width:66%"></div>
                <div class="mt-2 inline-block text-[10px] text-white px-3 py-1" :style="'background:'+primary+';border-radius:'+btnRadius()">Pobierz</div>
              </div>
            </div>
          </div>

          <!-- Róg: karta zadokowana w dolnym rogu -->
          <div x-show="layoutStyle==='corner'" x-cloak class="absolute inset-0 flex flex-col p-4">
            <div class="flex items-center gap-1.5" x-show="!hideName"><span class="w-4 h-4 rounded bg-brand-600 text-white text-[8px] flex items-center justify-center font-bold">E</span><span class="text-[11px] font-semibold" :class="bgIsDark()?'text-white':'text-slate-700'" x-text="appName"></span></div>
            <div class="flex-1 flex items-end" :class="cardSide==='right'?'justify-end':(cardSide==='center'?'justify-center':'')">
              <div class="p-3" :style="cardStyle()+';width:56%;max-width:240px'">
                <div class="text-[13px] font-semibold text-slate-800" :style="'font-family:'+fontHeading()">Pliki dla Ciebie</div>
                <div class="mt-1.5 h-1.5 rounded bg-slate-200" style="width:66%"></div>
                <div class="mt-2 inline-block text-[10px] text-white px-3 py-1" :style="'background:'+primary+';border-radius:'+btnRadius()">Pobierz</div>
              </div>
            </div>
          </div>

          <!-- Banner: brandowy pasek u góry + karta pod spodem -->
          <div x-show="layoutStyle==='banner'" x-cloak class="absolute inset-0 flex flex-col">
            <div class="bg-brand-600 text-white px-4 py-3">
              <div class="flex items-center gap-1.5" x-show="!hideName"><span class="w-4 h-4 rounded bg-white/20 flex items-center justify-center text-[8px] font-bold">E</span><span class="text-[10px] font-semibold" x-text="appName"></span></div>
              <div x-show="heroOnBg && heroTitle" class="mt-1 text-sm font-bold" :style="'font-family:'+fontHeading()" x-text="heroTitle"></div>
            </div>
            <div class="flex-1 flex items-center justify-center p-4">
              <div class="p-3" :style="cardStyle()+';width:60%;max-width:300px'">
                <div class="text-[13px] font-semibold text-slate-800" :style="'font-family:'+fontHeading()">Pliki dla Ciebie</div>
                <div class="mt-1.5 h-1.5 rounded bg-slate-200" style="width:66%"></div>
                <div class="mt-2 inline-block text-[10px] text-white px-3 py-1" :style="'background:'+primary+';border-radius:'+btnRadius()">Pobierz</div>
              </div>
            </div>
          </div>

          <!-- Split: hero z jednej strony, karta z drugiej -->
          <div x-show="layoutStyle==='split'" x-cloak class="absolute inset-0 grid grid-cols-2 items-center gap-3 p-4">
            <div :class="cardSide==='left' ? 'order-2 text-right' : 'order-1'">
              <div class="text-base font-bold" :class="bgIsDark()?'text-white':'text-slate-800'" :style="'font-family:'+fontHeading()" x-text="heroTitle || appName"></div>
              <div x-show="heroSubtitle" class="text-[11px]" :class="bgIsDark()?'text-white/80':'text-slate-500'" x-text="heroSubtitle"></div>
            </div>
            <div class="flex" :class="cardSide==='left' ? 'order-1 justify-start' : 'order-2 justify-end'">
              <div class="p-3" :style="cardStyle()+';width:100%;max-width:210px'">
                <div class="text-[13px] font-semibold text-slate-800" :style="'font-family:'+fontHeading()">Pliki dla Ciebie</div>
                <div class="mt-1.5 h-1.5 rounded bg-slate-200" style="width:66%"></div>
                <div class="mt-2 inline-block text-[10px] text-white px-3 py-1" :style="'background:'+primary+';border-radius:'+btnRadius()">Pobierz</div>
              </div>
            </div>
          </div>

          <!-- Pozostałe: klasyczny / landing / pełne tło / hero w karcie / minimal -->
          <div x-show="['classic','centered','showcase','hero-card','minimal'].includes(layoutStyle)" x-cloak class="absolute inset-0 flex flex-col p-4">
            <div class="flex items-center gap-1.5 mb-3" :class="logoAlign==='center'?'justify-center':(logoAlign==='right'?'justify-end':'')" x-show="!hideName && layoutStyle!=='minimal' && layoutStyle!=='hero-card'">
              <span class="w-4 h-4 rounded bg-brand-600 text-white text-[8px] flex items-center justify-center font-bold">E</span>
              <span class="text-[11px] font-semibold" :class="bgIsDark()?'text-white':'text-slate-700'" x-text="appName"></span>
            </div>
            <div x-show="heroOnBg && heroTitle && layoutStyle!=='hero-card'" class="mb-3" :class="layoutStyle==='centered'?'text-center':''">
              <div class="font-bold" :class="(layoutStyle==='centered'?'text-lg ':'text-base ') + (bgIsDark()?'text-white':'text-slate-800')" :style="'font-family:'+fontHeading()" x-text="heroTitle"></div>
              <div class="text-[11px]" :class="bgIsDark()?'text-white/80':'text-slate-500'" x-text="heroSubtitle"></div>
            </div>
            <div class="flex-1 flex items-center" :class="layoutStyle==='showcase' ? cardAlign() : 'justify-center'">
              <div class="p-3" :style="cardStyle()+';width:60%;max-width:300px'">
                <div x-show="layoutStyle==='hero-card' && heroTitle" class="text-sm font-bold text-slate-800 mb-1" :style="'font-family:'+fontHeading()" x-text="heroTitle"></div>
                <div class="text-[13px] font-semibold text-slate-800" :style="'font-family:'+fontHeading()">Pliki dla Ciebie</div>
                <div class="mt-1.5 h-1.5 rounded bg-slate-200" style="width:66%"></div>
                <div class="mt-1 h-1.5 rounded bg-slate-200" style="width:50%"></div>
                <div class="mt-2 inline-block text-[10px] text-white px-3 py-1" :style="'background:'+primary+';border-radius:'+btnRadius()">Pobierz</div>
              </div>
            </div>
          </div>
        </div>
        <p class="text-[11px] text-slate-400 mt-1">Poglądowo, na żywo: układ, karta, kolor, tło, font i hero. Dokładny wygląd — na stronach klienta po zapisaniu.</p>
      </div>
    </div>

    <!-- Układ stron klienta (kontrolki natywne — niezależne od Alpine) -->
    <div x-show="tab==='wyglad'" x-cloak class="bg-white rounded-2xl border border-slate-200 p-6 space-y-5">
      <h2 class="text-sm font-semibold text-slate-700">Układ stron klienta</h2>
      <p class="text-xs text-slate-400">Efekt zobaczysz po zapisaniu, na stronach klienta (oraz logowania, jeśli włączone).</p>

      <div>
        <label class="block text-xs font-medium text-slate-600 mb-1">Wariant</label>
        <div class="grid grid-cols-3 gap-2 text-sm">
          <% [['classic','Klasyczny'],['centered','Landing'],['split','Split'],['showcase','Pełne tło'],['panel','Panel na tle'],['sidebar','Pasek boczny'],['corner','Róg'],['hero-card','Hero w karcie'],['minimal','Minimal'],['banner','Banner']].forEach(function(o){ %>
            <label class="cursor-pointer">
              <input type="radio" name="layoutStyle" value="<%= o[0] %>" <%= settings.layout.style === o[0] ? 'checked' : '' %> @change="layoutStyle=$event.target.value" class="peer sr-only" />
              <span class="block text-center rounded-lg border border-slate-300 px-2 py-2 peer-checked:border-brand-500 peer-checked:bg-brand-50 peer-checked:text-brand-700 transition"><%= o[1] %></span>
            </label>
          <% }); %>
        </div>
      </div>

      <div>
        <label class="block text-xs font-medium text-slate-600 mb-1">Strona karty <span class="text-slate-400 font-normal">(dla „Split" i „Pełne tło")</span></label>
        <div class="grid grid-cols-3 gap-2 text-sm">
          <% [['left','Z lewej'],['center','Wyśrodkowana'],['right','Z prawej']].forEach(function(o){ %>
            <label class="cursor-pointer">
              <input type="radio" name="cardSide" value="<%= o[0] %>" <%= settings.layout.cardSide === o[0] ? 'checked' : '' %> @change="cardSide=$event.target.value" class="peer sr-only" />
              <span class="block text-center rounded-lg border border-slate-300 px-2 py-1.5 peer-checked:border-brand-500 peer-checked:bg-brand-50 peer-checked:text-brand-700 transition"><%= o[1] %></span>
            </label>
          <% }); %>
        </div>
      </div>

      <div>
        <label class="block text-xs font-medium text-slate-600 mb-1">Styl karty</label>
        <div class="grid grid-cols-3 gap-2 text-sm">
          <% [['solid','Pełna biel'],['glass','Mrożone szkło'],['elevated','Uniesiona']].forEach(function(o){ %>
            <label class="cursor-pointer">
              <input type="radio" name="layoutCard" value="<%= o[0] %>" <%= settings.layout.card === o[0] ? 'checked' : '' %> @change="layoutCard=$event.target.value" class="peer sr-only" />
              <span class="block text-center rounded-lg border border-slate-300 px-2 py-2 peer-checked:border-brand-500 peer-checked:bg-brand-50 peer-checked:text-brand-700 transition"><%= o[1] %></span>
            </label>
          <% }); %>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-1">Zaokrąglenie rogów: <span id="radiusOut"><%= settings.layout.radius %></span> px</label>
          <input type="range" name="layoutRadius" min="0" max="40" step="2" value="<%= settings.layout.radius %>"
                 @input="layoutRadius=$event.target.value"
                 oninput="var e=document.getElementById('radiusOut'); if(e){e.textContent=this.value;}" class="w-full accent-brand-600" />
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-1">Kształt przycisku</label>
          <div class="grid grid-cols-2 gap-2 text-sm">
            <% [['rounded','Zaokrąglony'],['pill','Pigułka']].forEach(function(o){ %>
              <label class="cursor-pointer">
                <input type="radio" name="layoutButton" value="<%= o[0] %>" <%= settings.layout.button === o[0] ? 'checked' : '' %> @change="layoutButton=$event.target.value" class="peer sr-only" />
                <span class="block text-center rounded-lg border border-slate-300 px-2 py-1.5 peer-checked:border-brand-500 peer-checked:bg-brand-50 peer-checked:text-brand-700 transition"><%= o[1] %></span>
              </label>
            <% }); %>
          </div>
        </div>
      </div>

      <div>
        <label class="block text-xs font-medium text-slate-600 mb-1">Typografia <span class="text-slate-400 font-normal">(czcionki systemowe — bez pobierania)</span></label>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 text-sm">
          <% [['system','Domyślny'],['serif','Serif nagłówki'],['editorial','Elegancki'],['mono','Techniczny']].forEach(function(o){ %>
            <label class="cursor-pointer">
              <input type="radio" name="layoutFont" value="<%= o[0] %>" <%= (settings.layout.font || 'system') === o[0] ? 'checked' : '' %> @change="layoutFont=$event.target.value" class="peer sr-only" />
              <span class="block text-center rounded-lg border border-slate-300 px-2 py-2 peer-checked:border-brand-500 peer-checked:bg-brand-50 peer-checked:text-brand-700 transition"><%= o[1] %></span>
            </label>
          <% }); %>
        </div>
      </div>

      <div class="space-y-2 pt-1">
        <label class="flex items-center gap-2 text-sm text-slate-600">
          <input type="checkbox" name="heroOnBg" <%= settings.layout.heroOnBg ? 'checked' : '' %> @change="heroOnBg=$event.target.checked" class="rounded border-slate-300" />
          Pokaż nagłówek (hero) na stronach klienta
        </label>
        <label class="flex items-center gap-2 text-sm text-slate-600">
          <input type="checkbox" name="hideName" <%= settings.layout.hideName ? 'checked' : '' %> @change="hideName=$event.target.checked" class="rounded border-slate-300" />
          Ukryj nazwę aplikacji (gdy nagłówek wyłączony / brak logo)
        </label>
        <label class="flex items-center gap-2 text-sm text-slate-600">
          <input type="checkbox" name="applyToLogin" <%= settings.layout.applyToLogin ? 'checked' : '' %> class="rounded border-slate-300" />
          Zastosuj styl karty/przycisku także na stronie logowania
        </label>
        <label class="flex items-center gap-2 text-sm text-slate-600">
          <input type="checkbox" name="stickyHeader" <%= settings.layout.stickyHeader ? 'checked' : '' %> class="rounded border-slate-300" />
          Przyklejony nagłówek (logo zostaje na górze przy przewijaniu)
        </label>
      </div>
    </div>

    <!-- Wydruk PDF rozliczenia (kontrolki natywne) -->
    <div x-show="tab==='pdf'" x-cloak class="bg-white rounded-2xl border border-slate-200 p-6 space-y-5">
      <h2 class="text-sm font-semibold text-slate-700">Wydruk PDF rozliczenia</h2>
      <p class="text-xs text-slate-400">Wygląd dokumentu pobieranego ze strony klienta („Pobierz rozliczenie PDF").</p>
      <div>
        <label class="block text-xs font-medium text-slate-600 mb-1">Typ dokumentu</label>
        <div class="grid grid-cols-2 gap-2 text-sm max-w-xs">
          <% [['rozliczenie','Rozliczenie'],['proforma','Proforma']].forEach(function(o){ %>
            <label class="cursor-pointer">
              <input type="radio" name="pdfDocType" value="<%= o[0] %>" <%= settings.pdf.docType === o[0] ? 'checked' : '' %> class="peer sr-only" />
              <span class="block text-center rounded-lg border border-slate-300 px-2 py-2 peer-checked:border-brand-500 peer-checked:bg-brand-50 peer-checked:text-brand-700 transition"><%= o[1] %></span>
            </label>
          <% }); %>
        </div>
        <p class="text-xs text-slate-400 mt-1">Słowo na dokumencie (tytuł).</p>
      </div>

      <div>
        <label class="block text-xs font-medium text-slate-600 mb-1">Układ</label>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 text-sm">
          <% [['standard','Standard'],['band','Pasek brandowy'],['accent','Akcent boczny'],['proforma','Klasyczny (ramki)']].forEach(function(o){ %>
            <label class="cursor-pointer">
              <input type="radio" name="pdfTemplate" value="<%= o[0] %>" <%= settings.pdf.template === o[0] ? 'checked' : '' %> class="peer sr-only" />
              <span class="block text-center rounded-lg border border-slate-300 px-2 py-2 peer-checked:border-brand-500 peer-checked:bg-brand-50 peer-checked:text-brand-700 transition"><%= o[1] %></span>
            </label>
          <% }); %>
        </div>
      </div>
      <div class="max-w-xs">
        <label class="block text-xs font-medium text-slate-600 mb-1">Wysokość logo na PDF: <span id="pdfLogoOut"><%= settings.pdf.logoHeight %></span> px</label>
        <input type="range" name="pdfLogoHeight" min="20" max="90" step="2" value="<%= settings.pdf.logoHeight %>"
               oninput="var e=document.getElementById('pdfLogoOut'); if(e){e.textContent=this.value;}" class="w-full accent-brand-600" />
      </div>
      <div class="border-t border-slate-100 pt-4">
        <h3 class="text-xs font-semibold text-slate-600 mb-1">Dane sprzedawcy (na dokument)</h3>
        <p class="text-xs text-slate-400 mb-3">Pojawią się jako „Sprzedawca" na wydruku (wszystkie układy). Puste = sama nazwa aplikacji. Nr konta pokazujemy w bloku „Do zapłaty", gdy coś zostało nierozliczone.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <input name="sellerName" type="text" value="<%= settings.pdf.seller.name %>" placeholder="Nazwa / firma (sprzedawca)" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
          <input name="sellerNip" type="text" value="<%= settings.pdf.seller.nip %>" placeholder="NIP" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
          <input name="sellerAddress" type="text" value="<%= settings.pdf.seller.address %>" placeholder="Adres (ul., kod, miasto)" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
          <input name="sellerBank" type="text" value="<%= settings.pdf.seller.bank %>" placeholder="Nr konta (IBAN)" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
        </div>
      </div>
    </div>

    <!-- Tryb ciemny -->
    <div x-show="tab==='wyglad'" x-cloak class="bg-white rounded-2xl border border-slate-200 p-6">
      <h2 class="text-sm font-semibold text-slate-700 mb-1">Tryb ciemny (dark mode)</h2>
      <p class="text-xs text-slate-400 mb-4">Kolory używane po włączeniu trybu ciemnego (ikona księżyca/słońca w nagłówku). Dotyczy panelu i stron klienta.</p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-1">Tło</label>
          <input type="color" name="darkBg" value="<%= settings.colors.darkBg %>" class="h-9 w-full rounded border border-slate-300 cursor-pointer" />
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-1">Karty / panele</label>
          <input type="color" name="darkSurface" value="<%= settings.colors.darkSurface %>" class="h-9 w-full rounded border border-slate-300 cursor-pointer" />
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-1">Tekst</label>
          <input type="color" name="darkText" value="<%= settings.colors.darkText %>" class="h-9 w-full rounded border border-slate-300 cursor-pointer" />
        </div>
      </div>
    </div>

    <!-- Treści -->
    <div x-show="tab==='wyglad'" x-cloak class="bg-white rounded-2xl border border-slate-200 p-6 space-y-5">
      <h2 class="text-sm font-semibold text-slate-700">Treści strony klienta</h2>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Nagłówek (hero)</label>
        <input name="heroTitle" type="text" value="<%= settings.texts.heroTitle %>" placeholder="np. Bezpieczna wymiana plików"
               class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Podtytuł</label>
        <input name="heroSubtitle" type="text" value="<%= settings.texts.heroSubtitle %>"
               class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Stopka</label>
        <input name="footer" type="text" value="<%= settings.texts.footer %>"
               class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
      </div>
    </div>

    <!-- E-mail: wygląd i treści -->
    <div id="emailCard" x-show="tab==='email'" x-cloak class="bg-white rounded-2xl border border-slate-200 p-6 space-y-5">
      <h2 class="text-sm font-semibold text-slate-700">E-mail — wygląd i treści</h2>
      <div class="rounded-lg bg-slate-50 border border-slate-200 px-3 py-2">
        <p class="text-xs text-slate-500 mb-1.5">Placeholdery — kliknij pole tekstowe poniżej, a potem placeholder, aby go wstawić:</p>
        <div class="flex flex-wrap gap-1.5">
          <% placeholders.forEach(function(ph){ %><button type="button" data-ph="<%= ph %>" class="ph-chip text-xs bg-white border border-slate-200 text-slate-600 rounded px-1.5 py-0.5 font-mono hover:bg-brand-50 hover:text-brand-700 hover:border-brand-300 transition cursor-pointer"><%= ph %></button><% }); %>
        </div>
