          <label class="block text-xs font-medium text-slate-600 mb-1">Temat: link do plików</label>
          <input name="linkSubject" type="text" value="<%= settings.emails.linkSubject %>" placeholder="domyślny"
                 class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
        </div>
        <div>
