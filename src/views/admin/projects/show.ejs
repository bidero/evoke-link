<a href="/admin/projects" class="text-sm text-slate-500 hover:text-slate-700">← Wszystkie projekty</a>

<!-- Nagłówek projektu -->
<div class="mt-4 flex items-start justify-between gap-4">
  <div>
    <div class="flex items-center gap-2">
      <h1 class="text-2xl font-semibold tracking-tight"><%= project.name %></h1>
      <% if (project.status === 'archived') { %><span class="text-xs px-2 py-0.5 rounded-full bg-slate-100 text-slate-500">archiwum</span><% } %>
    </div>
    <% if (project.client) { %>
      <p class="text-slate-500 mt-0.5">Klient: <a href="/admin/clients/<%= project.client.id %>" class="text-brand-700 hover:underline"><%= project.client.name %></a></p>
    <% } else if (project.clientName) { %>
      <p class="text-slate-500 mt-0.5"><%= project.clientName %></p>
    <% } %>
    <% if (project.description) { %><p class="text-sm text-slate-500 mt-2 max-w-2xl whitespace-pre-line"><%= project.description %></p><% } %>
  </div>
  <a href="/admin/projects/<%= project.id %>/edit" class="shrink-0 rounded-lg border border-slate-300 text-slate-700 hover:bg-slate-50 text-sm font-medium px-4 py-2 transition">Edytuj</a>
</div>

<!-- Akcje -->
<div class="mt-4 flex flex-wrap items-center gap-2">
  <a href="/admin/transfers/new?project=<%= project.id %>" class="rounded-lg bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium px-4 py-2 transition">+ Wyślij pliki klientowi</a>
  <a href="/admin/transfers/new-upload?project=<%= project.id %>" class="rounded-lg border border-slate-300 text-slate-700 hover:bg-slate-50 text-sm font-medium px-4 py-2 transition">+ Link uploadu</a>
  <% if (project.client) { %><a href="/admin/messages?client=<%= project.client.id %>&scope=p:<%= project.id %>" class="inline-flex items-center gap-1.5 rounded-lg border border-slate-300 text-slate-700 hover:bg-brand-50 hover:text-brand-700 hover:border-brand-200 text-sm font-medium px-4 py-2 transition"><%- icon('mail', { size: 15, cls: '' }) %> Napisz do klienta</a><% } %>
  <form method="POST" action="/admin/projects/<%= project.id %>/archive" class="ml-auto">
    <% const _arch = project.status === 'archived'; %>
    <button type="submit" class="inline-flex items-center gap-1.5 rounded-lg border border-slate-300 text-slate-600 hover:bg-slate-50 text-sm font-medium px-4 py-2 transition"><%- icon(_arch ? 'arrowLeft' : 'archive', { size: 15, cls: '' }) %> <%= _arch ? 'Przywróć z archiwum' : 'Archiwizuj' %></button>
  </form>
</div>

<!-- Panel klienta -->
<div class="mt-6 bg-white rounded-2xl border border-slate-200 p-5"
     x-data="{ copied: false, send() { var to = '<%= clientEmail %>'; if (!to) { to = (prompt('Wyślij link panelu na adres e-mail:') || '').trim(); if (!to) return; } this.$refs.sendEmail.value = to; this.$refs.sendForm.submit(); } }">
  <div class="flex items-center justify-between mb-2">
    <h2 class="text-sm font-medium text-slate-700">Panel klienta</h2>
    <span class="text-xs <%= project.clientPasswordHash ? 'text-slate-500' : 'text-amber-600' %>">
      <%= project.clientPasswordHash ? 'chroniony hasłem' : 'bez hasła' %>
    </span>
  </div>
  <p class="text-xs text-slate-400 mb-3">Klient widzi tu tylko transfery oznaczone „widoczny dla klienta" i może wgrywać pliki. Hasło ustawisz w „Edytuj".</p>
  <% if (panel === 'sent') { %>
    <div class="mb-3 flex items-center gap-2 rounded-lg bg-green-50 border border-green-200 text-green-800 text-sm px-3 py-2"><%- icon('check', { size: 16, cls: 'text-green-600' }) %> Wysłano link panelu.</div>
  <% } else if (panel === 'invalid') { %>
    <div class="mb-3 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm px-3 py-2">Podaj poprawny adres e-mail.</div>
  <% } else if (panel === 'error') { %>
    <div class="mb-3 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm px-3 py-2">Nie udało się wysłać. Sprawdź SMTP.</div>
  <% } %>
  <div class="flex flex-col sm:flex-row gap-2">
    <input readonly value="<%= portalUrl %>" x-ref="purl" class="flex-1 min-w-0 rounded-lg border border-slate-300 bg-slate-50 px-3 py-2 text-sm text-slate-700" />
    <div class="flex gap-2">
      <button type="button" @click="navigator.clipboard.writeText($refs.purl.value); copied = true; setTimeout(()=>copied=false,1500)"
              class="flex-1 sm:flex-none rounded-lg bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium px-4 py-2 transition whitespace-nowrap">
        <span x-show="!copied">Kopiuj</span><span x-show="copied">Skopiowano ✓</span>
      </button>
      <button type="button" @click="send()" class="flex-1 sm:flex-none rounded-lg border border-slate-300 text-slate-700 hover:bg-slate-50 text-sm font-medium px-4 py-2 transition whitespace-nowrap">Wyślij</button>
      <a href="<%= portalUrl %>" target="_blank" class="flex-1 sm:flex-none text-center rounded-lg border border-slate-300 text-slate-600 hover:bg-slate-50 text-sm font-medium px-4 py-2 transition whitespace-nowrap">Otwórz</a>
    </div>
  </div>
  <div class="mt-3" x-data="{ qr: false }">
    <button type="button" @click="qr = !qr" class="text-xs font-medium text-brand-700 hover:text-brand-800" x-text="qr ? 'Ukryj kod QR' : 'Pokaż kod QR (skan telefonem)'"></button>
    <div x-show="qr" x-cloak class="mt-2"><span class="inline-block rounded-xl border border-slate-200 bg-white p-2 shadow-sm"><%- qrSvg(portalUrl, { cell: 3 }) %></span></div>
  </div>
  <% if (!mailReady) { %><p class="text-xs text-amber-600 mt-2">SMTP niewłączony — mail trafi do logów serwera zamiast do klienta.</p><% } %>
  <form method="POST" action="/admin/projects/<%= project.id %>/send-panel" x-ref="sendForm" class="hidden"><input type="hidden" name="email" x-ref="sendEmail" /></form>
</div>

<!-- Lista braków: materiały, o które prosimy klienta (widoczna w jego panelu) -->
<div class="mt-6 bg-white rounded-2xl border border-slate-200 p-5" x-data="{ add: false }">
  <div class="flex items-center justify-between mb-2">
    <h2 class="text-sm font-medium text-slate-700">Lista braków <span class="text-slate-400 font-normal">(od klienta)</span></h2>
    <button type="button" @click="add = !add" class="text-sm text-brand-700 hover:underline">+ Dodaj punkt</button>
  </div>
  <p class="text-xs text-slate-400 mb-3">Klient widzi tę checklistę w swoim panelu i przy wysyłce plików może wskazać, czego dotyczą — punkt odhacza się sam. Możesz też odhaczać ręcznie.</p>

  <form x-show="add" x-cloak method="POST" action="/admin/projects/<%= project.id %>/requests" class="mb-3 flex flex-col sm:flex-row gap-2">
    <input name="label" type="text" required maxlength="200" placeholder="np. Logo w wektorze (AI/SVG)" class="flex-1 rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
    <input name="note" type="text" maxlength="500" placeholder="Podpowiedź (opcjonalnie)" class="flex-1 rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
    <button type="submit" class="rounded-lg bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium px-4 py-2 transition shrink-0">Dodaj</button>
  </form>

  <% const _reqs = project.fileRequests || []; %>
  <% if (!_reqs.length) { %>
    <p class="text-sm text-slate-400">Brak punktów — dodaj pierwszy, np. „Logo", „Teksty na stronę", „5 zdjęć produktów".</p>
  <% } else { %>
    <div class="divide-y divide-slate-100">
      <% _reqs.forEach(function(r){ %>
        <div class="flex items-center gap-2.5 py-2 text-sm group">
          <form method="POST" action="/admin/projects/<%= project.id %>/requests/<%= r.id %>/toggle" class="shrink-0">
            <button type="submit" class="w-4 h-4 rounded border <%= r.done ? 'bg-green-600 border-green-600' : 'border-slate-300 hover:border-brand-500' %> inline-flex items-center justify-center" title="<%= r.done ? 'Cofnij' : 'Odhacz' %>">
              <% if (r.done) { %><%- icon('check', { size: 12, cls: 'text-white' }) %><% } %>
            </button>
          </form>
          <div class="min-w-0 flex-1">
            <span class="<%= r.done ? 'text-slate-400 line-through' : 'text-slate-700' %>"><%= r.label %></span>
            <% if (r.note) { %><span class="text-xs text-slate-400 ml-2"><%= r.note %></span><% } %>
            <% if (r.done && r.transferId) { %><a href="/admin/transfers/<%= r.transferId %>" class="text-xs text-brand-700 hover:underline ml-2">zobacz pliki →</a><% } %>
          </div>
          <form method="POST" action="/admin/projects/<%= project.id %>/requests/<%= r.id %>/delete" onsubmit="return confirm('Usunąć punkt?');" class="shrink-0">
            <button type="submit" class="text-slate-300 hover:text-red-600 opacity-0 group-hover:opacity-100 transition p-1" title="Usuń"><%- icon('trash', { size: 14, cls: '' }) %></button>
          </form>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>

<div class="mt-6 grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- Kolumny transferów -->
  <div class="lg:col-span-2 space-y-6">
    <%
      const renderList = (items, emptyText) => {
        if (!items.length) return `<div class="px-5 py-6 text-center text-sm text-slate-400">${emptyText}</div>`;
        return items.map((t) => {
          const statusCls = t.status === 'active' ? 'bg-green-50 text-green-700' : (t.status === 'expired' ? 'bg-amber-50 text-amber-700' : 'bg-slate-100 text-slate-500');
          return `<a href="/admin/transfers/${t.id}" class="flex items-center justify-between px-5 py-3 hover:bg-slate-50 transition">
            <span class="min-w-0 mr-3">
              <span class="block text-sm font-medium text-slate-800 truncate">${t.title || ('Transfer ' + t.token)}</span>
              <span class="block text-xs text-slate-400">${t.files.length} plik(ów) · ${fmt.date(t.createdAt)}</span>
            </span>
            <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium ${statusCls} shrink-0">${fmt.status(t.status)}</span>
          </a>`;
        }).join('');
      };
    %>

    <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
      <div class="px-5 py-3 border-b border-slate-100 text-sm font-medium text-slate-700 flex items-center gap-2"><%- icon('upload', { size: 16 }) %> Wysłane do klienta (<%= outgoing.length %>)</div>
      <div class="divide-y divide-slate-100"><%- renderList(outgoing, 'Brak wysłanych transferów.') %></div>
    </div>

    <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
      <div class="px-5 py-3 border-b border-slate-100 text-sm font-medium text-slate-700 flex items-center gap-2"><%- icon('download', { size: 16 }) %> Odebrane od klienta (<%= incoming.length %>)</div>
      <div class="divide-y divide-slate-100"><%- renderList(incoming, 'Brak linków uploadu.') %></div>
    </div>

    <!-- Rozliczenia -->
    <div id="rozliczenia" class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
      <div class="px-5 py-3 border-b border-slate-100 flex flex-wrap items-center justify-between gap-x-3 gap-y-1">
        <h2 class="text-sm font-medium text-slate-700">Rozliczenia</h2>
        <% if (chargeTotals.gross > 0) { %>
          <div class="text-xs text-slate-400">
            <% if (chargeTotals.vat > 0) { %>
              Netto <span class="text-slate-600 font-medium"><%= fmt.money(chargeTotals.net) %></span> ·
              VAT <span class="text-slate-600 font-medium"><%= fmt.money(chargeTotals.vat) %></span> ·
              Brutto <span class="text-slate-600 font-medium"><%= fmt.money(chargeTotals.gross) %></span> ·
            <% } else { %>
              Wartość <span class="text-slate-600 font-medium"><%= fmt.money(chargeTotals.gross) %></span> ·
            <% } %>
            Rozliczono <span class="text-slate-600 font-medium"><%= fmt.money(chargeTotals.paid) %></span> ·
            Pozostało <span class="font-semibold <%= chargeTotals.outstanding > 0 ? 'text-amber-600' : 'text-green-600' %>"><%= fmt.money(chargeTotals.outstanding) %></span>
          </div>
        <% } %>
      </div>

      <% if (project.charges.length) { %>
        <ul class="divide-y divide-slate-100">
          <% project.charges.forEach(function(ch){ const _vat = ch.vatRate ? Math.round(ch.amount * ch.vatRate / 100) : 0; const _gross = ch.amount + _vat; %>
            <li class="flex items-center gap-3 px-5 py-3">
              <form method="POST" action="/admin/projects/<%= project.id %>/charges/<%= ch.id %>/toggle" class="shrink-0">
                <button type="submit" title="<%= ch.paidAt ? 'Oznacz jako nierozliczone' : 'Oznacz jako rozliczone' %>" class="w-5 h-5 rounded border flex items-center justify-center transition <%= ch.paidAt ? 'bg-green-500 border-green-500 text-white' : 'border-slate-300 text-transparent hover:border-brand-400' %>"><%- icon('check', { size: 13, cls: '' }) %></button>
              </form>
              <span class="min-w-0 flex-1">
                <span class="block text-sm <%= ch.paidAt ? 'line-through text-slate-400' : 'text-slate-800' %>"><%= ch.label || 'Pozycja' %><% if (ch.date) { %> <span class="text-xs font-normal text-slate-400">· <%= fmt.dateOnly(ch.date) %></span><% } %></span>
                <% if (ch.note) { %><span class="block text-xs text-slate-400"><%= ch.note %></span><% } %>
                <% if (ch.dueDate && !ch.paidAt) { const _od = new Date(ch.dueDate) < new Date(); %><span class="block text-xs <%= _od ? 'text-red-600' : 'text-slate-400' %>">termin: <%= fmt.dateOnly(ch.dueDate) %><%= _od ? ' — po terminie' : '' %></span><% } %>
                <% if (ch.paidAt) { %>
                  <form method="POST" action="/admin/projects/<%= project.id %>/charges/<%= ch.id %>/paid-date" class="flex items-center gap-1">
                    <span class="text-xs text-green-600">rozliczono</span>
                    <input type="date" name="paidAt" value="<%= new Date(ch.paidAt).toISOString().slice(0,10) %>" onchange="this.form.submit()" title="Zmień datę rozliczenia" class="text-xs text-green-700 bg-transparent border border-transparent hover:border-green-300 focus:border-green-400 rounded px-1 py-0.5 outline-none cursor-pointer" />
                  </form>
                <% } %>
              </span>
              <span class="shrink-0 text-right">
                <span class="block text-sm font-medium tabular-nums <%= ch.paidAt ? 'text-slate-400' : 'text-slate-800' %>"><%= fmt.money(_gross) %></span>
                <% if (ch.vatRate != null) { %><span class="block text-[11px] text-slate-400 tabular-nums"><%= fmt.money(ch.amount) %> netto + <%= ch.vatRate %>% VAT</span><% } %>
              </span>
              <form method="POST" action="/admin/projects/<%= project.id %>/charges/<%= ch.id %>/delete" class="shrink-0" onsubmit="return confirm('Usunąć pozycję rozliczeniową?')">
                <button type="submit" title="Usuń pozycję" class="p-1 text-slate-300 hover:text-red-600 transition"><%- icon('trash', { size: 15 }) %></button>
              </form>
            </li>
          <% }); %>
        </ul>
      <% } else { %>
        <div class="px-5 py-6 text-center text-sm text-slate-400">Brak pozycji rozliczeniowych.</div>
      <% } %>

      <form method="POST" action="/admin/projects/<%= project.id %>/charges" class="px-5 py-3 border-t border-slate-100 bg-slate-50 space-y-2">
        <div class="flex flex-wrap items-end gap-2">
          <label class="flex-1 min-w-[150px] text-[11px] text-slate-500">Nazwa
            <input name="label" type="text" placeholder="np. Sesja, Zaliczka" class="mt-0.5 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-800 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
          </label>
          <label class="text-[11px] text-slate-500">Netto zł
            <input name="amount" type="text" inputmode="decimal" required placeholder="0,00" class="mt-0.5 w-32 rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-800 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
          </label>
          <label class="text-[11px] text-slate-500">VAT
            <select name="vatRate" class="mt-0.5 w-24 rounded-lg border border-slate-300 px-2 py-2 text-sm text-slate-800 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none">
              <option value="">bez</option>
              <option value="23">23%</option>
              <option value="8">8%</option>
              <option value="5">5%</option>
              <option value="0">0%</option>
            </select>
          </label>
        </div>
        <div class="flex flex-wrap items-end gap-2">
          <label class="text-[11px] text-slate-500">Data
            <input name="date" type="date" value="<%= new Date().toISOString().slice(0,10) %>" class="mt-0.5 w-40 rounded-lg border border-slate-300 px-2 py-2 text-sm text-slate-800 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
          </label>
          <label class="text-[11px] text-slate-500">Termin
            <input name="dueDate" type="date" title="Termin płatności (opcjonalnie)" class="mt-0.5 w-40 rounded-lg border border-slate-300 px-2 py-2 text-sm text-slate-800 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
          </label>
          <button type="submit" class="ml-auto rounded-lg bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium px-5 py-2 transition whitespace-nowrap">Dodaj</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Historia -->
  <div>
    <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
      <div class="px-5 py-3 border-b border-slate-100 text-sm font-medium text-slate-700">Historia</div>
      <% if (!history.length) { %>
        <div class="px-5 py-6 text-center text-sm text-slate-400">Brak zdarzeń.</div>
      <% } else { %>
        <ul class="divide-y divide-slate-100">
          <% history.forEach(function(e){ %>
            <li class="px-5 py-3 flex gap-3">
              <span class="mt-0.5"><%- eventIcon(e.type) %></span>
              <span class="min-w-0">
                <span class="block text-sm text-slate-700"><%= e.message || e.type %></span>
                <span class="block text-xs text-slate-400 mt-0.5"><%= fmt.date(e.createdAt) %></span>
              </span>
            </li>
          <% }); %>
        </ul>
      <% } %>
    </div>
  </div>
</div>

<!-- Usuwanie -->
<form method="POST" action="/admin/projects/<%= project.id %>/delete" class="mt-6"
      onsubmit="return confirm('Usunąć projekt? Transfery pozostaną, ale stracą przypisanie do projektu, a historia projektu zostanie usunięta.');">
  <button type="submit" class="text-sm text-red-600 hover:text-red-700">Usuń projekt</button>
</form>
