<div class="flex flex-col gap-3 mb-6">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <div class="flex flex-wrap items-center gap-2 text-sm">
      <% const tabs = [ { label: 'Aktywne', q: 'active' }, { label: 'Zarchiwizowane', q: 'archived' }, { label: 'Wszystkie', q: '' } ]; %>
      <% tabs.forEach(function(t){ const isActive = (filter.status||'') === t.q; %>
        <a href="/admin/projects?status=<%= t.q || 'all' %>"
           class="px-3 py-1.5 rounded-lg <%= isActive ? 'bg-brand-600 text-white' : 'bg-white border border-slate-200 text-slate-600 hover:bg-slate-50' %>"><%= t.label %></a>
      <% }); %>
    </div>
    <div class="flex items-center gap-2 shrink-0">
      <a href="/admin/projects/board" class="rounded-lg border border-slate-300 text-slate-700 hover:bg-slate-50 text-sm font-medium px-4 py-2 transition">Tablica</a>
      <a href="/admin/projects/new" class="rounded-lg bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium px-4 py-2 transition">+ Nowy projekt</a>
    </div>
  </div>
  <form method="GET" action="/admin/projects" class="flex flex-col gap-2 sm:flex-row sm:items-center">
    <% if (filter.status) { %><input type="hidden" name="status" value="<%= filter.status %>" /><% } %>
    <div class="relative w-full sm:max-w-xs">
      <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none"><%- icon('search', { size: 16 }) %></span>
      <input type="search" name="q" value="<%= filter.q %>" placeholder="Szukaj projektu lub klienta…" class="w-full rounded-lg border border-slate-300 pl-9 pr-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
    </div>
    <div class="flex items-center gap-2 text-sm sm:ml-auto">
      <label class="text-slate-500 shrink-0">Sortuj:</label>
      <select name="sort" onchange="this.form.submit()" class="rounded-lg border border-slate-300 pl-3 pr-9 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none">
        <% [['activity','Ostatnia aktywność'],['created','Najnowsze'],['name','Nazwa A-Z'],['manual','Ręczna kolejność']].forEach(function(o){ %>
          <option value="<%= o[0] %>" <%= filter.sort === o[0] ? 'selected' : '' %>><%= o[1] %></option>
        <% }); %>
      </select>
    </div>
  </form>
</div>

<% if (!projects.length) { %>
  <div class="bg-white rounded-2xl border border-slate-200 p-10 text-center text-slate-500">
    <% if (filter.q) { %>
      <p>Brak wyników dla „<%= filter.q %>".</p>
    <% } else { %>
      <p class="mb-3">Brak projektów.</p>
      <a href="/admin/projects/new" class="text-brand-700 font-medium hover:underline">Utwórz pierwszy projekt →</a>
    <% } %>
  </div>
<% } else { %>
  <div id="projectGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    <% projects.forEach(function(p){ %>
      <a href="/admin/projects/<%= p.id %>" data-id="<%= p.id %>" class="block bg-white rounded-2xl border border-slate-200 p-5 hover:border-brand-300 hover:shadow-sm transition">
        <div class="flex items-start justify-between gap-2">
          <h3 class="font-semibold text-slate-800"><%= p.name %></h3>
          <div class="flex items-center gap-2 shrink-0">
            <% if (p.unread > 0) { %>
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-brand-600 text-white text-xs font-semibold" title="Nowa aktywność">
                <%- icon('bell', { size: 12, cls: '' }) %><%= p.unread %>
              </span>
            <% } %>
            <% if (p.status === 'archived') { %><span class="text-xs px-2 py-0.5 rounded-full bg-slate-100 text-slate-500">archiwum</span><% } %>
          </div>
        </div>
        <% const _clientLabel = (p.client && p.client.name) ? p.client.name : p.clientName; %>
        <% if (_clientLabel) { %><p class="text-sm text-slate-500 mt-0.5"><%= _clientLabel %></p><% } %>
        <div class="mt-4 flex items-center gap-4 text-xs text-slate-400">
          <span><%= p._count.transfers %> transfer(ów)</span>
          <span>·</span>
          <span>akt. <%= fmt.date(p.updatedAt) %></span>
        </div>
      </a>
    <% }); %>
  </div>

  <% if (filter.sort === 'manual') { %>
    <p class="mt-3 text-xs text-slate-400">Przeciągnij karty, aby zmienić kolejność — zapisuje się automatycznie.</p>
    <script src="/js/sortable.min.js"></script>
    <script>
      (function () {
        var grid = document.getElementById('projectGrid');
        if (!grid || !window.Sortable) return;
        Sortable.create(grid, {
          animation: 150,
          ghostClass: 'opacity-50', // placeholder zostawiony w miejscu; obrazek przeciągania = natywny snapshot karty
          onEnd: function () {
            var ids = Array.prototype.map.call(grid.querySelectorAll('[data-id]'), function (el) { return el.getAttribute('data-id'); });
            fetch('/admin/projects/reorder', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ ids: ids }),
            }).catch(function () {});
          },
        });
      })();
    </script>
  <% } %>
<% } %>
