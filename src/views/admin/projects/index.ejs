<div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between mb-6">
  <div class="flex flex-wrap items-center gap-2 text-sm">
    <% const tabs = [ { label: 'Aktywne', q: 'active' }, { label: 'Zarchiwizowane', q: 'archived' }, { label: 'Wszystkie', q: '' } ]; %>
    <% tabs.forEach(function(t){ const isActive = (filter.status||'') === t.q; %>
      <a href="/admin/projects<%= t.q ? '?status=' + t.q : '' %>"
         class="px-3 py-1.5 rounded-lg <%= isActive ? 'bg-brand-600 text-white' : 'bg-white border border-slate-200 text-slate-600 hover:bg-slate-50' %>"><%= t.label %></a>
    <% }); %>
  </div>
  <a href="/admin/projects/new" class="rounded-lg bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium px-4 py-2 transition">+ Nowy projekt</a>
</div>

<% if (!projects.length) { %>
  <div class="bg-white rounded-2xl border border-slate-200 p-10 text-center text-slate-500">
    <p class="mb-3">Brak projektów.</p>
    <a href="/admin/projects/new" class="text-brand-700 font-medium hover:underline">Utwórz pierwszy projekt →</a>
  </div>
<% } else { %>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    <% projects.forEach(function(p){ %>
      <a href="/admin/projects/<%= p.id %>" class="block bg-white rounded-2xl border border-slate-200 p-5 hover:border-brand-300 hover:shadow-sm transition">
        <div class="flex items-start justify-between gap-2">
          <h3 class="font-semibold text-slate-800"><%= p.name %></h3>
          <div class="flex items-center gap-2 shrink-0">
            <% if (p.unread > 0) { %>
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-brand-600 text-white text-xs font-semibold" title="Nowa aktywność">
                <%- icon('bell', { size: 12, cls: '' }) %><%= p.unread %>
              </span>
            <% } %>
            <% if (p.status === 'archived') { %><span class="text-xs px-2 py-0.5 rounded-full bg-slate-100 text-slate-500">archiwum</span><% } %>
          </div>
        </div>
        <% if (p.clientName) { %><p class="text-sm text-slate-500 mt-0.5"><%= p.clientName %></p><% } %>
        <div class="mt-4 flex items-center gap-4 text-xs text-slate-400">
          <span><%= p._count.transfers %> transfer(ów)</span>
          <span>·</span>
          <span>akt. <%= fmt.date(p.updatedAt) %></span>
        </div>
      </a>
    <% }); %>
  </div>
<% } %>
