<div class="mb-5">
  <a href="/admin/projects" class="inline-flex items-center gap-1 text-sm text-slate-500 hover:text-slate-700"><%- icon('arrowLeft', { size: 15 }) %> Projekty</a>
</div>

<% if (saved === '1') { %>
  <div class="mb-4 flex items-center gap-2 rounded-lg bg-green-50 border border-green-200 text-green-800 text-sm px-3 py-2"><%- icon('check', { size: 16, cls: 'text-green-600' }) %> Zapisano szablon.</div>
<% } else if (saved === 'del') { %>
  <div class="mb-4 rounded-lg bg-green-50 border border-green-200 text-green-800 text-sm px-3 py-2">Usunięto szablon (istniejące projekty bez zmian).</div>
<% } else if (saved === 'invalid') { %>
  <div class="mb-4 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm px-3 py-2">Podaj nazwę szablonu.</div>
<% } %>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-5 items-start">
  <!-- Lista szablonów -->
  <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
    <div class="px-5 py-3 border-b border-slate-100">
      <h2 class="text-sm font-medium text-slate-700">Szablony projektów</h2>
      <p class="text-xs text-slate-400 mt-0.5">Wybierasz je przy tworzeniu projektu — rozstawiają listę braków i przypomnienia.</p>
    </div>
    <% if (!templates.length) { %>
      <div class="px-5 py-8 text-center text-sm text-slate-400">Brak szablonów — dodaj pierwszy obok.</div>
    <% } else { %>
      <div class="divide-y divide-slate-100">
        <% templates.forEach(function(t){ %>
          <div class="px-5 py-3">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <div class="text-sm font-medium text-slate-800"><%= t.name %></div>
                <% if (t.description) { %><div class="text-xs text-slate-400 mt-0.5"><%= t.description %></div><% } %>
                <div class="text-xs text-slate-400 mt-1"><%= t.parsed.fileRequests.length %> brak(ów) · <%= t.parsed.reminders.length %> przypomnień</div>
              </div>
              <form method="POST" action="/admin/projects/templates/<%= t.id %>/delete" class="shrink-0" onsubmit="return confirm('Usunąć szablon? Istniejące projekty zostaną bez zmian.')">
                <button type="submit" class="text-slate-400 hover:text-red-600 transition" title="Usuń"><%- icon('trash', { size: 15, cls: '' }) %></button>
              </form>
            </div>
            <% if (t.parsed.fileRequests.length || t.parsed.reminders.length) { %>
              <div class="mt-2 grid grid-cols-1 sm:grid-cols-2 gap-2 text-xs text-slate-500">
                <% if (t.parsed.fileRequests.length) { %>
                  <div>
                    <div class="font-medium text-slate-400 uppercase tracking-wide text-[10px] mb-0.5">Lista braków</div>
                    <% t.parsed.fileRequests.forEach(function(fr){ %><div class="truncate">• <%= fr.label %></div><% }); %>
                  </div>
                <% } %>
                <% if (t.parsed.reminders.length) { %>
                  <div>
                    <div class="font-medium text-slate-400 uppercase tracking-wide text-[10px] mb-0.5">Przypomnienia</div>
                    <% t.parsed.reminders.forEach(function(r){ %><div class="truncate">• <%= r.title %> <span class="text-slate-400">(+<%= r.offsetDays %> dni<%= r.priority !== 'normal' ? ' · ' + r.priority : '' %>)</span></div><% }); %>
                  </div>
                <% } %>
              </div>
            <% } %>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>

  <!-- Nowy szablon -->
  <form method="POST" action="/admin/projects/templates" class="bg-white rounded-2xl border border-slate-200 p-5 space-y-4">
    <h2 class="text-sm font-medium text-slate-700">Nowy szablon</h2>
    <div>
      <label class="block text-xs font-medium text-slate-600 mb-1">Nazwa *</label>
      <input name="name" type="text" required placeholder="np. Strona www" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-600 mb-1">Opis (opcjonalnie)</label>
      <input name="description" type="text" placeholder="np. standardowy projekt strony z CMS" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-600 mb-1">Lista braków — jedna pozycja na linię</label>
      <textarea name="fileRequestsText" rows="5" spellcheck="false" placeholder="Logo w wektorze | AI lub SVG&#10;Teksty na stronę&#10;Zdjęcia produktów"
                class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm font-mono focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none"></textarea>
      <p class="text-xs text-slate-400 mt-1">Format: <code>Etykieta</code> lub <code>Etykieta | notatka</code>. Klient zobaczy checklistę w panelu projektu.</p>
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-600 mb-1">Przypomnienia — jedno na linię</label>
      <textarea name="remindersText" rows="5" spellcheck="false" placeholder="Wysłać brief | +1&#10;Pierwsza wersja do klienta | +7 | high&#10;Follow-up po wdrożeniu | +30"
                class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm font-mono focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none"></textarea>
      <p class="text-xs text-slate-400 mt-1">Format: <code>Tytuł | +dni | priorytet</code> (dni od utworzenia projektu; priorytet <code>low</code>/<code>high</code>, domyślnie normalny).</p>
    </div>
    <button type="submit" class="rounded-lg bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium px-5 py-2.5 transition">Zapisz szablon</button>
  </form>
</div>
