<div class="max-w-xl">
  <a href="/admin/projects/<%= project.id %>" class="text-sm text-slate-500 hover:text-slate-700">← Wróć do projektu</a>
  <% if (error) { %>
    <div class="mt-4 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm px-3 py-2"><%= error %></div>
  <% } %>
  <form method="POST" action="/admin/projects/<%= project.id %>" class="mt-4 space-y-5 bg-white rounded-2xl border border-slate-200 p-6">
    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">Nazwa projektu *</label>
      <input name="name" type="text" required value="<%= project.name %>"
             class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">Klient</label>
      <input name="clientName" type="text" value="<%= project.clientName || '' %>"
             class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">Opis</label>
      <textarea name="description" rows="3"
                class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none"><%= project.description || '' %></textarea>
    </div>
    <div class="border-t border-slate-100 pt-4">
      <label class="block text-sm font-medium text-slate-700 mb-1">Hasło do panelu klienta</label>
      <input name="clientPassword" type="text" autocomplete="off"
             placeholder="<%= project.clientPasswordHash ? 'wpisz, aby zmienić (puste = bez zmian)' : 'ustaw hasło (puste = brak)' %>"
             class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
      <% if (project.clientPasswordHash) { %>
        <label class="inline-flex items-center gap-2 mt-2 text-sm text-slate-600">
          <input type="checkbox" name="removeClientPassword" class="rounded border-slate-300" />
          Usuń hasło (panel klienta bez hasła)
        </label>
      <% } %>
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">Status</label>
      <select name="status" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none">
        <option value="active" <%= project.status === 'active' ? 'selected' : '' %>>Aktywny</option>
        <option value="archived" <%= project.status === 'archived' ? 'selected' : '' %>>Zarchiwizowany</option>
      </select>
    </div>
    <div class="flex items-center gap-3">
      <button type="submit" class="rounded-lg bg-brand-600 hover:bg-brand-700 text-white font-medium px-5 py-2.5 text-sm transition">Zapisz zmiany</button>
      <a href="/admin/projects/<%= project.id %>" class="text-sm text-slate-500 hover:text-slate-700">Anuluj</a>
    </div>
  </form>
</div>
