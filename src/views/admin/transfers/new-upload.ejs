<div class="max-w-2xl">
  <% if (error) { %>
    <div class="mb-4 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm px-3 py-2"><%= error %></div>
  <% } %>

  <p class="text-sm text-slate-500 mb-4">
    Tworzysz link, pod którym <b>klient wgra pliki do Ciebie</b>. Otrzymasz e-mail i powiadomienie po przesłaniu.
  </p>

  <form method="POST" action="/admin/transfers/upload" class="space-y-5 bg-white rounded-2xl border border-slate-200 p-6">
    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">Projekt (opcjonalnie)</label>
      <select name="projectId" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none">
        <option value="">— bez projektu —</option>
        <% projects.forEach(function(p){ %>
          <option value="<%= p.id %>" <%= selectedProjectId === p.id ? 'selected' : '' %>><%= p.name %><%= p.clientName ? ' (' + p.clientName + ')' : '' %></option>
        <% }); %>
      </select>
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">Nagłówek (widoczny dla klienta)</label>
      <input name="title" type="text" placeholder="np. Prześlij materiały do projektu"
             class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">Opis / instrukcja (opcjonalnie)</label>
      <textarea name="message" rows="3" placeholder="np. Wgraj logo w wektorze, zdjęcia i teksty."
                class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none"></textarea>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Hasło (opcjonalnie)</label>
        <input name="password" type="text" autocomplete="off" placeholder="bez hasła"
               class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Data wygaśnięcia (opcjonalnie)</label>
        <input name="expiresAt" type="datetime-local"
               class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
      </div>
    </div>

    <div class="flex items-center gap-3">
      <button type="submit" class="rounded-lg bg-brand-600 hover:bg-brand-700 text-white font-medium px-5 py-2.5 text-sm transition">Utwórz link uploadu</button>
      <a href="/admin/transfers" class="text-sm text-slate-500 hover:text-slate-700">Anuluj</a>
    </div>
  </form>
</div>
