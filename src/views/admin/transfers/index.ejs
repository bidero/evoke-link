<div class="flex flex-col gap-3 mb-6">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <div class="flex flex-wrap items-center gap-2 text-sm">
      <% const tabs = [
        { label: 'Wszystkie', q: '' },
        { label: 'Aktywne', q: 'status=active' },
        { label: 'Wygasłe', q: 'status=expired' },
      ]; %>
      <% tabs.forEach(function(t){ const isActive = (filter.status||'') === (t.q.split('=')[1]||''); %>
        <a href="/admin/transfers<%= t.q ? '?' + t.q : '' %>"
           class="px-3 py-1.5 rounded-lg <%= isActive ? 'bg-brand-600 text-white' : 'bg-white border border-slate-200 text-slate-600 hover:bg-slate-50' %>">
          <%= t.label %>
        </a>
      <% }); %>
    </div>
    <div class="flex flex-wrap items-center gap-2">
      <a href="/admin/transfers/new-upload" class="rounded-lg border border-slate-300 text-slate-700 hover:bg-slate-50 text-sm font-medium px-4 py-2 transition">
        + Link uploadu
      </a>
      <a href="/admin/transfers/new" class="rounded-lg bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium px-4 py-2 transition">
        + Nowy transfer
      </a>
    </div>
  </div>
  <form method="GET" action="/admin/transfers" class="relative w-full sm:max-w-md">
    <% if (filter.status) { %><input type="hidden" name="status" value="<%= filter.status %>" /><% } %>
    <% if (filter.direction) { %><input type="hidden" name="direction" value="<%= filter.direction %>" /><% } %>
    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none"><%- icon('search', { size: 16 }) %></span>
    <input type="search" name="q" value="<%= filter.q %>" placeholder="Szukaj po nazwie pliku, tytule lub tokenie…" class="w-full rounded-lg border border-slate-300 pl-9 pr-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
  </form>
</div>

<% if (!transfers.length) { %>
  <div class="bg-white rounded-2xl border border-slate-200 p-10 text-center text-slate-500">
    <% if (filter.q) { %>
      <p>Brak wyników dla „<%= filter.q %>".</p>
    <% } else { %>
      <p class="mb-3">Brak transferów.</p>
      <a href="/admin/transfers/new" class="text-brand-700 font-medium hover:underline">Utwórz pierwszy transfer →</a>
    <% } %>
  </div>
<% } else { %>
  <form method="POST" action="/admin/transfers/bulk-delete"
        x-data="{ n: 0, count(){ return this.$root.querySelectorAll('input[name=ids]:checked').length } }"
        @change="n = count()"
        onsubmit="return confirm('Usunąć zaznaczone transfery i ich pliki? Tej operacji nie można cofnąć.')">
    <div x-show="n > 0" x-cloak class="mb-3 flex items-center gap-3">
      <span class="text-sm text-slate-600"><span x-text="n"></span> zaznaczonych</span>
      <button type="submit" class="rounded-lg bg-red-600 hover:bg-red-700 text-white text-sm font-medium px-4 py-2 transition">Usuń zaznaczone</button>
    </div>
  <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
    <div class="overflow-x-auto">
    <table class="w-full text-sm min-w-[760px]">
      <thead class="bg-slate-50 text-slate-500 text-left">
        <tr>
          <th class="px-4 py-3 w-10"><input type="checkbox" @change="$root.querySelectorAll('input[name=ids]').forEach(c => c.checked = $el.checked); n = count()" class="rounded border-slate-300" title="Zaznacz wszystkie" /></th>
          <th class="px-4 py-3 font-medium">Tytuł</th>
          <th class="px-4 py-3 font-medium">Pliki</th>
          <th class="px-4 py-3 font-medium">Rozmiar</th>
          <th class="px-4 py-3 font-medium">Pobrania</th>
          <th class="px-4 py-3 font-medium">Wygasa</th>
          <th class="px-4 py-3 font-medium">Status</th>
          <th class="px-4 py-3 font-medium">Utworzono</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% transfers.forEach(function(t){ %>
          <tr class="hover:bg-slate-50 cursor-pointer" onclick="window.location='/admin/transfers/<%= t.id %>'">
            <td class="px-4 py-3" @click.stop><input type="checkbox" name="ids" value="<%= t.id %>" class="rounded border-slate-300" /></td>
            <td class="px-4 py-3 font-medium text-slate-800">
              <span class="inline-flex items-center gap-1.5">
                <% if (t.direction === 'incoming') { %><span title="Odebrane od klienta"><%- icon('download', { size: 15, cls: 'text-sky-600' }) %></span><% } else { %><span title="Wysłane do klienta"><%- icon('upload', { size: 15 }) %></span><% } %>
                <span><%= t.title || ('Transfer ' + t.token) %></span>
                <% if (t.passwordHash) { %><%- icon('lock', { size: 13, cls: 'text-slate-400' }) %><% } %>
              </span>
              <% if (filter.q) { const _ql = filter.q.toLowerCase(); const _hits = t.files.filter(function(f){ return f.originalName.toLowerCase().includes(_ql); }); %>
                <% if (_hits.length) { %>
                  <span class="mt-1 flex flex-wrap gap-1">
                    <% _hits.slice(0,4).forEach(function(f){ %><span class="inline-flex items-center gap-1 text-xs font-normal text-slate-500 bg-slate-100 rounded px-1.5 py-0.5"><%- icon('file', { size: 11 }) %><%= f.originalName %></span><% }); %>
                    <% if (_hits.length > 4) { %><span class="text-xs text-slate-400">+<%= _hits.length - 4 %></span><% } %>
                  </span>
                <% } %>
              <% } %>
            </td>
            <td class="px-4 py-3 text-slate-500"><%= t.files.length %></td>
            <td class="px-4 py-3 text-slate-500"><% let _sz = 0n; t.files.forEach(function(f){ _sz += BigInt(f.size); }); %><%= fmt.bytes(_sz) %></td>
            <td class="px-4 py-3 text-slate-500"><%= t.direction === 'incoming' ? '—' : (t.downloadCount + (t.maxDownloads ? ' / ' + t.maxDownloads : '')) %></td>
            <td class="px-4 py-3 text-slate-500"><%= t.expiresAt ? fmt.date(t.expiresAt) : '—' %></td>
            <td class="px-4 py-3">
              <% const s = t.status; const cls = s==='active' ? 'bg-green-50 text-green-700' : (s==='expired' ? 'bg-amber-50 text-amber-700' : 'bg-slate-100 text-slate-500'); %>
              <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium <%= cls %>"><%= fmt.status(s) %></span>
            </td>
            <td class="px-4 py-3 text-slate-400"><%= fmt.date(t.createdAt) %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
    </div>
  </div>
  </form>
<% } %>
