<% const incoming = transfer.direction === 'incoming'; %>
<div class="max-w-3xl" x-data="{ copied: false }">
  <div class="flex items-center justify-between">
    <% if (typeof back !== 'undefined' && back) { %>
      <a href="<%= back.href %>" class="text-sm text-slate-500 hover:text-slate-700">← <%= back.label %></a>
    <% } else if (transfer.project) { %>
      <a href="/admin/projects/<%= transfer.project.id %>" class="text-sm text-slate-500 hover:text-slate-700">← <%= transfer.project.name %></a>
    <% } else { %>
      <a href="/admin/transfers" class="text-sm text-slate-500 hover:text-slate-700">← Wszystkie transfery</a>
    <% } %>
    <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium <%= incoming ? 'bg-sky-50 text-sky-700' : 'bg-violet-50 text-brand-700' %>">
      <%- icon(incoming ? 'download' : 'upload', { size: 13, cls: '' }) %>
      <%= incoming ? 'Upload (klient → Ty)' : 'Wysyłka (Ty → klient)' %>
    </span>
  </div>

  <!-- Link publiczny -->
  <div class="mt-4 bg-white rounded-2xl border border-slate-200 p-5">
    <div class="text-sm font-medium text-slate-700 mb-2"><%= incoming ? 'Link uploadu (wyślij klientowi)' : 'Link do pobrania (wyślij klientowi)' %></div>
    <div class="flex flex-col sm:flex-row gap-2">
      <input readonly value="<%= publicUrl %>" x-ref="url"
             class="flex-1 min-w-0 rounded-lg border border-slate-300 bg-slate-50 px-3 py-2 text-sm text-slate-700" />
      <div class="flex gap-2">
        <button @click="navigator.clipboard.writeText($refs.url.value); copied = true; setTimeout(()=>copied=false, 1500)"
                class="flex-1 sm:flex-none rounded-lg bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium px-4 py-2 transition whitespace-nowrap">
          <span x-show="!copied">Kopiuj</span>
          <span x-show="copied">Skopiowano ✓</span>
        </button>
        <a href="<%= publicUrl %>" target="_blank" class="flex-1 sm:flex-none text-center rounded-lg border border-slate-300 text-slate-600 hover:bg-slate-50 text-sm font-medium px-4 py-2 transition whitespace-nowrap">Otwórz</a>
      </div>
    </div>
  </div>

  <!-- Wyślij link e-mailem -->
  <div class="mt-4 bg-white rounded-2xl border border-slate-200 p-5">
    <div class="text-sm font-medium text-slate-700 mb-2">Wyślij link e-mailem</div>
    <% if (mail === 'sent') { %>
      <div class="mb-3 flex items-center gap-2 rounded-lg bg-green-50 border border-green-200 text-green-800 text-sm px-3 py-2"><%- icon('check', { size: 16, cls: 'text-green-600' }) %> Wysłano link na podany adres.</div>
    <% } else if (mail === 'invalid') { %>
      <div class="mb-3 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm px-3 py-2">Podaj poprawny adres e-mail.</div>
    <% } else if (mail === 'error') { %>
      <div class="mb-3 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm px-3 py-2">Nie udało się wysłać. Sprawdź konfigurację SMTP w .env.</div>
    <% } %>
    <form method="POST" action="/admin/transfers/<%= transfer.id %>/send" class="space-y-2">
      <div class="flex flex-col sm:flex-row gap-2">
        <input name="email" type="email" required placeholder="adres@klienta.pl"
               value="<%= (transfer.project && transfer.project.client && transfer.project.client.email) || '' %>"
               class="flex-1 rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
        <button type="submit" class="rounded-lg bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium px-4 py-2 transition whitespace-nowrap">Wyślij link</button>
      </div>
      <textarea name="message" rows="2" placeholder="Wiadomość do klienta (opcjonalnie)"
                class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none"></textarea>
      <% if (!mailReady) { %>
        <p class="text-xs text-amber-600">SMTP nie jest skonfigurowany w .env — wiadomość trafi do logów serwera zamiast do klienta.</p>
      <% } %>
    </form>
  </div>

  <!-- Parametry -->
  <div class="mt-4 grid grid-cols-2 sm:grid-cols-4 gap-3">
    <% const box = (label, val) => `<div class="bg-white rounded-xl border border-slate-200 p-3"><div class="text-xs text-slate-400">${label}</div><div class="text-sm font-medium text-slate-700 mt-0.5">${val}</div></div>`; %>
    <%- box('Status', fmt.status(transfer.status)) %>
    <% if (incoming) { %>
      <%- box('Otrzymane pliki', transfer.files.length) %>
    <% } else { %>
      <%- box('Pobrania', transfer.downloadCount + (transfer.maxDownloads ? ' / ' + transfer.maxDownloads : '')) %>
    <% } %>
    <%- box('Hasło', transfer.passwordHash ? 'tak ' + icon('lock', { size: 14 }) : 'nie') %>
    <%- box('Wygasa', transfer.expiresAt ? fmt.date(transfer.expiresAt) : 'nigdy') %>
  </div>

  <form method="POST" action="/admin/transfers/<%= transfer.id %>/extend" class="mt-3 flex items-center gap-2 flex-wrap">
    <span class="text-sm text-slate-500">Przedłuż ważność o</span>
    <select name="days" class="rounded-lg border border-slate-300 px-2 py-1.5 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none">
      <option value="7">7 dni</option><option value="14" selected>14 dni</option><option value="30">30 dni</option><option value="90">90 dni</option>
    </select>
    <button type="submit" class="rounded-lg border border-slate-300 text-slate-700 hover:bg-slate-50 text-sm font-medium px-3 py-1.5 transition">Przedłuż<%= transfer.status === 'expired' ? ' i reaktywuj' : '' %></button>
  </form>

  <% if (transfer.proofing && !incoming) { %>
    <div class="mt-3 rounded-xl border p-4 <%= transfer.approvalStatus === 'approved' ? 'border-green-200 bg-green-50/60' : (transfer.approvalStatus === 'changes' ? 'border-amber-200 bg-amber-50/60' : 'border-slate-200 bg-white') %>">
      <div class="flex items-center gap-2 text-sm">
        <% if (transfer.approvalStatus === 'approved') { %>
          <%- icon('check', { size: 16, cls: 'text-green-600' }) %>
          <span class="font-medium text-green-800">Klient zatwierdził pliki</span>
          <span class="text-xs text-green-700/70"><%= transfer.approvalBy ? transfer.approvalBy + ' · ' : '' %><%= fmt.date(transfer.approvalAt) %></span>
        <% } else if (transfer.approvalStatus === 'changes') { %>
          <%- icon('alert', { size: 16, cls: 'text-amber-600' }) %>
          <span class="font-medium text-amber-800">Klient zgłosił poprawki</span>
          <span class="text-xs text-amber-700/70"><%= transfer.approvalBy ? transfer.approvalBy + ' · ' : '' %><%= fmt.date(transfer.approvalAt) %></span>
        <% } else { %>
          <%- icon('clock', { size: 16, cls: 'text-slate-400' }) %>
          <span class="text-slate-600">Oczekuje na akceptację klienta</span>
        <% } %>
      </div>
      <% if (transfer.approvalComment) { %>
        <div class="mt-2 text-sm text-slate-700 whitespace-pre-wrap border-l-2 <%= transfer.approvalStatus === 'approved' ? 'border-green-300' : 'border-amber-300' %> pl-3"><%= transfer.approvalComment %></div>
      <% } %>
    </div>
  <% } %>

  <div class="mt-3">
    <a href="/admin/transfers/<%= transfer.id %>/edit" class="inline-block rounded-lg border border-slate-300 text-slate-700 hover:bg-slate-50 text-sm font-medium px-4 py-2 transition">
      Edytuj ustawienia
    </a>
  </div>

  <% if (transfer.message) { %>
    <div class="mt-4 bg-white rounded-2xl border border-slate-200 p-5">
      <div class="text-xs text-slate-400 mb-1"><%= incoming ? 'Instrukcja dla klienta' : 'Wiadomość' %></div>
      <p class="text-sm text-slate-700 whitespace-pre-line"><%= transfer.message %></p>
    </div>
  <% } %>

  <!-- Pliki -->
  <%
    // Obrazy (raster) do Quick Look — Alpine cyklicznie przegląda po tej liście.
    const _imgs = transfer.files.filter((f) => fileMeta(f.originalName, f.mimeType).thumb);
    const _lb = _imgs.map((f) => ({
      src: `/admin/transfers/${transfer.id}/preview/${f.id}`,
      dl: `/admin/transfers/${transfer.id}/file/${f.id}`,
      name: f.originalName,
    }));
  %>
  <div class="mt-4 bg-white rounded-2xl border border-slate-200 overflow-hidden" x-data="lightbox(<%= JSON.stringify(_lb) %>)">
    <div class="px-5 py-3 border-b border-slate-100 flex items-center justify-between">
      <span class="text-sm font-medium text-slate-700">
        <%= incoming ? 'Otrzymane pliki' : 'Pliki' %> (<%= transfer.files.length %>)
      </span>
      <% if (transfer.files.length) { %>
        <a href="/admin/transfers/<%= transfer.id %>/zip" class="text-sm text-brand-700 hover:underline">Pobierz ZIP</a>
      <% } %>
    </div>
    <% if (!transfer.files.length) { %>
      <div class="px-5 py-8 text-center text-sm text-slate-400">
        <%= incoming ? 'Oczekiwanie na pliki od klienta…' : 'Brak plików.' %>
      </div>
    <% } else { %>
      <div class="divide-y divide-slate-100">
        <% transfer.files.forEach(function(f){ %>
          <%
            const _m = fileMeta(f.originalName, f.mimeType);
            const _dl = `/admin/transfers/${transfer.id}/file/${f.id}`;
            const _prev = `/admin/transfers/${transfer.id}/preview/${f.id}`;
            const _ii = _m.thumb ? _imgs.indexOf(f) : -1;
          %>
          <div class="flex items-center justify-between px-5 py-2.5 text-sm hover:bg-slate-50 transition group">
            <div class="flex items-center gap-3 min-w-0 mr-3">
              <% if (_m.thumb) { %>
                <button type="button" @click="open(<%= _ii %>)" class="shrink-0" title="Podgląd (Quick Look)">
                  <img src="<%= _prev %>" alt="" loading="lazy" class="w-12 h-12 rounded-lg object-cover border border-slate-200 bg-slate-50" />
                </button>
                <button type="button" @click="open(<%= _ii %>)" class="min-w-0 truncate text-left text-slate-700 hover:text-brand-700"><%= f.originalName %></button>
              <% } else { %>
                <span class="w-12 h-12 rounded-lg bg-slate-50 border border-slate-100 flex items-center justify-center shrink-0"><%- icon(_m.icon, { size: 22, cls: _m.color }) %></span>
                <a href="<%= _dl %>" class="min-w-0 truncate text-slate-700 hover:text-brand-700"><%= f.originalName %></a>
              <% } %>
            </div>
            <span class="flex items-center gap-3 shrink-0">
              <span class="text-slate-400"><%= fmt.bytes(f.size) %></span>
              <a href="<%= _dl %>" class="text-slate-400 hover:text-brand-700 opacity-0 group-hover:opacity-100 transition" aria-label="Pobierz" title="Pobierz"><%- icon('download', { size: 16 }) %></a>
            </span>
          </div>
        <% }); %>
      </div>
    <% } %>

    <!-- Quick Look (podgląd jak na Macu): Esc zamyka, ← → przewija -->
    <div x-show="show" x-cloak x-transition.opacity.duration.200ms
         @keydown.escape.window="close()" @keydown.arrow-right.window="next()" @keydown.arrow-left.window="prev()"
         class="fixed inset-0 z-50 bg-black/80 backdrop-blur-sm flex items-center justify-center p-4" @click.self="close()">
      <button type="button" @click="close()" class="absolute top-4 right-4 w-10 h-10 inline-flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-white" aria-label="Zamknij"><%- icon('x', { size: 20, cls: '' }) %></button>
      <button type="button" x-show="items.length > 1" @click.stop="prev()" class="absolute left-3 sm:left-6 w-11 h-11 inline-flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-white" aria-label="Poprzedni"><%- icon('arrowLeft', { size: 22, cls: '' }) %></button>
      <button type="button" x-show="items.length > 1" @click.stop="next()" class="absolute right-3 sm:right-6 w-11 h-11 inline-flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-white" aria-label="Następny"><%- icon('arrowRight', { size: 22, cls: '' }) %></button>
      <div x-show="show" x-transition.duration.200ms class="flex flex-col items-center gap-3 max-w-[92vw]">
        <img :src="cur.src" :alt="cur.name" class="max-w-[92vw] max-h-[80vh] rounded-lg object-contain shadow-2xl" />
        <div class="flex items-center gap-4 text-white text-sm">
          <span class="truncate max-w-[60vw]" x-text="cur.name"></span>
          <span class="text-white/50" x-show="items.length > 1" x-text="(i + 1) + ' / ' + items.length"></span>
          <a :href="cur.dl" class="underline hover:text-white/80">Pobierz</a>
        </div>
      </div>
    </div>
  </div>

  <script>
    function lightbox(items) {
      return {
        items: items || [],
        i: 0,
        show: false,
        open(idx) { if (idx == null || idx < 0) return; this.i = idx; this.show = true; },
        close() { this.show = false; },
        next() { if (this.items.length) this.i = (this.i + 1) % this.items.length; },
        prev() { if (this.items.length) this.i = (this.i - 1 + this.items.length) % this.items.length; },
        get cur() { return this.items[this.i] || {}; },
      };
    }
  </script>

  <!-- Usuwanie -->
  <form method="POST" action="/admin/transfers/<%= transfer.id %>/delete" class="mt-4"
        onsubmit="return confirm('Usunąć transfer i wszystkie jego pliki? Tej operacji nie można cofnąć.');">
    <button type="submit" class="text-sm text-red-600 hover:text-red-700">Usuń transfer</button>
  </form>
</div>
