<div class="max-w-2xl" x-data="uploader()">
  <% if (error) { %>
    <div class="mb-4 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm px-3 py-2"><%= error %></div>
  <% } %>

  <form @submit.prevent="submit" class="space-y-6">
    <!-- Strefa drag & drop -->
    <div
      @dragover.prevent="dragging = true"
      @dragleave.prevent="dragging = false"
      @drop.prevent="onDrop($event)"
      :class="dragging ? 'border-brand-500 bg-brand-50' : 'border-slate-300 bg-white'"
      class="rounded-2xl border-2 border-dashed p-10 text-center transition cursor-pointer"
      @click="$refs.input.click()"
    >
      <input x-ref="input" type="file" multiple class="hidden" @change="addFiles($event.target.files)" />
      <input x-ref="dirInput" type="file" webkitdirectory multiple class="hidden" @change="addFiles($event.target.files)" />
      <div class="text-slate-600">
        <div class="flex justify-center mb-2"><%- icon('cloudUpload', { size: 36 }) %></div>
        <p class="font-medium">Przeciągnij pliki lub folder tutaj</p>
        <p class="text-sm text-slate-400">lub kliknij, aby wybrać &middot;
          <button type="button" @click.stop="$refs.dirInput.click()" class="font-medium text-brand-700 hover:text-brand-800 underline underline-offset-2">wybierz folder</button>
        </p>
      </div>
    </div>

    <!-- Lista wybranych plików -->
    <template x-if="files.length">
      <div class="bg-white rounded-xl border border-slate-200 divide-y divide-slate-100">
        <template x-for="(f, i) in files" :key="i">
          <div class="flex items-center justify-between px-4 py-2.5 text-sm">
            <span class="truncate mr-3" x-text="f.name"></span>
            <div class="flex items-center gap-3 shrink-0">
              <span class="text-slate-400" x-text="human(f.size)"></span>
              <button type="button" @click="remove(i)" class="text-slate-400 hover:text-red-600"><%- icon('x', { size: 16, cls: '' }) %></button>
            </div>
          </div>
        </template>
        <div class="px-4 py-2 text-xs text-slate-500 bg-slate-50" x-text="files.length + ' plik(ów), razem ' + human(totalSize())"></div>
      </div>
    </template>

    <!-- Opcje transferu -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="sm:col-span-2">
        <label class="block text-sm font-medium text-slate-700 mb-1">Projekt (opcjonalnie)</label>
        <select name="projectId" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none">
          <option value="">— bez projektu —</option>
          <% projects.forEach(function(p){ %>
            <option value="<%= p.id %>" <%= selectedProjectId === p.id ? 'selected' : '' %>><%= p.name %><%= p.clientName ? ' (' + p.clientName + ')' : '' %></option>
          <% }); %>
        </select>
      </div>
      <div class="sm:col-span-2">
        <label class="block text-sm font-medium text-slate-700 mb-1">Tytuł (opcjonalnie)</label>
        <input name="title" type="text" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
      </div>
      <div class="sm:col-span-2">
        <label class="block text-sm font-medium text-slate-700 mb-1">Wiadomość (opcjonalnie)</label>
        <textarea name="message" rows="2" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none"></textarea>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Hasło (opcjonalnie)</label>
        <div class="flex gap-2">
          <input x-ref="pwd" name="password" type="text" autocomplete="off" placeholder="bez hasła" class="flex-1 min-w-0 rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
          <button type="button" @click="$refs.pwd.value = genPwd()" title="Wygeneruj mocne hasło" class="rounded-lg border border-slate-300 text-slate-600 hover:bg-slate-50 text-sm px-3 transition whitespace-nowrap">Generuj</button>
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Limit pobrań (opcjonalnie)</label>
        <input name="maxDownloads" type="number" min="1" placeholder="bez limitu" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
      </div>
      <div class="sm:col-span-2">
        <label class="block text-sm font-medium text-slate-700 mb-1">Data wygaśnięcia (opcjonalnie)</label>
        <input x-ref="exp" name="expiresAt" type="datetime-local" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
        <div class="flex flex-wrap gap-2 mt-2">
          <% [['1','1 dzień'],['7','7 dni'],['30','30 dni']].forEach(function(o){ %>
            <button type="button" @click="$refs.exp.value = expIn(<%= o[0] %>)" class="rounded-lg border border-slate-300 text-slate-600 hover:bg-slate-50 text-xs px-2.5 py-1 transition"><%= o[1] %></button>
          <% }); %>
          <button type="button" @click="$refs.exp.value = ''" class="rounded-lg border border-slate-300 text-slate-500 hover:bg-slate-50 text-xs px-2.5 py-1 transition">wyczyść</button>
        </div>
      </div>
    </div>

    <!-- Pasek postępu -->
    <template x-if="uploading">
      <div class="w-full bg-slate-100 rounded-full h-2 overflow-hidden">
        <div class="bg-brand-600 h-2 transition-all duration-200" :class="finalizing ? 'animate-pulse' : ''"
             :style="'width:' + (finalizing ? 100 : Math.max(progress, 4)) + '%'"></div>
      </div>
    </template>

    <div class="space-y-2">
      <label class="flex items-center gap-2 text-sm text-slate-700">
        <input type="checkbox" name="clientVisible" class="rounded border-slate-300" checked />
        Widoczny w panelu klienta projektu (jeśli przypisany)
      </label>
      <label class="flex items-center gap-2 text-sm text-slate-700">
        <input type="checkbox" name="notifyOnDownload" class="rounded border-slate-300" />
        Powiadom mnie e-mailem przy pierwszym pobraniu
      </label>
      <label class="flex items-center gap-2 text-sm text-slate-700">
        <input type="checkbox" name="proofing" class="rounded border-slate-300" />
        Poproś klienta o akceptację plików (Zatwierdź / Poprawki)
      </label>
    </div>

    <div class="flex items-center gap-3">
      <button type="submit" :disabled="uploading || !files.length"
              class="rounded-lg bg-brand-600 hover:bg-brand-700 disabled:opacity-40 disabled:cursor-not-allowed text-white font-medium px-5 py-2.5 text-sm transition">
        <span x-show="!uploading">Utwórz transfer</span>
        <span x-show="uploading" x-text="finalizing ? 'Finalizowanie…' : ('Wysyłanie… ' + progress + '%')"></span>
      </button>
      <a href="/admin/transfers" class="text-sm text-slate-500 hover:text-slate-700">Anuluj</a>
    </div>
  </form>
</div>

<script>
function uploader() {
  return {
    files: [],
    dragging: false,
    uploading: false,
    finalizing: false,
    progress: 0,
    // list: FileList (zwykły input lub webkitdirectory) albo [{ file, relPath }] z onDrop.
    // Trzymamy { file, name } — name to ścieżka względna z folderu ('katalog/plik.pdf').
    addFiles(list) {
      let over = false;
      Array.from(list).forEach((f) => {
        const file = f && f.file ? f.file : f;
        const name = (f && f.relPath) || file.webkitRelativePath || file.name;
        if (/^(\.DS_Store|Thumbs\.db|desktop\.ini|\.localized)$|^\._/.test(name.split('/').pop())) return;
        if (this.files.length >= 5000) { over = true; return; } // MAX_FILES z chunk.service.js
        this.files.push({ file, name, size: file.size });
      });
      if (over) alert('Maksymalnie 5000 plików w jednej wysyłce — nadmiarowe pominięto.');
    },
    onDrop(e) { this.dragging = false; window.collectDataTransferFiles(e.dataTransfer).then((items) => this.addFiles(items)); },
    remove(i) { this.files.splice(i, 1); },
    totalSize() { return this.files.reduce((s, f) => s + f.size, 0); },
    human(b) {
      if (!b) return '0 B';
      const u = ['B','KB','MB','GB','TB']; const i = Math.floor(Math.log(b)/Math.log(1024));
      return (b/Math.pow(1024,i)).toFixed(i===0?0:1) + ' ' + u[i];
    },
    genPwd() {
      const c = 'ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnpqrstuvwxyz23456789!@#$%&*';
      const a = new Uint32Array(16);
      (window.crypto && window.crypto.getRandomValues) ? window.crypto.getRandomValues(a) : a.forEach((_, i) => a[i] = Math.floor(Math.random() * 1e9));
      let s = ''; for (let i = 0; i < 16; i++) s += c[a[i] % c.length];
      return s;
    },
    expIn(days) {
      const d = new Date(Date.now() + days * 86400000); const p = (n) => String(n).padStart(2, '0');
      return d.getFullYear() + '-' + p(d.getMonth() + 1) + '-' + p(d.getDate()) + 'T' + p(d.getHours()) + ':' + p(d.getMinutes());
    },
    async submit(e) {
      if (!this.files.length || this.uploading) return;
      const form = e.target;
      this.uploading = true; this.progress = 0;
      try {
        const uploadId = await window.chunkedUpload(this.files, '/admin/transfers/chunk', (p) => { this.progress = p; });
        this.finalizing = true; // serwer skleja kawałki — pokaż aktywność
        const body = new URLSearchParams();
        body.append('uploadId', uploadId);
        ['title','message','password','maxDownloads','expiresAt','projectId'].forEach((n) => {
          if (form[n] && form[n].value) body.append(n, form[n].value);
        });
        if (form['clientVisible'] && form['clientVisible'].checked) body.append('clientVisible', 'on');
        if (form['notifyOnDownload'] && form['notifyOnDownload'].checked) body.append('notifyOnDownload', 'on');
        if (form['proofing'] && form['proofing'].checked) body.append('proofing', 'on');
        const res = await fetch('/admin/transfers', { method: 'POST', body });
        if (res.ok) { window.location = res.url || '/admin/transfers'; }
        else { this.uploading = false; this.finalizing = false; alert('Błąd tworzenia transferu (' + res.status + ').'); }
      } catch (err) {
        this.uploading = false; this.finalizing = false;
        alert(err && err.message ? err.message : 'Błąd wysyłania.');
      }
    },
  };
}
</script>
