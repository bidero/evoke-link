<%
  const M = pulse.money, D = pulse.delivery, C = pulse.clients, R = pulse.retainers;
  const zl = (g) => fmt.money(g);
  const zlShort = (g) => (g >= 100000 ? Math.round(g / 100).toLocaleString('pl-PL') + ' zł' : (g / 100).toFixed(0) + ' zł');
  // Delta miesiąc/miesiąc (procent) — tylko gdy był poprzedni miesiąc.
  const delta = M.paidPrevMonth > 0 ? Math.round(((M.paidThisMonth - M.paidPrevMonth) / M.paidPrevMonth) * 100) : null;
  // Wykres: skala do max wartości. TOP = zapas na etykiety cen NAD najwyższym słupkiem
  // (bez niego tekst wystaje ponad viewBox i jest obcinany).
  const maxV = Math.max(1, ...M.chart.map((c) => c.value));
  const CH = 150, CW = 560, BW = 56, GAP = (CW - 6 * BW) / 7, TOP = 20;
%>

<!-- FINANSE -->
<h2 class="text-xs font-semibold uppercase tracking-wide text-slate-400 mb-3">Finanse</h2>
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  <div class="bg-white rounded-2xl border border-slate-200 p-5">
    <div class="text-sm text-slate-500">Przychód w tym miesiącu</div>
    <div class="mt-1 flex items-baseline gap-2 flex-wrap">
      <span class="text-2xl font-bold text-slate-800"><%= zl(M.paidThisMonth) %></span>
      <% if (delta !== null) { %>
        <span class="text-xs font-medium px-1.5 py-0.5 rounded-full <%= delta >= 0 ? 'bg-green-50 text-green-700' : 'bg-red-50 text-red-700' %>"><%= delta >= 0 ? '▲' : '▼' %> <%= Math.abs(delta) %>%</span>
      <% } %>
    </div>
    <div class="text-xs text-slate-400 mt-1">poprzedni miesiąc: <%= zl(M.paidPrevMonth) %></div>
  </div>
  <div class="bg-white rounded-2xl border border-slate-200 p-5">
    <div class="text-sm text-slate-500">Do zapłaty (wszystkie)</div>
    <div class="mt-1 text-2xl font-bold text-slate-800"><%= zl(M.outstanding) %></div>
    <div class="text-xs text-slate-400 mt-1">nierozliczone pozycje</div>
  </div>
  <div class="bg-white rounded-2xl border <%= M.overdue > 0 ? 'border-red-200' : 'border-slate-200' %> p-5">
    <div class="text-sm text-slate-500">Przeterminowane</div>
    <div class="mt-1 text-2xl font-bold <%= M.overdue > 0 ? 'text-red-600' : 'text-slate-800' %>"><%= zl(M.overdue) %></div>
    <div class="text-xs text-slate-400 mt-1">po terminie płatności</div>
  </div>
  <div class="bg-white rounded-2xl border border-slate-200 p-5">
    <div class="text-sm text-slate-500">Stały przychód (MRR)</div>
    <div class="mt-1 text-2xl font-bold text-slate-800"><%= zl(R.mrr) %><span class="text-sm font-medium text-slate-400">/mc</span></div>
    <div class="text-xs text-slate-400 mt-1"><%= R.count %> aktywnych retainerów</div>
  </div>
</div>

<!-- WYKRES: przychód 6 miesięcy -->
<div class="bg-white rounded-2xl border border-slate-200 p-5 mb-6">
  <div class="text-sm font-medium text-slate-700 mb-3">Przychód — ostatnie 6 miesięcy</div>
  <svg viewBox="0 0 <%= CW %> <%= TOP + CH + 28 %>" class="w-full" role="img" aria-label="Wykres przychodu z 6 miesięcy">
    <% M.chart.forEach(function(c, i){
      const h = Math.max(3, Math.round((c.value / maxV) * CH));
      const x = GAP + i * (BW + GAP);
      const y = TOP + (CH - h);
    %>
      <rect x="<%= x %>" y="<%= y %>" width="<%= BW %>" height="<%= h %>" rx="6"
            class="<%= c.current ? 'fill-brand-600' : 'fill-brand-200' %>" />
      <% if (c.value > 0) { %><text x="<%= x + BW / 2 %>" y="<%= y - 6 %>" text-anchor="middle" class="fill-slate-500" font-size="11"><%= zlShort(c.value) %></text><% } %>
      <text x="<%= x + BW / 2 %>" y="<%= TOP + CH + 18 %>" text-anchor="middle" class="<%= c.current ? 'fill-brand-700' : 'fill-slate-400' %>" font-size="11" font-weight="<%= c.current ? '600' : '400' %>"><%= c.label %></text>
    <% }); %>
  </svg>
</div>

<% if (R.count > 0) { %>
<!-- RETAINERY: skład stałego przychodu miesięcznego -->
<div class="bg-white rounded-2xl border border-slate-200 overflow-hidden mb-6">
  <div class="px-5 py-3 border-b border-slate-100 flex items-center justify-between">
    <div class="text-sm font-medium text-slate-700">Retainery — stały przychód miesięczny</div>
    <div class="text-xs text-slate-400">razem <span class="text-slate-600 font-medium"><%= zl(R.mrr) %></span>/mc</div>
  </div>
  <div class="divide-y divide-slate-100">
    <% R.items.forEach(function(r){ %>
      <div class="flex items-center justify-between gap-3 px-5 py-2.5 text-sm">
        <span class="min-w-0">
          <a href="/admin/clients/<%= r.client.id %>?tab=rozliczenia" class="text-slate-700 hover:text-brand-700 font-medium"><%= r.client.name %></a>
          <span class="text-slate-400"> · <%= r.label %></span>
        </span>
        <span class="shrink-0 font-medium text-slate-800"><%= zl(r.gross) %><span class="text-xs text-slate-400">/mc</span></span>
      </div>
    <% }); %>
  </div>
</div>
<% } %>

<!-- DOSTARCZANIE (30 dni) -->
<h2 class="text-xs font-semibold uppercase tracking-wide text-slate-400 mb-3">Dostarczanie · ostatnie 30 dni</h2>
<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4 mb-6">
  <div class="bg-white rounded-2xl border border-slate-200 p-4">
    <div class="text-xs text-slate-500">Wysłane transfery</div>
    <div class="mt-1 text-xl font-bold text-slate-800"><%= D.sent30 %></div>
  </div>
  <div class="bg-white rounded-2xl border border-slate-200 p-4">
    <div class="text-xs text-slate-500">Skuteczność pobrań</div>
    <div class="mt-1 text-xl font-bold <%= D.pickupRate === null ? 'text-slate-400' : (D.pickupRate >= 70 ? 'text-green-600' : 'text-amber-600') %>"><%= D.pickupRate === null ? '—' : D.pickupRate + '%' %></div>
    <% if (D.sent30) { %><div class="text-[11px] text-slate-400 mt-0.5">pobrane <%= D.pickedUp %> z <%= D.sent30 %></div><% } %>
  </div>
  <div class="bg-white rounded-2xl border border-slate-200 p-4">
    <div class="text-xs text-slate-500">Pobrania plików</div>
    <div class="mt-1 text-xl font-bold text-slate-800"><%= D.downloads30 %></div>
  </div>
  <div class="bg-white rounded-2xl border border-slate-200 p-4">
    <div class="text-xs text-slate-500">Pliki: wysłane / odebrane</div>
    <div class="mt-1 text-xl font-bold text-slate-800"><%= D.filesOut30 %> <span class="text-slate-300 font-normal">/</span> <%= D.filesIn30 %></div>
  </div>
  <div class="bg-white rounded-2xl border border-slate-200 p-4">
    <div class="text-xs text-slate-500">Otwarcia linków</div>
    <div class="mt-1 text-xl font-bold text-slate-800"><%= D.views30 %></div>
  </div>
</div>

<!-- KLIENCI -->
<h2 class="text-xs font-semibold uppercase tracking-wide text-slate-400 mb-3">Klienci</h2>
<div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
  <div class="bg-white rounded-2xl border border-slate-200 p-5">
    <div class="text-sm text-slate-500">Aktywni klienci (30 dni)</div>
    <div class="mt-1 text-2xl font-bold text-slate-800"><%= C.active30 %> <span class="text-sm font-normal text-slate-400">z <%= C.total %></span></div>
    <div class="text-xs text-slate-400 mt-1">otwierali, pobierali lub wgrywali</div>
  </div>
  <div class="lg:col-span-2 bg-white rounded-2xl border border-slate-200 p-5">
    <div class="text-sm font-medium text-slate-700 mb-3">Top klienci wg przychodu <span class="text-slate-400 font-normal">(6 mies.)</span></div>
    <% if (!C.top.length) { %>
      <p class="text-sm text-slate-400">Brak opłaconych pozycji w tym okresie.</p>
    <% } else { %>
      <% const maxP = C.top[0].paid || 1; %>
      <div class="space-y-2.5">
        <% C.top.forEach(function(t){ %>
          <a href="/admin/clients/<%= t.id %>?tab=rozliczenia" class="block group">
            <div class="flex items-center justify-between text-sm mb-1">
              <span class="text-slate-700 group-hover:text-brand-700 truncate mr-3"><%= t.name %></span>
              <span class="text-slate-500 shrink-0"><%= zl(t.paid) %></span>
            </div>
            <div class="h-2 bg-slate-100 rounded-full overflow-hidden"><div class="h-full bg-brand-500 rounded-full" style="width: <%= Math.max(3, Math.round((t.paid / maxP) * 100)) %>%"></div></div>
          </a>
        <% }); %>
      </div>
    <% } %>
  </div>
</div>
