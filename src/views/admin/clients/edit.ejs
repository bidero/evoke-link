<div class="max-w-xl" x-data="{ copied: false, send() { var to = '<%= client.email || '' %>'; if (!to) { to = (prompt('Wyślij link panelu na adres e-mail:') || '').trim(); if (!to) return; } this.$refs.sendEmail.value = to; this.$refs.sendForm.submit(); } }">
  <a href="/admin/clients" class="text-sm text-slate-500 hover:text-slate-700">← Wszyscy klienci</a>
  <% if (error) { %>
    <div class="mt-4 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm px-3 py-2"><%= error %></div>
  <% } %>

  <form method="POST" action="/admin/clients/<%= client.id %>" class="mt-4 space-y-5 bg-white rounded-2xl border border-slate-200 p-6">
    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">Nazwa klienta *</label>
      <input name="name" type="text" required value="<%= client.name %>"
             class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">E-mail</label>
      <input name="email" type="email" value="<%= client.email || '' %>"
             class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">Notatka</label>
      <textarea name="note" rows="2" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none"><%= client.note || '' %></textarea>
    </div>
    <div class="flex items-center gap-3">
      <button type="submit" class="rounded-lg bg-brand-600 hover:bg-brand-700 text-white font-medium px-5 py-2.5 text-sm transition">Zapisz</button>
      <a href="/admin/clients" class="text-sm text-slate-500 hover:text-slate-700">Anuluj</a>
    </div>
  </form>

  <!-- Portal klienta -->
  <div class="mt-4 bg-white rounded-2xl border border-slate-200 p-5">
    <div class="text-sm font-medium text-slate-700 mb-2">Portal klienta (wszystkie jego projekty)</div>
    <% if (panel === 'sent') { %>
      <div class="mb-3 flex items-center gap-2 rounded-lg bg-green-50 border border-green-200 text-green-800 text-sm px-3 py-2"><%- icon('check', { size: 16, cls: 'text-green-600' }) %> Wysłano link panelu.</div>
    <% } else if (panel === 'invalid') { %>
      <div class="mb-3 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm px-3 py-2">Podaj poprawny adres e-mail (klient nie ma zapisanego e-maila).</div>
    <% } else if (panel === 'error') { %>
      <div class="mb-3 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm px-3 py-2">Nie udało się wysłać. Sprawdź SMTP.</div>
    <% } %>
    <div class="flex flex-col sm:flex-row gap-2">
      <input readonly value="<%= portalUrl %>" x-ref="purl" class="flex-1 min-w-0 rounded-lg border border-slate-300 bg-slate-50 px-3 py-2 text-sm text-slate-700" />
      <div class="flex gap-2">
        <button type="button" @click="navigator.clipboard.writeText($refs.purl.value); copied = true; setTimeout(()=>copied=false,1500)"
                class="flex-1 sm:flex-none rounded-lg bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium px-4 py-2 transition whitespace-nowrap">
          <span x-show="!copied">Kopiuj</span><span x-show="copied">Skopiowano ✓</span>
        </button>
        <button type="button" @click="send()" class="flex-1 sm:flex-none rounded-lg border border-slate-300 text-slate-700 hover:bg-slate-50 text-sm font-medium px-4 py-2 transition whitespace-nowrap">Wyślij</button>
        <a href="<%= portalUrl %>" target="_blank" class="flex-1 sm:flex-none text-center rounded-lg border border-slate-300 text-slate-600 hover:bg-slate-50 text-sm font-medium px-4 py-2 transition whitespace-nowrap">Otwórz</a>
      </div>
    </div>
    <% if (!mailReady) { %><p class="text-xs text-amber-600 mt-2">SMTP niewłączony — mail trafi do logów serwera.</p><% } %>
    <form method="POST" action="/admin/clients/<%= client.id %>/send-panel" x-ref="sendForm" class="hidden"><input type="hidden" name="email" x-ref="sendEmail" /></form>
  </div>

  <!-- Projekty klienta -->
  <div class="mt-4 bg-white rounded-2xl border border-slate-200 overflow-hidden">
    <div class="px-5 py-3 border-b border-slate-100 text-sm font-medium text-slate-700">Projekty (<%= client.projects.length %>)</div>
    <% if (!client.projects.length) { %>
      <div class="px-5 py-6 text-center text-sm text-slate-400">Brak przypisanych projektów. Przypisz klienta w edycji projektu.</div>
    <% } else { %>
      <div class="divide-y divide-slate-100">
        <% client.projects.forEach(function(p){ %>
          <a href="/admin/projects/<%= p.id %>" class="flex items-center justify-between px-5 py-2.5 text-sm hover:bg-slate-50 transition">
            <span class="text-slate-700"><%= p.name %></span>
            <span class="text-slate-400"><%= fmt.status(p.status) %></span>
          </a>
        <% }); %>
      </div>
    <% } %>
  </div>

  <form method="POST" action="/admin/clients/<%= client.id %>/delete" class="mt-4"
        onsubmit="return confirm('Usunąć klienta? Projekty zostaną, ale stracą przypisanie.');">
    <button type="submit" class="text-sm text-red-600 hover:text-red-700">Usuń klienta</button>
  </form>
</div>
