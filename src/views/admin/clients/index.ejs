<div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between mb-6">
  <form method="GET" action="/admin/clients" class="relative w-full sm:max-w-xs">
    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none"><%- icon('search', { size: 16 }) %></span>
    <input type="search" name="q" value="<%= q %>" placeholder="Szukaj klienta lub e-maila…" class="w-full rounded-lg border border-slate-300 pl-9 pr-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
  </form>
  <a href="/admin/clients/new" class="rounded-lg bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium px-4 py-2 transition self-start sm:self-auto shrink-0">+ Nowy klient</a>
</div>

<% if (!clients.length) { %>
  <div class="bg-white rounded-2xl border border-slate-200 p-10 text-center text-slate-500">
    <% if (q) { %>
      <p>Brak wyników dla „<%= q %>".</p>
    <% } else { %>
      <p class="mb-3">Brak klientów.</p>
      <a href="/admin/clients/new" class="text-brand-700 font-medium hover:underline">Dodaj pierwszego klienta →</a>
    <% } %>
  </div>
<% } else { %>
  <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
    <div class="overflow-x-auto">
    <table class="w-full text-sm min-w-[640px]">
      <thead class="bg-slate-50 text-slate-500 text-left">
        <tr>
          <th class="px-4 py-3 font-medium">Klient</th>
          <th class="px-4 py-3 font-medium">E-mail</th>
          <th class="px-4 py-3 font-medium">Projekty</th>
          <th class="px-4 py-3 font-medium">Portal klienta</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% clients.forEach(function(c){ %>
          <tr class="hover:bg-slate-50 cursor-pointer" onclick="window.location='/admin/clients/<%= c.id %>/edit'">
            <td class="px-4 py-3 font-medium text-slate-800"><%= c.name %></td>
            <td class="px-4 py-3 text-slate-500"><%= c.email || '—' %></td>
            <td class="px-4 py-3 text-slate-500"><%= c._count.projects %></td>
            <td class="px-4 py-3 text-slate-400"><a href="<%= appUrl %>/c/<%= c.token %>" target="_blank" @click.stop class="text-brand-700 hover:underline" onclick="event.stopPropagation()">/c/<%= c.token %></a></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
    </div>
  </div>
<% } %>
