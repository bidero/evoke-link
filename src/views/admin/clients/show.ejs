<div class="mb-5">
  <a href="/admin/clients" class="inline-flex items-center gap-1 text-sm text-slate-500 hover:text-slate-700"><%- icon('arrowLeft', { size: 15 }) %> Klienci</a>
</div>

<!-- Nagłówek klienta -->
<div class="bg-white rounded-2xl border border-slate-200 p-6 mb-5">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
    <div class="min-w-0">
      <h1 class="text-xl font-semibold text-slate-800"><%= client.name %></h1>
      <div class="mt-2 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-slate-500">
        <% if (client.email) { %><span class="inline-flex items-center gap-1.5"><%- icon('mail', { size: 14 }) %><a href="mailto:<%= client.email %>" class="hover:underline"><%= client.email %></a></span><% } %>
        <span class="inline-flex items-center gap-1.5"><%- icon('folder', { size: 14 }) %><%= client.projects.length %> projekt(ów)</span>
      </div>
      <% if (client.note) { %><p class="mt-3 text-sm text-slate-600 whitespace-pre-line"><%= client.note %></p><% } %>
    </div>
    <div class="flex flex-wrap items-center gap-2 shrink-0">
      <a href="/admin/projects/new?client=<%= client.id %>" class="rounded-lg bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium px-4 py-2 transition">+ Nowy projekt</a>
      <a href="/admin/clients/<%= client.id %>/edit" class="rounded-lg border border-slate-300 text-slate-700 hover:bg-slate-50 text-sm font-medium px-4 py-2 transition">Edytuj</a>
    </div>
  </div>
  <div class="mt-4 pt-4 border-t border-slate-100 text-sm">
    <span class="text-slate-500">Portal klienta:</span>
    <a href="<%= portalUrl %>" target="_blank" class="text-brand-700 hover:underline break-all"><%= portalUrl %></a>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
  <div class="lg:col-span-2 space-y-5">
    <!-- Projekty klienta -->
    <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
      <div class="px-5 py-3 border-b border-slate-100">
        <h2 class="text-sm font-medium text-slate-700">Projekty</h2>
      </div>
      <% if (!client.projects.length) { %>
        <div class="px-5 py-8 text-center text-sm text-slate-400">Brak projektów. <a href="/admin/projects/new?client=<%= client.id %>" class="text-brand-700 hover:underline">Utwórz pierwszy →</a></div>
      <% } else { %>
        <ul class="divide-y divide-slate-100">
          <% client.projects.forEach(function(p){ %>
            <li>
              <a href="/admin/projects/<%= p.id %>" class="flex items-center justify-between gap-3 px-5 py-3 hover:bg-slate-50 transition">
                <span class="min-w-0">
                  <span class="block text-sm font-medium text-slate-800 truncate"><%= p.name %></span>
                  <span class="block text-xs text-slate-400 mt-0.5"><%= p._count.transfers %> transfer(ów) · akt. <%= fmt.date(p.updatedAt) %></span>
                </span>
                <% if (p.status === 'archived') { %><span class="text-xs px-2 py-0.5 rounded-full bg-slate-100 text-slate-500 shrink-0">archiwum</span><% } else { %><span class="text-xs px-2 py-0.5 rounded-full bg-green-50 text-green-700 shrink-0">aktywny</span><% } %>
              </a>
            </li>
          <% }); %>
        </ul>
      <% } %>
    </div>

    <!-- Ostatnie transfery -->
    <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
      <div class="px-5 py-3 border-b border-slate-100">
        <h2 class="text-sm font-medium text-slate-700">Ostatnie transfery</h2>
      </div>
      <% if (!transfers.length) { %>
        <div class="px-5 py-8 text-center text-sm text-slate-400">Brak transferów.</div>
      <% } else { %>
        <ul class="divide-y divide-slate-100">
          <% transfers.forEach(function(t){ %>
            <li>
              <a href="/admin/transfers/<%= t.id %>" class="flex items-center gap-3 px-5 py-3 hover:bg-slate-50 transition">
                <span class="shrink-0"><% if (t.direction === 'incoming') { %><%- icon('download', { size: 15, cls: 'text-sky-600' }) %><% } else { %><%- icon('upload', { size: 15 }) %><% } %></span>
                <span class="min-w-0 flex-1">
                  <span class="block text-sm text-slate-700 truncate"><%= t.title || ('Transfer ' + t.token) %></span>
                  <span class="block text-xs text-slate-400 mt-0.5"><%= t.files.length %> plików<%= t.project ? ' · ' + t.project.name : '' %> · <%= fmt.date(t.createdAt) %></span>
                </span>
              </a>
            </li>
          <% }); %>
        </ul>
      <% } %>
    </div>
  </div>

  <!-- Oś czasu aktywności -->
  <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden self-start">
    <div class="px-5 py-3 border-b border-slate-100">
      <h2 class="text-sm font-medium text-slate-700">Oś czasu</h2>
    </div>
    <% if (!events.length) { %>
      <div class="px-5 py-8 text-center text-sm text-slate-400">Brak aktywności.</div>
    <% } else { %>
      <ul class="divide-y divide-slate-100">
        <% events.forEach(function(e){ %>
          <li class="px-5 py-3 flex gap-3 items-start">
            <span class="mt-0.5"><%- eventIcon(e.type) %></span>
            <span class="min-w-0 flex-1">
              <span class="block text-sm text-slate-700"><%= e.message || e.type %></span>
              <span class="block text-xs text-slate-400 mt-0.5"><%= fmt.date(e.createdAt) %><%= e.project ? ' · ' + e.project.name : '' %></span>
            </span>
          </li>
        <% }); %>
      </ul>
    <% } %>
  </div>
</div>
