<div class="mb-5">
  <a href="/admin/clients" class="inline-flex items-center gap-1 text-sm text-slate-500 hover:text-slate-700"><%- icon('arrowLeft', { size: 15 }) %> Klienci</a>
</div>

<% if (sent === 'ok') { %>
  <div class="mb-4 flex items-center gap-2 rounded-lg bg-green-50 border border-green-200 text-green-800 text-sm px-3 py-2"><%- icon('check', { size: 16, cls: 'text-green-600' }) %> Wysłano link panelu klienta.</div>
<% } else if (sent === 'dev') { %>
  <div class="mb-4 rounded-lg bg-amber-50 border border-amber-200 text-amber-800 text-sm px-3 py-2">SMTP niewłączony — link panelu trafił do logów serwera (tryb deweloperski).</div>
<% } else if (sent === 'invalid') { %>
  <div class="mb-4 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm px-3 py-2">Klient nie ma poprawnego adresu e-mail.</div>
<% } else if (sent === 'error') { %>
  <div class="mb-4 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm px-3 py-2">Nie udało się wysłać. Sprawdź ustawienia SMTP.</div>
<% } else if (sent === 'stmt-ok') { %>
  <div class="mb-4 flex items-center gap-2 rounded-lg bg-green-50 border border-green-200 text-green-800 text-sm px-3 py-2"><%- icon('check', { size: 16, cls: 'text-green-600' }) %> Wysłano rozliczenie do klienta.</div>
<% } else if (sent === 'stmt-dev') { %>
  <div class="mb-4 rounded-lg bg-amber-50 border border-amber-200 text-amber-800 text-sm px-3 py-2">SMTP niewłączony — rozliczenie trafiło do logów serwera (tryb deweloperski).</div>
<% } else if (sent === 'stmt-noemail') { %>
  <div class="mb-4 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm px-3 py-2">Klient nie ma adresu e-mail — uzupełnij go w edycji.</div>
<% } else if (sent === 'stmt-error') { %>
  <div class="mb-4 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm px-3 py-2">Nie udało się wysłać rozliczenia. Sprawdź ustawienia SMTP.</div>
<% } else if (sent === 'has-charges') { %>
  <div class="mb-4 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm px-3 py-2">Nie można usunąć klienta — ma pozycje rozliczeniowe „bez projektu". Usuń je najpierw (zakładka „Rozliczenia").</div>
<% } else if (sent === 'onb-new') { %>
  <div class="mb-4 flex items-center gap-2 rounded-lg bg-green-50 border border-green-200 text-green-800 text-sm px-3 py-2"><%- icon('check', { size: 16, cls: 'text-green-600' }) %> Utworzono link onboardingowy.</div>
<% } else if (sent === 'onb-ok') { %>
  <div class="mb-4 flex items-center gap-2 rounded-lg bg-green-50 border border-green-200 text-green-800 text-sm px-3 py-2"><%- icon('check', { size: 16, cls: 'text-green-600' }) %> Wysłano link onboardingowy.</div>
<% } else if (sent === 'onb-dev') { %>
  <div class="mb-4 rounded-lg bg-amber-50 border border-amber-200 text-amber-800 text-sm px-3 py-2">SMTP niewłączony — link onboardingowy trafił do logów serwera (tryb deweloperski).</div>
<% } else if (sent === 'onb-nolink') { %>
  <div class="mb-4 rounded-lg bg-amber-50 border border-amber-200 text-amber-800 text-sm px-3 py-2">Najpierw wygeneruj link onboardingowy.</div>
<% } else if (sent === 'onb-invalid') { %>
  <div class="mb-4 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm px-3 py-2">Klient nie ma poprawnego adresu e-mail.</div>
<% } else if (sent === 'onb-error') { %>
  <div class="mb-4 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm px-3 py-2">Nie udało się wysłać. Sprawdź ustawienia SMTP.</div>
<% } else if (sent === 'ret-new') { %>
  <div class="mb-4 flex items-center gap-2 rounded-lg bg-green-50 border border-green-200 text-green-800 text-sm px-3 py-2"><%- icon('check', { size: 16, cls: 'text-green-600' }) %> Dodano cykliczną pozycję. Pierwsza pozycja wygeneruje się w dniu generowania (albo przyciskiem „Generuj teraz").</div>
<% } else if (sent === 'ret-gen') { %>
  <div class="mb-4 flex items-center gap-2 rounded-lg bg-green-50 border border-green-200 text-green-800 text-sm px-3 py-2"><%- icon('check', { size: 16, cls: 'text-green-600' }) %> Wygenerowano pozycję rozliczeniową za bieżący miesiąc.</div>
<% } else if (sent === 'ret-dup') { %>
  <div class="mb-4 rounded-lg bg-amber-50 border border-amber-200 text-amber-800 text-sm px-3 py-2">Pozycja za ten miesiąc już istnieje — kolejna wygeneruje się w przyszłym miesiącu.</div>
<% } else if (sent === 'ret-del') { %>
  <div class="mb-4 rounded-lg bg-green-50 border border-green-200 text-green-800 text-sm px-3 py-2">Usunięto cykliczną pozycję (wygenerowane wcześniej pozycje zostały).</div>
<% } else if (sent === 'ret-invalid') { %>
  <div class="mb-4 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm px-3 py-2">Podaj nazwę i kwotę cyklicznej pozycji.</div>
<% } else if (sent === 'off-new') { %>
  <div class="mb-4 flex items-center gap-2 rounded-lg bg-green-50 border border-green-200 text-green-800 text-sm px-3 py-2"><%- icon('check', { size: 16, cls: 'text-green-600' }) %> Utworzono ofertę. Wyślij ją klientowi (link/mail).</div>
<% } else if (sent === 'off-ok') { %>
  <div class="mb-4 flex items-center gap-2 rounded-lg bg-green-50 border border-green-200 text-green-800 text-sm px-3 py-2"><%- icon('check', { size: 16, cls: 'text-green-600' }) %> Wysłano ofertę mailem.</div>
<% } else if (sent === 'off-dev') { %>
  <div class="mb-4 rounded-lg bg-amber-50 border border-amber-200 text-amber-800 text-sm px-3 py-2">SMTP niewłączony — oferta trafiła do logów serwera (tryb deweloperski).</div>
<% } else if (sent === 'off-noemail') { %>
  <div class="mb-4 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm px-3 py-2">Klient nie ma adresu e-mail — uzupełnij go albo wyślij link ręcznie.</div>
<% } else if (sent === 'off-del') { %>
  <div class="mb-4 rounded-lg bg-green-50 border border-green-200 text-green-800 text-sm px-3 py-2">Usunięto ofertę.</div>
<% } else if (sent === 'off-invalid') { %>
  <div class="mb-4 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm px-3 py-2">Podaj tytuł oferty i co najmniej jedną pozycję.</div>
<% } else if (sent === 'off-error') { %>
  <div class="mb-4 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm px-3 py-2">Nie udało się wysłać oferty. Sprawdź ustawienia SMTP.</div>
<% } %>

<!-- Nagłówek klienta (stały nad zakładkami) -->
<div class="bg-white rounded-2xl border border-slate-200 p-6 mb-5">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
    <div class="min-w-0">
      <div class="flex items-center gap-2 flex-wrap">
        <h1 class="text-xl font-semibold text-slate-800"><%= client.name %></h1>
        <% const _statusMap = { lead: ['Lead', 'bg-amber-50 text-amber-700'], active: ['Aktywny', 'bg-green-50 text-green-700'], inactive: ['Nieaktywny', 'bg-slate-100 text-slate-500'] }; const _s = _statusMap[client.status] || _statusMap.active; %>
        <span class="text-xs px-2 py-0.5 rounded-full <%= _s[1] %>"><%= _s[0] %></span>
      </div>
      <% if (client.company) { %><p class="text-sm text-slate-500 mt-0.5"><%= client.company %></p><% } %>
      <div class="mt-2 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-slate-500">
        <% if (client.email) { %><span class="inline-flex items-center gap-1.5"><%- icon('mail', { size: 14 }) %><a href="mailto:<%= client.email %>" class="hover:underline"><%= client.email %></a></span><% } %>
        <% if (client.phone) { %><span class="inline-flex items-center gap-1.5">tel. <a href="tel:<%= client.phone.replace(/\s/g, '') %>" class="hover:underline"><%= client.phone %></a></span><% } %>
        <span class="inline-flex items-center gap-1.5"><%- icon('folder', { size: 14 }) %><%= client.projects.length %> projekt(ów)</span>
      </div>
      <% if (client.tags) { %>
        <div class="mt-3 flex flex-wrap gap-1.5">
          <% client.tags.split(',').map(function(t){ return t.trim(); }).filter(Boolean).forEach(function(tag){ %>
            <a href="/admin/clients?q=<%= encodeURIComponent(tag) %>" class="text-xs px-2 py-0.5 rounded-full bg-brand-50 text-brand-700 hover:bg-brand-100 transition" title="Pokaż klientów z tym tagiem"><%= tag %></a>
          <% }); %>
        </div>
      <% } %>
      <% if (client.note) { %><p class="mt-3 text-sm text-slate-600 whitespace-pre-line"><%= client.note %></p><% } %>
    </div>
    <div class="flex flex-wrap items-center gap-2 shrink-0">
      <a href="/admin/projects/new?client=<%= client.id %>" class="rounded-lg bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium px-4 py-2 transition">+ Nowy projekt</a>
      <a href="/admin/clients/<%= client.id %>/edit" class="rounded-lg border border-slate-300 text-slate-700 hover:bg-slate-50 text-sm font-medium px-4 py-2 transition">Edytuj</a>
    </div>
  </div>
  <div class="mt-4 pt-4 border-t border-slate-100 flex flex-col sm:flex-row sm:items-center gap-3">
    <div class="text-sm min-w-0 flex-1">
      <span class="text-slate-500">Portal klienta:</span>
      <a href="<%= portalUrl %>" target="_blank" class="text-brand-700 hover:underline break-all"><%= portalUrl %></a>
    </div>
    <% if (client.email) { %>
      <form method="POST" action="/admin/clients/<%= client.id %>/send-panel" class="shrink-0 sm:ml-auto">
        <input type="hidden" name="redirect" value="show" />
        <button type="submit" title="Wyślij link panelu na <%= client.email %>" class="inline-flex items-center gap-1.5 rounded-lg border border-slate-300 text-slate-600 hover:bg-brand-50 hover:text-brand-700 hover:border-brand-200 text-sm font-medium px-4 py-2 transition"><%- icon('mail', { size: 15 }) %> Wyślij</button>
      </form>
    <% } %>
  </div>

  <!-- Onboarding — jednorazowy link, przez który klient sam uzupełnia dane -->
  <div class="mt-3 pt-3 border-t border-slate-100" x-data="{ copied: false, qr: false }">
    <% const _btnCls = 'inline-flex items-center gap-1.5 rounded-lg border border-slate-300 text-slate-600 hover:bg-brand-50 hover:text-brand-700 hover:border-brand-200 text-sm font-medium px-4 py-2 transition'; %>
    <% if (onboarding === 'none') { %>
      <div class="flex flex-col sm:flex-row sm:items-center gap-3">
        <div class="text-sm flex-1"><span class="text-slate-500">Onboarding:</span> <span class="text-slate-400">klient może sam uzupełnić swoje dane (firma, NIP, adres, kontakt).</span></div>
        <form method="POST" action="/admin/clients/<%= client.id %>/onboarding" class="shrink-0 sm:ml-auto">
          <button type="submit" class="<%= _btnCls %>"><%- icon('userCheck', { size: 15 }) %> Utwórz link onboardingowy</button>
        </form>
      </div>
    <% } else { %>
      <div class="flex flex-col sm:flex-row sm:items-center gap-3">
        <div class="text-sm min-w-0 flex-1">
          <span class="text-slate-500">Onboarding:</span>
          <% if (onboarding === 'active') { %>
            <span class="text-xs px-2 py-0.5 rounded-full bg-green-50 text-green-700">aktywny do <%= fmt.dateOnly(client.onboardingExpiresAt) %></span>
            <a href="<%= onboardUrl %>" target="_blank" class="text-brand-700 hover:underline break-all ml-1"><%= onboardUrl %></a>
          <% } else if (onboarding === 'expired') { %>
            <span class="text-xs px-2 py-0.5 rounded-full bg-amber-50 text-amber-700">wygasł <%= fmt.dateOnly(client.onboardingExpiresAt) %></span>
          <% } else { %>
            <span class="inline-flex items-center gap-1 text-xs px-2 py-0.5 rounded-full bg-green-50 text-green-700"><%- icon('check', { size: 13, cls: 'text-green-600' }) %> wypełniony <%= fmt.dateOnly(client.onboardingCompletedAt) %></span>
          <% } %>
        </div>
        <div class="flex flex-wrap gap-2 shrink-0 sm:ml-auto">
          <% if (onboarding === 'active') { %>
            <input type="hidden" x-ref="ourl" value="<%= onboardUrl %>" />
            <button type="button" @click="navigator.clipboard.writeText($refs.ourl.value); copied = true; setTimeout(()=>copied=false,1500)" class="<%= _btnCls %>">
              <span x-show="!copied"><%- icon('copy', { size: 15 }) %> Kopiuj</span><span x-show="copied" x-cloak>Skopiowano ✓</span>
            </button>
            <button type="button" @click="qr = !qr" class="<%= _btnCls %>" x-text="qr ? 'Ukryj QR' : 'Kod QR'"></button>
            <% if (client.email) { %>
              <form method="POST" action="/admin/clients/<%= client.id %>/onboarding/send">
                <button type="submit" title="Wyślij link onboardingowy na <%= client.email %>" class="<%= _btnCls %>"><%- icon('mail', { size: 15 }) %> Wyślij mailem</button>
              </form>
            <% } %>
            <form method="POST" action="/admin/clients/<%= client.id %>/onboarding" onsubmit="return confirm('Wygenerować nowy link? Obecny przestanie działać.')">
              <button type="submit" class="<%= _btnCls %>">Wygeneruj nowy</button>
            </form>
          <% } else { %>
            <form method="POST" action="/admin/clients/<%= client.id %>/onboarding" <% if (onboarding === 'completed') { %>onsubmit="return confirm('Klient wypełnił już formularz. Wygenerować nowy link?')"<% } %>>
              <button type="submit" class="<%= _btnCls %>">Wygeneruj nowy</button>
            </form>
          <% } %>
        </div>
      </div>
      <% if (onboarding === 'active') { %>
        <div x-show="qr" x-cloak class="mt-2">
          <span class="inline-block rounded-xl border border-slate-200 bg-white p-2 shadow-sm"><%- qrSvg(onboardUrl, { cell: 3 }) %></span>
        </div>
      <% } %>
    <% } %>
  </div>
</div>

<!-- Zakładki -->
<div x-data="{ tab: '<%= activeTab %>' }" x-init="$watch('tab', function(v){ history.replaceState(null, '', '?tab=' + v); })" x-cloak>
  <div class="border-b border-slate-200 flex flex-wrap">
    <% [['przeglad','Przegląd'],['projekty','Projekty'],['rozliczenia','Rozliczenia'],['oferty','Oferty'],['transfery','Transfery'],['historia','Oś czasu']].forEach(function(t){ %>
      <button type="button" @click="tab='<%= t[0] %>'" class="px-4 py-2.5 text-sm font-medium border-b-2 -mb-px transition" :class="tab==='<%= t[0] %>' ? 'border-brand-600 text-brand-700' : 'border-transparent text-slate-500 hover:text-slate-700'"><%= t[1] %></button>
    <% }); %>
  </div>

  <div class="pt-5">

    <!-- ===== Przegląd ===== -->
    <div x-show="tab==='przeglad'" class="space-y-5">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
        <div class="bg-white rounded-2xl border border-slate-200 p-4">
          <div class="text-xs text-slate-400">Projekty</div>
          <div class="text-2xl font-semibold text-slate-800 mt-1"><%= client.projects.length %></div>
        </div>
        <div class="bg-white rounded-2xl border border-slate-200 p-4">
          <div class="text-xs text-slate-400">Do rozliczenia</div>
          <div class="text-2xl font-semibold mt-1 <%= billing.outstanding > 0 ? 'text-amber-600' : 'text-green-600' %>"><%= fmt.money(billing.outstanding) %></div>
        </div>
        <div class="bg-white rounded-2xl border border-slate-200 p-4">
          <div class="text-xs text-slate-400">Pozycje</div>
          <div class="text-2xl font-semibold text-slate-800 mt-1"><%= charges.length %></div>
        </div>
        <div class="bg-white rounded-2xl border border-slate-200 p-4">
          <div class="text-xs text-slate-400">Ostatni transfer</div>
          <div class="text-2xl font-semibold text-slate-800 mt-1"><%= transfers.length ? fmt.date(transfers[0].createdAt) : '—' %></div>
        </div>
      </div>

      <!-- Statystyki klienta: LTV, śr. czas płatności, wykres przychodu 12 mies. -->
      <div class="bg-white rounded-2xl border border-slate-200 p-5">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <div class="text-xs text-slate-400 inline-flex items-center gap-1.5"><%- icon('trendingUp', { size: 14, cls: 'text-slate-400' }) %> Wartość klienta (LTV)</div>
            <div class="text-2xl font-semibold text-slate-800 mt-1"><%= fmt.money(metrics.ltv) %></div>
            <div class="text-xs text-slate-400 mt-0.5">zapłacone brutto · <%= metrics.paidCount %> poz.</div>
          </div>
          <div>
            <div class="text-xs text-slate-400 inline-flex items-center gap-1.5"><%- icon('clock', { size: 14, cls: 'text-slate-400' }) %> Śr. czas płatności</div>
            <div class="text-2xl font-semibold text-slate-800 mt-1"><%= metrics.avgPayDays === null ? '—' : metrics.avgPayDays + ' dni' %></div>
            <div class="text-xs text-slate-400 mt-0.5">od wystawienia do zapłaty</div>
          </div>
        </div>
        <div class="mt-4 pt-4 border-t border-slate-100">
          <div class="text-xs font-medium text-slate-500 mb-2">Przychód (zapłacone) — 12 miesięcy</div>
          <% if (metrics.ltv === 0) { %>
            <div class="py-4 text-center text-xs text-slate-400">Brak zapłaconych pozycji — wykres pojawi się po pierwszej wpłacie.</div>
          <% } else { %>
            <% const CW = 480, CH = 80, N = 12, GAP = 6, BW = (CW - (N - 1) * GAP) / N, TOP = 16; %>
            <svg viewBox="0 0 <%= CW %> <%= TOP + CH + 20 %>" class="w-full" role="img" aria-label="Wykres przychodu klienta z 12 miesięcy">
              <% metrics.chart.forEach(function(c, i){
                   const h = c.value > 0 ? Math.max(3, Math.round((c.value / metrics.chartMax) * CH)) : 0;
                   const x = i * (BW + GAP);
                   const y = TOP + (CH - h); %>
                <% if (h > 0) { %><rect x="<%= x %>" y="<%= y %>" width="<%= BW %>" height="<%= h %>" rx="3" class="<%= c.current ? 'fill-brand-600' : 'fill-brand-200' %>" /><% } %>
                <text x="<%= x + BW / 2 %>" y="<%= TOP + CH + 14 %>" text-anchor="middle" class="<%= c.current ? 'fill-brand-700' : 'fill-slate-400' %>" font-size="9" font-weight="<%= c.current ? '600' : '400' %>"><%= c.label %></text>
              <% }); %>
            </svg>
          <% } %>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
        <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
          <div class="px-5 py-3 border-b border-slate-100 flex items-center justify-between">
            <h2 class="text-sm font-medium text-slate-700">Ostatnie transfery</h2>
            <% if (transfers.length > 3) { %><button type="button" @click="tab='transfery'" class="text-xs text-brand-700 hover:underline">Wszystkie →</button><% } %>
          </div>
          <% if (!transfers.length) { %>
            <div class="px-5 py-8 text-center text-sm text-slate-400">Brak transferów.</div>
          <% } else { %>
            <ul class="divide-y divide-slate-100">
              <% transfers.slice(0,3).forEach(function(t){ %>
                <li>
                  <a href="/admin/transfers/<%= t.id %>" class="flex items-center gap-3 px-5 py-3 hover:bg-slate-50 transition">
                    <span class="shrink-0"><% if (t.direction === 'incoming') { %><%- icon('download', { size: 15, cls: 'text-sky-600' }) %><% } else { %><%- icon('upload', { size: 15 }) %><% } %></span>
                    <span class="min-w-0 flex-1">
                      <span class="block text-sm text-slate-700 truncate"><%= t.title || ('Transfer ' + t.token) %></span>
                      <span class="block text-xs text-slate-400 mt-0.5"><%= t.files.length %> plików<%= t.project ? ' · ' + t.project.name : '' %> · <%= fmt.date(t.createdAt) %></span>
                    </span>
                  </a>
                </li>
              <% }); %>
            </ul>
          <% } %>
        </div>

        <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
          <div class="px-5 py-3 border-b border-slate-100 flex items-center justify-between">
            <h2 class="text-sm font-medium text-slate-700">Ostatnia aktywność</h2>
            <% if (events.length > 3) { %><button type="button" @click="tab='historia'" class="text-xs text-brand-700 hover:underline">Cała oś czasu →</button><% } %>
          </div>
          <% if (!events.length) { %>
            <div class="px-5 py-8 text-center text-sm text-slate-400">Brak aktywności.</div>
          <% } else { %>
            <ul class="divide-y divide-slate-100">
              <% events.slice(0,3).forEach(function(e){ %>
                <li class="px-5 py-3 flex gap-3 items-start">
                  <span class="mt-0.5"><%- eventIcon(e.type) %></span>
                  <span class="min-w-0 flex-1">
                    <span class="block text-sm text-slate-700"><%= e.message || e.type %></span>
                    <span class="block text-xs text-slate-400 mt-0.5"><%= fmt.date(e.createdAt) %><%= e.project ? ' · ' + e.project.name : '' %></span>
                  </span>
                </li>
              <% }); %>
            </ul>
          <% } %>
        </div>
      </div>
    </div>

    <!-- ===== Projekty ===== -->
    <div x-show="tab==='projekty'">
      <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
        <div class="px-5 py-3 border-b border-slate-100 flex items-center justify-between">
          <h2 class="text-sm font-medium text-slate-700">Projekty</h2>
          <a href="/admin/projects/new?client=<%= client.id %>" class="text-xs text-brand-700 hover:underline">+ Nowy projekt</a>
        </div>
        <% if (!client.projects.length) { %>
          <div class="px-5 py-8 text-center text-sm text-slate-400">Brak projektów. <a href="/admin/projects/new?client=<%= client.id %>" class="text-brand-700 hover:underline">Utwórz pierwszy →</a></div>
        <% } else { %>
          <ul class="divide-y divide-slate-100">
            <% client.projects.forEach(function(p){ %>
              <li>
                <a href="/admin/projects/<%= p.id %>" class="flex items-center justify-between gap-3 px-5 py-3 hover:bg-slate-50 transition">
                  <span class="min-w-0">
                    <span class="block text-sm font-medium text-slate-800 truncate"><%= p.name %></span>
                    <span class="block text-xs text-slate-400 mt-0.5"><%= p._count.transfers %> transfer(ów) · akt. <%= fmt.date(p.updatedAt) %></span>
                  </span>
                  <% if (p.status === 'archived') { %><span class="text-xs px-2 py-0.5 rounded-full bg-slate-100 text-slate-500 shrink-0">archiwum</span><% } else { %><span class="text-xs px-2 py-0.5 rounded-full bg-green-50 text-green-700 shrink-0">aktywny</span><% } %>
                </a>
              </li>
            <% }); %>
          </ul>
        <% } %>
      </div>
    </div>

    <!-- ===== Rozliczenia ===== -->
    <div x-show="tab==='rozliczenia'" id="rozliczenia" class="space-y-5">
      <!-- Retainery — cykliczne pozycje (cron generuje z nich zwykłe pozycje poniżej) -->
      <%
        const _retGross = (r) => r.amount + (r.vatRate ? Math.round(r.amount * r.vatRate / 100) : 0);
        const _retMrr = retainers.filter(function(r){ return r.active; }).reduce(function(s, r){ return s + _retGross(r); }, 0);
        const _period = (function(d){ return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0'); })(new Date());
      %>
      <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
        <div class="px-5 py-3 border-b border-slate-100 flex flex-wrap items-center justify-between gap-x-3 gap-y-1">
          <h2 class="text-sm font-medium text-slate-700">Cykliczne (retainery)</h2>
          <% if (_retMrr > 0) { %>
            <div class="text-xs text-slate-400">Miesięcznie <span class="text-slate-600 font-medium"><%= fmt.money(_retMrr) %></span> brutto</div>
          <% } %>
        </div>
        <% if (retainers.length) { %>
          <div class="divide-y divide-slate-100">
            <% retainers.forEach(function(r){ %>
              <div class="flex flex-col sm:flex-row sm:items-center gap-2 px-5 py-2.5 text-sm">
                <span class="min-w-0 flex-1">
                  <span class="text-slate-700 <%= r.active ? '' : 'line-through opacity-60' %>"><%= r.label %></span>
                  <span class="block text-xs text-slate-400 mt-0.5">
                    dzień <%= r.dayOfMonth %> · termin +<%= r.dueDays %> dni ·
                    <%= r.lastPeriod === _period ? 'wygenerowano w tym miesiącu ✓' : (r.lastPeriod ? 'ostatnio: ' + r.lastPeriod : 'jeszcze nie generowano') %>
                  </span>
                </span>
                <span class="shrink-0 text-right">
                  <span class="font-medium text-slate-800"><%= fmt.money(_retGross(r)) %></span><span class="text-xs text-slate-400">/mc</span>
                  <% if (r.vatRate) { %><span class="block text-xs text-slate-400"><%= fmt.money(r.amount) %> + <%= r.vatRate %>% VAT</span><% } %>
                </span>
                <span class="shrink-0 flex items-center gap-1.5 sm:ml-3">
                  <% if (!r.active) { %>
                    <span class="text-xs px-2 py-0.5 rounded-full bg-slate-100 text-slate-500">wstrzymany</span>
                  <% } else if (r.lastPeriod !== _period) { %>
                    <form method="POST" action="/admin/clients/<%= client.id %>/retainers/<%= r.id %>/generate">
                      <button type="submit" class="text-xs px-2.5 py-1 rounded-full border border-slate-300 text-slate-600 hover:bg-brand-50 hover:text-brand-700 hover:border-brand-200 transition" title="Utwórz pozycję za bieżący miesiąc od razu">Generuj teraz</button>
                    </form>
                  <% } %>
                  <form method="POST" action="/admin/clients/<%= client.id %>/retainers/<%= r.id %>/toggle">
                    <button type="submit" class="text-xs px-2.5 py-1 rounded-full border border-slate-300 text-slate-600 hover:bg-slate-50 transition"><%= r.active ? 'Wstrzymaj' : 'Wznów' %></button>
                  </form>
                  <form method="POST" action="/admin/clients/<%= client.id %>/retainers/<%= r.id %>/delete" onsubmit="return confirm('Usunąć cykliczną pozycję? Wygenerowane wcześniej pozycje zostaną.')">
                    <button type="submit" class="text-slate-400 hover:text-red-600 transition" title="Usuń"><%- icon('trash', { size: 15, cls: '' }) %></button>
                  </form>
                </span>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <div class="px-5 py-4 text-center text-xs text-slate-400">Brak cyklicznych pozycji. Dodaj abonament poniżej — co miesiąc sam utworzy pozycję rozliczeniową z terminem płatności.</div>
        <% } %>
        <form method="POST" action="/admin/clients/<%= client.id %>/retainers" class="flex flex-col sm:flex-row sm:items-center gap-2 px-5 py-3 border-t border-slate-100 bg-slate-50">
          <input name="label" type="text" required placeholder="Nazwa (np. Abonament — obsługa www)" class="flex-1 min-w-0 rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
          <input name="amount" type="text" inputmode="decimal" required placeholder="Netto zł/mc" title="Kwota netto miesięcznie (zł)" class="shrink-0 w-24 rounded-lg border border-slate-300 px-2 py-2 text-sm text-right focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
          <select name="vatRate" title="Stawka VAT" class="shrink-0 w-[4.5rem] rounded-lg border border-slate-300 px-1.5 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none">
            <option value="">bez</option>
            <% [23,8,5,0].forEach(function(rr){ %><option value="<%= rr %>"><%= rr %>%</option><% }); %>
          </select>
          <label class="shrink-0 flex items-center gap-1.5 text-xs text-slate-500" title="Którego dnia miesiąca tworzyć pozycję (1–28)">dzień
            <input name="dayOfMonth" type="number" min="1" max="28" value="1" class="w-14 rounded-lg border border-slate-300 px-2 py-2 text-sm text-right focus:border-brand-500 outline-none" />
          </label>
          <label class="shrink-0 flex items-center gap-1.5 text-xs text-slate-500" title="Termin płatności: ile dni od wygenerowania">termin +
            <input name="dueDays" type="number" min="0" max="60" value="7" class="w-14 rounded-lg border border-slate-300 px-2 py-2 text-sm text-right focus:border-brand-500 outline-none" />
          </label>
          <button type="submit" class="shrink-0 rounded-lg bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium px-4 py-2 transition whitespace-nowrap">Dodaj</button>
        </form>
      </div>

      <!-- Pozycje (edytowalne) -->
      <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
        <div class="px-5 py-3 border-b border-slate-100 flex flex-wrap items-center justify-between gap-x-3 gap-y-1">
          <h2 class="text-sm font-medium text-slate-700">Pozycje rozliczeniowe</h2>
          <% if (billing.gross > 0) { %>
            <div class="text-xs text-slate-400">
              <% if (billing.vat > 0) { %>
                Netto <span class="text-slate-600 font-medium"><%= fmt.money(billing.net) %></span> ·
                VAT <span class="text-slate-600 font-medium"><%= fmt.money(billing.vat) %></span> ·
                Brutto <span class="text-slate-600 font-medium"><%= fmt.money(billing.gross) %></span> ·
              <% } else { %>
                Wartość <span class="text-slate-600 font-medium"><%= fmt.money(billing.gross) %></span> ·
              <% } %>
              Rozliczono <span class="text-slate-600 font-medium"><%= fmt.money(billing.paid) %></span> ·
              Pozostało <span class="font-semibold <%= billing.outstanding > 0 ? 'text-amber-600' : 'text-green-600' %>"><%= fmt.money(billing.outstanding) %></span>
            </div>
          <% } %>
        </div>

        <% if (charges.length) { %>
          <div class="divide-y divide-slate-100">
            <% let _gp = undefined; %>
            <% charges.forEach(function(ch){ const _pn = (ch.project && ch.project.name) || 'Bez projektu'; const _vat = ch.vatRate ? Math.round(ch.amount * ch.vatRate / 100) : 0; const _gross = ch.amount + _vat; %>
              <% if (_pn !== _gp) { _gp = _pn; %>
                <div class="px-5 py-1.5 bg-slate-50 text-xs font-medium text-slate-500"><%= _pn %></div>
              <% } %>
              <form method="POST" action="/admin/clients/<%= client.id %>/charges/<%= ch.id %>" class="flex flex-col sm:flex-row sm:items-center gap-2 px-5 py-2.5">
                <button type="submit" formaction="/admin/clients/<%= client.id %>/charges/<%= ch.id %>/toggle" title="<%= ch.paidAt ? 'Oznacz jako nierozliczone' : 'Oznacz jako rozliczone' %>" class="shrink-0 w-5 h-5 rounded border flex items-center justify-center transition <%= ch.paidAt ? 'bg-green-500 border-green-500 text-white' : 'border-slate-300 text-transparent hover:border-brand-400' %>"><%- icon('check', { size: 13, cls: '' }) %></button>
                <select name="projectId" title="Przypisanie do projektu" class="shrink-0 sm:w-40 rounded-lg border border-slate-300 px-2 py-1.5 text-sm focus:border-brand-500 outline-none">
                  <option value="">— bez projektu —</option>
                  <% client.projects.forEach(function(p){ %>
                    <option value="<%= p.id %>" <%= ch.projectId === p.id ? 'selected' : '' %>><%= p.name %></option>
                  <% }); %>
                </select>
                <input name="label" type="text" value="<%= ch.label || '' %>" placeholder="Nazwa pozycji" class="flex-1 min-w-0 rounded-lg border border-slate-300 px-3 py-1.5 text-sm focus:border-brand-500 outline-none <%= ch.paidAt ? 'text-slate-400' : '' %>" />
                <input name="date" type="date" value="<%= ch.date ? new Date(ch.date).toISOString().slice(0,10) : '' %>" title="Data pozycji" class="shrink-0 rounded-lg border border-slate-300 px-2 py-1.5 text-sm focus:border-brand-500 outline-none" />
                <% const _od = ch.dueDate && !ch.paidAt && new Date(ch.dueDate) < new Date(); %>
                <input name="dueDate" type="date" value="<%= ch.dueDate ? new Date(ch.dueDate).toISOString().slice(0,10) : '' %>" title="Termin płatności<%= _od ? ' — po terminie!' : '' %>" class="shrink-0 rounded-lg border px-2 py-1.5 text-sm outline-none <%= _od ? 'border-red-400 text-red-600' : 'border-slate-300 focus:border-brand-500' %>" />
                <% if (ch.paidAt) { %>
                  <input name="paidAt" type="date" value="<%= new Date(ch.paidAt).toISOString().slice(0,10) %>" onchange="this.form.submit()" title="Data rozliczenia" class="shrink-0 rounded-lg border border-green-300 text-green-700 bg-green-50 px-2 py-1.5 text-sm focus:border-green-500 outline-none" />
                <% } %>
                <input name="amount" type="text" inputmode="decimal" value="<%= (ch.amount/100).toFixed(2) %>" title="Kwota netto (zł)" class="shrink-0 w-20 rounded-lg border border-slate-300 px-2 py-1.5 text-sm text-right tabular-nums focus:border-brand-500 outline-none" />
                <select name="vatRate" title="Stawka VAT" class="shrink-0 w-[4.5rem] rounded-lg border border-slate-300 px-1.5 py-1.5 text-sm focus:border-brand-500 outline-none">
                  <option value="" <%= ch.vatRate == null ? 'selected' : '' %>>bez</option>
                  <% [23,8,5,0].forEach(function(r){ %><option value="<%= r %>" <%= ch.vatRate === r ? 'selected' : '' %>><%= r %>%</option><% }); %>
                </select>
                <span class="shrink-0 w-24 text-right text-xs tabular-nums <%= ch.vatRate != null ? 'text-slate-500' : 'text-transparent' %>" title="Brutto"><%= ch.vatRate != null ? 'brutto ' + fmt.money(_gross) : '' %></span>
                <button type="submit" title="Zapisz zmiany" class="shrink-0 rounded-lg border border-slate-300 text-slate-600 hover:bg-brand-50 hover:text-brand-700 hover:border-brand-200 px-3 py-1.5 text-sm font-medium transition">Zapisz</button>
                <button type="submit" formaction="/admin/clients/<%= client.id %>/charges/<%= ch.id %>/delete" onclick="return confirm('Usunąć pozycję rozliczeniową?')" title="Usuń pozycję" class="shrink-0 p-1.5 text-slate-300 hover:text-red-600 transition"><%- icon('trash', { size: 16 }) %></button>
              </form>
            <% }); %>
          </div>
        <% } else { %>
          <div class="px-5 py-6 text-center text-sm text-slate-400">Brak pozycji rozliczeniowych. Dodaj pierwszą poniżej.</div>
        <% } %>

        <form method="POST" action="/admin/clients/<%= client.id %>/charges" class="flex flex-col sm:flex-row sm:items-center gap-2 px-5 py-3 border-t border-slate-100 bg-slate-50">
          <span class="hidden sm:block shrink-0 w-5"></span>
          <select name="projectId" title="Przypisanie do projektu" class="shrink-0 sm:w-44 rounded-lg border border-slate-300 px-2 py-2 text-sm focus:border-brand-500 outline-none">
            <option value="">— bez projektu —</option>
            <% client.projects.forEach(function(p){ %>
              <option value="<%= p.id %>"><%= p.name %></option>
            <% }); %>
          </select>
          <input name="label" type="text" placeholder="Nazwa (np. Sesja, Zaliczka)" class="flex-1 min-w-0 rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
          <input name="date" type="date" value="<%= new Date().toISOString().slice(0,10) %>" title="Data pozycji" class="shrink-0 rounded-lg border border-slate-300 px-2 py-2 text-sm focus:border-brand-500 outline-none" />
          <input name="dueDate" type="date" title="Termin płatności (opcjonalnie)" class="shrink-0 rounded-lg border border-slate-300 px-2 py-2 text-sm focus:border-brand-500 outline-none" />
          <input name="amount" type="text" inputmode="decimal" required placeholder="Netto zł" title="Kwota netto (zł)" class="shrink-0 w-20 rounded-lg border border-slate-300 px-2 py-2 text-sm text-right focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
          <select name="vatRate" title="Stawka VAT" class="shrink-0 w-[4.5rem] rounded-lg border border-slate-300 px-1.5 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none">
            <option value="">bez</option>
            <% [23,8,5,0].forEach(function(r){ %><option value="<%= r %>"><%= r %>%</option><% }); %>
          </select>
          <button type="submit" class="shrink-0 rounded-lg bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium px-4 py-2 transition whitespace-nowrap">Dodaj</button>
        </form>
      </div>

      <!-- Wydruk / wysyłka PDF -->
      <% if (charges.length) { %>
      <div class="bg-white rounded-2xl border border-slate-200 p-5">
        <h2 class="text-sm font-medium text-slate-700 mb-3">Wydruk i wysyłka (PDF)</h2>
        <form method="GET" action="/admin/clients/<%= client.id %>/rozliczenie.pdf" target="_blank" class="space-y-3">
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
            <label class="block text-xs text-slate-500">Od<input type="date" name="from" class="mt-1 w-full rounded-lg border border-slate-300 px-2 py-1.5 text-sm focus:border-brand-500 outline-none" /></label>
            <label class="block text-xs text-slate-500">Do<input type="date" name="to" class="mt-1 w-full rounded-lg border border-slate-300 px-2 py-1.5 text-sm focus:border-brand-500 outline-none" /></label>
            <label class="block text-xs text-slate-500">Status
              <select name="status" class="mt-1 w-full rounded-lg border border-slate-300 px-2 py-1.5 text-sm focus:border-brand-500 outline-none">
                <option value="">Wszystkie</option>
                <option value="unpaid">Nierozliczone</option>
                <option value="paid">Rozliczone</option>
              </select>
            </label>
          </div>
          <div class="text-xs text-slate-500">Pozycje (odznacz, by pominąć):</div>
          <div class="max-h-56 overflow-y-auto rounded-lg border border-slate-100 divide-y divide-slate-100">
            <% let _cp = null; %>
            <% charges.forEach(function(ch){ const _pn = (ch.project && ch.project.name) || 'Bez projektu'; %>
              <% if (_pn !== _cp) { _cp = _pn; %>
                <div class="px-3 py-1.5 bg-slate-50 text-xs font-medium text-slate-500"><%= _pn %></div>
              <% } %>
              <label class="flex items-center gap-2 px-3 py-1.5">
                <input type="checkbox" name="ids" value="<%= ch.id %>" checked class="rounded border-slate-300 shrink-0" />
                <span class="text-xs text-slate-400 w-16 shrink-0"><%= fmt.dateOnly(ch.date) %></span>
                <span class="flex-1 min-w-0 truncate text-sm <%= ch.paidAt ? 'text-slate-400 line-through' : 'text-slate-700' %>"><%= ch.label || 'Pozycja' %></span>
                <span class="tabular-nums text-xs shrink-0 <%= ch.paidAt ? 'text-slate-400' : 'text-slate-700' %>"><%= fmt.money(ch.amount + (ch.vatRate ? Math.round(ch.amount * ch.vatRate / 100) : 0)) %></span>
              </label>
            <% }); %>
          </div>
          <div class="flex flex-col sm:flex-row gap-2">
            <button type="submit" class="flex-1 inline-flex items-center justify-center gap-1.5 rounded-lg border border-slate-300 text-slate-700 hover:bg-slate-50 text-sm font-medium px-4 py-2 transition"><%- icon('file', { size: 15 }) %> Pobierz PDF</button>
            <button type="submit" formaction="/admin/clients/<%= client.id %>/pozycje.csv" title="Eksport pozycji do CSV (księgowość)" class="flex-1 inline-flex items-center justify-center gap-1.5 rounded-lg border border-slate-300 text-slate-700 hover:bg-slate-50 text-sm font-medium px-4 py-2 transition"><%- icon('sheet', { size: 15 }) %> Pobierz CSV</button>
            <% if (client.email) { %>
              <button type="submit" formaction="/admin/clients/<%= client.id %>/rozliczenie/send" formmethod="post" formtarget="_self" title="Wyślij PDF na <%= client.email %>" class="flex-1 inline-flex items-center justify-center gap-1.5 rounded-lg bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium px-4 py-2 transition"><%- icon('mail', { size: 15, cls: '' }) %> Wyślij e-mailem</button>
            <% } %>
          </div>
        </form>
      </div>
      <% } %>
    </div>

    <!-- ===== Oferty ===== -->
    <div x-show="tab==='oferty'" id="oferty" class="space-y-5">
      <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
        <div class="px-5 py-3 border-b border-slate-100">
          <h2 class="text-sm font-medium text-slate-700">Oferty / wyceny</h2>
          <p class="text-xs text-slate-400 mt-0.5">Wyślij klientowi wycenę do akceptacji. Po „Akceptuję" pozycje trafiają do rozliczeń, a projekt (jeśli powiązany) rusza na kanbanie.</p>
        </div>
        <% if (offers.length) { %>
          <% const _offSt = { open: ['Oczekuje', 'bg-amber-50 text-amber-700'], accepted: ['Zaakceptowana', 'bg-green-50 text-green-700'], rejected: ['Odrzucona', 'bg-red-50 text-red-700'], expired: ['Wygasła', 'bg-slate-100 text-slate-500'] }; %>
          <div class="divide-y divide-slate-100">
            <% offers.forEach(function(o){ const _s = _offSt[o.st] || _offSt.open; const _url = offerBaseUrl + '/o/' + o.token; %>
              <div class="px-5 py-3" x-data="{ copied: false }">
                <div class="flex flex-wrap items-start justify-between gap-2">
                  <div class="min-w-0">
                    <div class="flex items-center gap-2 flex-wrap">
                      <span class="text-sm font-medium text-slate-800"><%= o.title %></span>
                      <span class="text-xs px-2 py-0.5 rounded-full <%= _s[1] %>"><%= _s[0] %></span>
                    </div>
                    <div class="text-xs text-slate-400 mt-0.5">
                      <%= o.items.length %> poz. · <span class="text-slate-600 font-medium"><%= fmt.money(o.gross) %></span> brutto<%= o.project ? ' · ' + o.project.name : '' %><%= o.validUntil ? ' · ważna do ' + fmt.dateOnly(o.validUntil) : '' %>
                    </div>
                    <% if (o.st === 'rejected' && o.decisionComment) { %><div class="text-xs text-amber-700 mt-1">Powód: <%= o.decisionComment %></div><% } %>
                    <% if (o.decidedAt) { %><div class="text-xs text-slate-400 mt-0.5"><%= o.st === 'accepted' ? 'Zaakceptowano' : 'Odrzucono' %> <%= fmt.date(o.decidedAt) %><%= o.decisionName ? ' · ' + o.decisionName : '' %></div><% } %>
                  </div>
                  <div class="flex flex-wrap items-center gap-1.5 shrink-0">
                    <input type="hidden" x-ref="ou<%= o.id %>" value="<%= _url %>" />
                    <button type="button" @click="navigator.clipboard.writeText($refs.ou<%= o.id %>.value); copied = true; setTimeout(()=>copied=false,1500)" class="text-xs px-2.5 py-1 rounded-full border border-slate-300 text-slate-600 hover:bg-brand-50 hover:text-brand-700 hover:border-brand-200 transition">
                      <span x-show="!copied">Kopiuj link</span><span x-show="copied" x-cloak>Skopiowano ✓</span>
                    </button>
                    <a href="<%= _url %>" target="_blank" class="text-xs px-2.5 py-1 rounded-full border border-slate-300 text-slate-600 hover:bg-slate-50 transition">Otwórz</a>
                    <% if (o.st === 'open' && client.email) { %>
                      <form method="POST" action="/admin/clients/<%= client.id %>/offers/<%= o.id %>/send">
                        <button type="submit" class="text-xs px-2.5 py-1 rounded-full border border-slate-300 text-slate-600 hover:bg-brand-50 hover:text-brand-700 hover:border-brand-200 transition">Wyślij mailem</button>
                      </form>
                    <% } %>
                    <form method="POST" action="/admin/clients/<%= client.id %>/offers/<%= o.id %>/delete" onsubmit="return confirm('Usunąć ofertę?<%= o.st === 'accepted' ? ' Utworzone z niej pozycje rozliczeniowe zostaną.' : '' %>')">
                      <button type="submit" class="text-slate-400 hover:text-red-600 transition" title="Usuń"><%- icon('trash', { size: 15, cls: '' }) %></button>
                    </form>
                  </div>
                </div>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <div class="px-5 py-6 text-center text-sm text-slate-400">Brak ofert. Utwórz pierwszą poniżej.</div>
        <% } %>
      </div>

      <!-- Nowa oferta -->
      <form method="POST" action="/admin/clients/<%= client.id %>/offers" class="bg-white rounded-2xl border border-slate-200 p-5 space-y-4">
        <h2 class="text-sm font-medium text-slate-700">Nowa oferta</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-slate-600 mb-1">Tytuł *</label>
            <input name="title" type="text" required placeholder="np. Projekt strony www" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
          </div>
          <div>
            <label class="block text-xs font-medium text-slate-600 mb-1">Projekt (opcjonalnie)</label>
            <select name="projectId" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 outline-none">
              <option value="">— bez projektu —</option>
              <% client.projects.forEach(function(p){ %><option value="<%= p.id %>"><%= p.name %></option><% }); %>
            </select>
          </div>
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-1">Wstęp / opis (opcjonalnie)</label>
          <textarea name="intro" rows="2" placeholder="Kilka zdań wprowadzenia dla klienta" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none"></textarea>
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-1">Pozycje — jedna na linię</label>
          <textarea name="itemsText" rows="4" spellcheck="false" required placeholder="Projekt graficzny | 3000 | 23&#10;Wdrożenie | 2500 | 23&#10;Sesja zdjęciowa | 800 | 23 | 2"
                    class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm font-mono focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none"></textarea>
          <p class="text-xs text-slate-400 mt-1">Format: <code>Etykieta | netto | VAT% | ilość</code> (VAT i ilość opcjonalne; netto w zł).</p>
        </div>
        <div class="max-w-xs">
          <label class="block text-xs font-medium text-slate-600 mb-1">Ważna do (opcjonalnie)</label>
          <input name="validUntil" type="date" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 outline-none" />
        </div>
        <button type="submit" class="rounded-lg bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium px-5 py-2.5 transition">Utwórz ofertę</button>
      </form>
    </div>

    <!-- ===== Transfery ===== -->
    <div x-show="tab==='transfery'">
      <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
        <div class="px-5 py-3 border-b border-slate-100">
          <h2 class="text-sm font-medium text-slate-700">Transfery</h2>
        </div>
        <% if (!transfers.length) { %>
          <div class="px-5 py-8 text-center text-sm text-slate-400">Brak transferów.</div>
        <% } else { %>
          <ul class="divide-y divide-slate-100">
            <% transfers.forEach(function(t){ %>
              <li>
                <a href="/admin/transfers/<%= t.id %>" class="flex items-center gap-3 px-5 py-3 hover:bg-slate-50 transition">
                  <span class="shrink-0"><% if (t.direction === 'incoming') { %><%- icon('download', { size: 15, cls: 'text-sky-600' }) %><% } else { %><%- icon('upload', { size: 15 }) %><% } %></span>
                  <span class="min-w-0 flex-1">
                    <span class="block text-sm text-slate-700 truncate"><%= t.title || ('Transfer ' + t.token) %></span>
                    <span class="block text-xs text-slate-400 mt-0.5"><%= t.files.length %> plików<%= t.project ? ' · ' + t.project.name : '' %> · <%= fmt.date(t.createdAt) %></span>
                  </span>
                </a>
              </li>
            <% }); %>
          </ul>
        <% } %>
      </div>
    </div>

    <!-- ===== Oś czasu ===== -->
    <div x-show="tab==='historia'">
      <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
        <div class="px-5 py-3 border-b border-slate-100">
          <h2 class="text-sm font-medium text-slate-700">Oś czasu</h2>
        </div>
        <form method="POST" action="/admin/clients/<%= client.id %>/note" class="px-5 py-3 border-b border-slate-100">
          <div class="flex flex-col sm:flex-row gap-2">
            <select name="kind" title="Rodzaj interakcji" class="shrink-0 sm:w-36 rounded-lg border border-slate-300 px-2 py-2 text-sm focus:border-brand-500 outline-none">
              <option value="note">Notatka</option>
              <option value="call">Telefon</option>
              <option value="meeting">Spotkanie</option>
              <option value="email">E-mail</option>
            </select>
            <textarea name="note" rows="2" required placeholder="Co ustaliliście?…" class="flex-1 rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none"></textarea>
          </div>
          <div class="mt-2 flex flex-wrap items-center justify-between gap-3">
            <label class="inline-flex items-center gap-1.5 text-xs text-slate-500" title="Utworzy przypomnienie „Follow-up" w kalendarzu (puste = bez przypomnienia)">
              follow-up za
              <input name="followupDays" type="number" min="1" max="365" placeholder="—" class="w-16 rounded-lg border border-slate-300 px-2 py-1.5 text-sm text-right focus:border-brand-500 outline-none" />
              dni
            </label>
            <button type="submit" class="inline-flex items-center gap-1.5 rounded-lg bg-brand-600 hover:bg-brand-700 text-white text-xs font-medium px-3 py-1.5 transition"><%- icon('pencil', { size: 13, cls: '' }) %> Dodaj</button>
          </div>
        </form>
        <% if (!events.length) { %>
          <div class="px-5 py-8 text-center text-sm text-slate-400">Brak aktywności.</div>
        <% } else { %>
          <ul class="divide-y divide-slate-100">
            <% events.forEach(function(e){ %>
              <li class="px-5 py-3 flex gap-3 items-start">
                <span class="mt-0.5"><%- eventIcon(e.type) %></span>
                <span class="min-w-0 flex-1">
                  <span class="block text-sm text-slate-700"><%= e.message || e.type %></span>
                  <span class="block text-xs text-slate-400 mt-0.5"><%= fmt.date(e.createdAt) %><%= e.project ? ' · ' + e.project.name : '' %></span>
                </span>
              </li>
            <% }); %>
          </ul>
        <% } %>
      </div>
    </div>

  </div>
</div>
