<div class="max-w-xl">
  <% if (error) { %>
    <div class="mb-4 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm px-3 py-2"><%= error %></div>
  <% } %>
  <form method="POST" action="/admin/clients" class="space-y-5 bg-white rounded-2xl border border-slate-200 p-6">
    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">Nazwa klienta *</label>
      <input name="name" type="text" required placeholder="np. Marka XYZ"
             class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">E-mail (do wysyłki linków)</label>
        <input name="email" type="email" placeholder="kontakt@marka.pl"
               class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Telefon</label>
        <input name="phone" type="text" placeholder="np. 600 100 200"
               class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
      </div>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Firma</label>
        <input name="company" type="text" placeholder="np. Marka XYZ Sp. z o.o."
               class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Status</label>
        <select name="status" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none">
          <option value="lead">Lead</option>
          <option value="active" selected>Aktywny</option>
          <option value="inactive">Nieaktywny</option>
        </select>
      </div>
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">Tagi <span class="text-slate-400 font-normal">(po przecinku)</span></label>
      <input name="tags" type="text" placeholder="np. VIP, foto, retainer"
             class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none" />
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">Notatka (opcjonalnie)</label>
      <textarea name="note" rows="2" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none"></textarea>
    </div>
    <div class="flex items-center gap-3">
      <button type="submit" class="rounded-lg bg-brand-600 hover:bg-brand-700 text-white font-medium px-5 py-2.5 text-sm transition">Dodaj klienta</button>
      <a href="/admin/clients" class="text-sm text-slate-500 hover:text-slate-700">Anuluj</a>
    </div>
  </form>
</div>
